   3.8883137184338264`*^9}, 3.8883822498997393`*^9, {3.8883834247484217`*^9, 
   3.888383424985591*^9}, 3.8883863841619015`*^9, {3.888394854217784*^9, 
   3.8883948546868258`*^9}, 3.888399889643489*^9, 3.8884001206989126`*^9, 
   3.888400250710778*^9, {3.8884004564625115`*^9, 3.8884004567839556`*^9}, 
   3.8884006048699055`*^9, {3.8884007067661734`*^9, 3.888400717585126*^9}, 
   3.888400878965273*^9, 3.888401074647033*^9, 3.8884011779473057`*^9, 
   3.8884013069217825`*^9, 3.8884013954501605`*^9, {3.888481723984605*^9, 
   3.8884817245396657`*^9}, {3.8884818029752984`*^9, 3.88848180340248*^9}, 
   3.888481878124488*^9, {3.888481960399429*^9, 3.8884819608746185`*^9}, {
   3.8884820260872955`*^9, 3.8884820265147176`*^9}, 3.8884825292016144`*^9, 
   3.888482583201415*^9, {3.8884826962149076`*^9, 3.8884826972445607`*^9}, {
   3.888482753097562*^9, 3.8884827535867453`*^9}, 3.8884828063717775`*^9, 
   3.8884828591717467`*^9, 3.892182655176363*^9, {3.892182694571339*^9, 
   3.892182695055002*^9}, 3.8921827482826853`*^9, 3.892182790422224*^9, 
   3.8921828294978647`*^9, 3.892182878627262*^9, 3.892182927599293*^9, 
   3.892182972639331*^9, 3.892183018444195*^9, {3.892183058948018*^9, 
   3.892183059515789*^9}, 3.8921831332775717`*^9, 3.8921831970509024`*^9, 
   3.8971071815974073`*^9, {3.8979909956897926`*^9, 3.897990998571561*^9}, {
