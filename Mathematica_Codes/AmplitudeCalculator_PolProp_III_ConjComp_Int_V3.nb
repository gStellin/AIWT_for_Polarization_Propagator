Cell[BoxData[
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"u", "=", "1"}], ",", 
   RowBox[{"u", "\[LessEqual]", " ", "2880"}], ",", 
   RowBox[{"u", "++"}], ",", 
