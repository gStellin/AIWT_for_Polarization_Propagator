   3.898083084444205*^9, 3.898083085491214*^9}, 3.9095751880600643`*^9, 
   3.909575699205435*^9, 3.9095771968831463`*^9, 
   3.9405867574177265`*^9},ExpressionUUID->"ec27fbe7-fb7f-46cf-a4b7-\
