     RowBox[{"GGFTime", "[", 
      RowBox[{"[", "u", "]"}], "]"}]}], "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.8740534673734355`*^9, 3.874053486721454*^9}, {
   3.8740535363188667`*^9, 3.874053552077848*^9}, {3.874556804727316*^9, 
