   3.89807885966827*^9}, {3.898078894083348*^9, 3.8980789298986835`*^9}, {
   3.898083084444205*^9, 3.898083085491214*^9}, 3.9095751880600643`*^9, 
   3.909575699205435*^9, 3.9095771968831463`*^9, {3.9144023114331427`*^9, 
