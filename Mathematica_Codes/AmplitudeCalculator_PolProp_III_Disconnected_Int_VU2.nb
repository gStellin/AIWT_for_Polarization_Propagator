                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "=", "0"}]}],
             "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"CombDisc", "[", 
                RowBox[{"[", 
