                    RowBox[{"GGFSParticle", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}], "]"}]}], 
                    "]"}], ",", 
                    RowBox[{"GGFNambu", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]}], "]"}], 
                  ",", 
                  SubscriptBox["k", "i"]}], "]"}]}], "]"}]}]}], " ", ";", 
            "\[IndentingNewLine]", " ", 
            RowBox[{
             RowBox[{"GGFPolynomial", "[", 
