              "\[LessEqual]", " ", "4"}], ",", 
             RowBox[{
              RowBox[{"NambuDisc", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "=", "1"}]}],
             "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
