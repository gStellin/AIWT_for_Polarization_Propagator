          RowBox[{"\[Iota]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "5"], "-", 
             SubscriptBox["t", "4"]}], ")"}]}], "-", 
          RowBox[{"\[Gamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "4"], "-", 
