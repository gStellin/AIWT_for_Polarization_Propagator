              RowBox[{"TimeClassOrdMinus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
          RowBox[{"\[Iota]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "5"], "-", 
             SubscriptBox["t", "4"]}], ")"}]}], "-", 
          RowBox[{"\[Gamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "4"], "-", 
             SubscriptBox["t", "3"]}], ")"}]}], "-", 
          RowBox[{"\[Epsilon]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "3"], "-", 
             SubscriptBox["t", "2"]}], ")"}]}], "-", 
          RowBox[{"\[Digamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "2"], "-", 
             SubscriptBox["t", "1"]}], ")"}]}]}]}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
