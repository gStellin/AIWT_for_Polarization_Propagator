             RowBox[{"GGFTime", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "=", 
             RowBox[{"TimeClassOrdPlus", "[", 
              RowBox[{"[", 
               RowBox[{"T", ",", "4"}], "]"}], "]"}]}]}], "]"}], ";", " ", 
          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{"Time", " ", "Class", " ", "4"}], " ", "=", " ", 
            SubscriptBox["t", "1"]}], " ", "*)"}], "\[IndentingNewLine]", 
