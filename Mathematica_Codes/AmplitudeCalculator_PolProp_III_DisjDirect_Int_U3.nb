   3.914410058423773*^9}, {3.91457715549125*^9, 3.914577163730484*^9}, {
   3.914582251382819*^9, 
   3.914582261739478*^9}},ExpressionUUID->"557f8b47-8735-4927-9f8e-\
ce3fe4288786"],

