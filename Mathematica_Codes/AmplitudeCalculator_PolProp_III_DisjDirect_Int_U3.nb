   3.8884828591717467`*^9, 3.892182655176363*^9, {3.892182694571339*^9, 
   3.892182695055002*^9}, 3.8921827482826858`*^9, 3.892182790422224*^9, 
   3.8921828294978642`*^9, 3.892182878627262*^9, 3.892182927599293*^9, 
   3.892182972639331*^9, 3.892183018444195*^9, {3.892183058948018*^9, 
   3.892183059515789*^9}, 3.892183133277571*^9, 3.8921831970509024`*^9, 
   3.897107181597408*^9, {3.8979909956897926`*^9, 3.897990998571561*^9}, {
   3.89805346931641*^9, 3.898053569036813*^9}, {3.8980788421387177`*^9, 
   3.89807885966827*^9}, {3.898078894083348*^9, 3.8980789298986835`*^9}, {
   3.898083084444205*^9, 3.898083085491214*^9}, 3.9095751880600643`*^9, 
   3.909575699205435*^9, 3.9095771968831463`*^9, {3.90966320674636*^9, 
   3.909663230618151*^9}, 3.909666506531625*^9, 3.909666547109261*^9, 
   3.909667208041149*^9, 3.909667439204066*^9, 3.909667709277534*^9, {
