      RowBox[{
       RowBox[{
        RowBox[{"SPSequence", "[", 
         RowBox[{"[", 
          RowBox[{"r", ",", 
           RowBox[{
            RowBox[{"2", "i"}], "+", "1"}]}], "]"}], "]"}], " ", "=", " ", 
