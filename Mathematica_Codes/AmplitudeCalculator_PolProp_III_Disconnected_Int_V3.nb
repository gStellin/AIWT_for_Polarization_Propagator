            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "3"}], " ", "&&", " ", 
              RowBox[{
