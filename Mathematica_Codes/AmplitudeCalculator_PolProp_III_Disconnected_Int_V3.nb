               "\[Equal]", " ", "1"}]}], " ", ",", " ", 
             RowBox[{
              RowBox[{"SPLIndex", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "=", "\"\<q\>\""}]}], "]"}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "2"}], " ", "&&", 
              RowBox[{
               RowBox[{"GGFNambu", "[", 
