Cell[BoxData[{
 RowBox[{
  RowBox[{"T", " ", "=", " ", "5"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"r", "=", "1"}], ",", 
     RowBox[{"r", "\[LessEqual]", " ", "1524"}], ",", " ", 
     RowBox[{"r", "++"}], ",", " ", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "\[LessEqual]", " ", "8"}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"j", "=", "1"}], ",", 
         RowBox[{"j", "\[LessEqual]", "2"}], ",", 
         RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "1"}], " ", "||", " ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
