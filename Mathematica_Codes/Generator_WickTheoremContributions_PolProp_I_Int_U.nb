2bf433d667b6"],

Cell["\<\
From the application of Wick\[CloseCurlyQuote]s theorem to the following \
matrix element (cf. expansion formula of Gorkov\[CloseCurlyQuote]s \
polarization propagator),\
\>", "Text",
 CellChangeTimes->{{3.9191572317656364`*^9, 
  3.919157277263522*^9}},ExpressionUUID->"5209b591-2973-40d7-ac84-\
7d715124c44a"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["\[CapitalPi]", "acdb"], 
    RowBox[{
     SubscriptBox["g", "1"], 
     SubscriptBox["g", "3"], 
     SubscriptBox["g", "4"], 
     SubscriptBox["g", "2"]}]], TraditionalForm]],ExpressionUUID->
  "9504fdf1-306c-4f10-9cd4-b0e297cf1ecd"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"t", ",", 
      RowBox[{"t", "'"}]}], ")"}], 
    SubscriptBox["|", 
     RowBox[{"first", " ", "order"}]]}], TraditionalForm]],ExpressionUUID->
  "b2cc6e93-7290-4566-95bc-4ffa283a6d6f"],
 "     = +\[ImaginaryI] ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"-", "\[ImaginaryI]"}], "\[HBar]"], TraditionalForm]],
  ExpressionUUID->"87e83f42-54ca-44c6-80c8-292490fa6e0f"],
 " ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", 
    RowBox[{"1", "!"}]], TraditionalForm]],ExpressionUUID->
  "8eb0c503-1d1e-476e-8279-03a8a2bb0f02"],
 " ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{"\[DifferentialD]", 
    FormBox[
     SubscriptBox["t", "1"],
     TraditionalForm]}]}]],ExpressionUUID->
  "1f2c4a12-3cfe-4c9c-967d-29f54597bc87"],
 "  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[LeftAngleBracket]", 
    SubscriptBox["\[CapitalPhi]", "0"]}], TraditionalForm]],ExpressionUUID->
  "806c89fa-ffd0-479d-9e98-80e970f5c339"],
 "| T{ ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "1"]}], TraditionalForm]],ExpressionUUID->
  "799df6d1-114f-4236-b5c0-2f8cb0a8b2af"],
 ") ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["A", "Ia"], 
    SubscriptBox["g", "1"]], TraditionalForm]],ExpressionUUID->
  "9ef720a9-e76f-4b24-a33d-e80f7ddb5a05"],
 "(t)",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["A", "Ib"], 
    SubscriptBox["g", "2"]], TraditionalForm]],ExpressionUUID->
  "4356c4ef-ed65-415b-8e5b-fa7a2023e311"],
 "(t\[CloseCurlyQuote])",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["A", "Id"], 
    RowBox[{"\[Dagger]", " ", 
     SubscriptBox["g", "4"]}]], TraditionalForm]],ExpressionUUID->
  "964a8432-c5a9-4ed9-9b9b-2483d2c83057"],
 "(t\[CloseCurlyQuote])",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["A", "Ic"], 
    RowBox[{"\[Dagger]", " ", 
     SubscriptBox["g", "3"]}]], TraditionalForm]],ExpressionUUID->
  "b53d8f2a-99c6-45cc-8560-1f59f0defded"],
 "(t)| ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalPhi]", "0"], TraditionalForm]],ExpressionUUID->
  "5a74e731-40a6-4627-a961-8fc0993c8018"],
 "\[RightAngleBracket]",
 Cell[BoxData[
  FormBox[
   SubscriptBox["", "C"], TraditionalForm]],ExpressionUUID->
  "d9bfca46-ebad-44fb-ac81-b64ddfbe417f"]
}], "Text",
 CellChangeTimes->{{3.919164167700763*^9, 
  3.9191642492635837`*^9}},ExpressionUUID->"471d6479-b611-4693-ae72-\
fd8cbddf5a62"],

Cell[TextData[{
 "the fully-contracted terms consisting of 6 second-quantization operators \
are generated. The one-body potential insertion, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "1"]}], TraditionalForm]],ExpressionUUID->
  "db70f47d-8353-4cf9-a621-40cb19b95f96"],
 "), takes the form"
}], "Text",
 CellChangeTimes->{{3.9191572830495567`*^9, 
  3.9191573396307325`*^9}},ExpressionUUID->"cdcbe632-9ea9-484c-9e0e-\
03edb91d7e17"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "1"]}], TraditionalForm]],ExpressionUUID->
  "4c6f3e06-5c4a-4447-8ee0-5d794998de43"],
 ") = ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", "2"], TraditionalForm]],ExpressionUUID->
  "4ae9e3df-fa4f-4a53-ad8b-86a0afc1de62"],
 Cell[BoxData[
  RowBox[{
   UnderscriptBox["\[Sum]", "ef"], 
   RowBox[{"[", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       SubscriptBox["u", "ef"], "11"], 
      SuperscriptBox[
       SubscriptBox["a", "e"], "\[Dagger]"], 
      RowBox[{"(", 
       SubscriptBox["t", "1"], ")"}], 
      SubscriptBox["a", "f"], 
      RowBox[{"(", 
       SubscriptBox["t", "1"], ")"}]}], "+", 
     RowBox[{
      SuperscriptBox[
       SubscriptBox["u", "ef"], "22"], 
      SubscriptBox["a", 
       OverscriptBox["e", "_"]], 
      RowBox[{"(", 
       SubscriptBox["t", "1"], ")"}], 
      SuperscriptBox[
       SubscriptBox["a", 
        OverscriptBox["f", "_"]], "\[Dagger]"], 
      RowBox[{"(", 
       SubscriptBox["t", "1"], ")"}]}], "+", 
     RowBox[{
      SuperscriptBox[
       SubscriptBox["u", "ef"], "12"], 
      SuperscriptBox[
       SubscriptBox["a", "e"], "\[Dagger]"], 
      RowBox[{"(", 
       SubscriptBox["t", "1"], ")"}], 
      SuperscriptBox[
       SubscriptBox["a", 
        OverscriptBox["f", "_"]], "\[Dagger]"], 
      RowBox[{"(", 
       SubscriptBox["t", "1"], ")"}]}], "+", 
     RowBox[{
      SuperscriptBox[
       SubscriptBox["u", "ef"], "21"], 
      SubscriptBox["a", 
       OverscriptBox["e", "_"]], 
      RowBox[{"(", 
       SubscriptBox["t", "1"], ")"}], 
      SubscriptBox["a", "f"], 
      RowBox[{"(", 
       SubscriptBox["t", "1"], ")"}]}]}], "]"}]}]],ExpressionUUID->
  "e9abe07b-b4e2-48bc-a76e-88b6ac22c757"],
 "."
}], "Text",
 CellChangeTimes->{3.9191641847034383`*^9, 
  3.9191642676324244`*^9},ExpressionUUID->"b994e4e2-abf5-4ce4-936b-\
65a312bf347c"],

Cell[TextData[{
 "Due to the presence of a one-body interaction vertex, the number of \
distinct fully-contracted terms of ",
 StyleBox["6",
  FontSlant->"Italic"],
 " second quantization operators at first order corresponds to 5",
 StyleBox["!! = 15",
  FontSlant->"Italic"],
 ". The results of the generation process hold identically for all the 4 \
Nambu components of the one-body potential and are the same for each of the ",
 StyleBox["16",
  FontSlant->"Italic"],
 " Nambu components of Gorkov\[CloseCurlyQuote]s polarization propagator.  A \
significant part of these Wick\[CloseCurlyQuote]s-theorem contributions has \
to be discarded, since it corresponds either to disconnected diagrams or to \
exchange diagrams that are cancelled by the subtractive term of the \
polarization propagator.  At first order, no conjoint diagram containing a \
one-body interaction vertex exists. Additionally, since the one-body \
potential is not invariant under permutation of the two indices, no \
filtration process applies at first order, as only one interaction vertex is \
present. The fully-contracted terms are, thus, inequivalent. "
}], "Text",
 CellChangeTimes->{{3.874645469364807*^9, 3.874645558141898*^9}, {
  3.8746455892271357`*^9, 3.8746458332056046`*^9}, {3.8746520484004583`*^9, 
  3.8746520621013403`*^9}, {3.8836800758523192`*^9, 3.883680077052704*^9}, {
  3.8895283433205495`*^9, 3.889528365465126*^9}, {3.9118800207592287`*^9, 
  3.9118800274714775`*^9}, {3.9118800633231573`*^9, 3.911880196411795*^9}, {
  3.9120685309910316`*^9, 3.9120685468340797`*^9}, {3.91207110568344*^9, 
  3.9120711423537416`*^9}, {3.9120711781541443`*^9, 3.9120713019889345`*^9}, {
  3.912073198438121*^9, 3.912073235257908*^9}, {3.9120732842981143`*^9, 
  3.9120732894814386`*^9}, {3.9120734122331514`*^9, 
  3.9120735423580775`*^9}},ExpressionUUID->"6b9ce1b1-18e0-4672-949f-\
9748a7226dc5"],

