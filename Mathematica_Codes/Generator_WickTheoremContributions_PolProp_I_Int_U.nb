Cell["\<\
The alphabetic single-particle indices of the second-quantization operators \
are converted into positive integers by means of the following map:\
\>", "Text",
 CellChangeTimes->{{3.911880385154636*^9, 3.911880500879594*^9}, {
  3.9191571050534687`*^9, 
  3.919157146558923*^9}},ExpressionUUID->"49398fc3-870a-48f1-9562-\
0bac4b2abd43"],

Cell[TextData[{
 "\n",
 Cell[BoxData[GridBox[{
    {"e", "f", "a", "b", "d", "c"},
    {"1", "2", "3", "4", "5", "6"}
   },
   GridBoxDividers->{"Columns" -> {{True}}, "Rows" -> {{True}}}]],
  ExpressionUUID->"eb2fc847-e7de-4553-a576-3e156b83c9c5"]
}], "Text",
 CellChangeTimes->{{3.8746528633189774`*^9, 3.8746529425611305`*^9}, {
   3.8895283862467823`*^9, 3.889528411462181*^9}, 3.911880364486044*^9, {
   3.9120713124011545`*^9, 3.9120713847791314`*^9}, {3.9228774447979956`*^9, 
   3.922877449546419*^9}},ExpressionUUID->"db503fce-2f92-400f-b6d4-\
496dea2a191e"],

Cell["\<\
as such, the single-particle indices are stored into arrays (cf. \
\[OpenCurlyQuote]Acomb\[CloseCurlyQuote], \[OpenCurlyQuote]Acombsort\
\[CloseCurlyQuote], \[OpenCurlyQuote]AdisjBogoDiag\[CloseCurlyQuote] et c.).\
\>", "Text",
 CellChangeTimes->{{3.9191571533049364`*^9, 
  3.9191572059589853`*^9}},ExpressionUUID->"21ea8b1f-c6f0-45c9-9ded-\
a5df5ecea742"],

Cell[CellGroupData[{

Cell["Generation of the first-order fully-contracted terms", "Section",
 CellChangeTimes->{{3.8746447213615894`*^9, 3.874644731124649*^9}, {
  3.8746447691271086`*^9, 3.87464477328621*^9}, {3.8746449100185723`*^9, 
  3.87464492347766*^9}, {3.883683441766288*^9, 3.8836834625750504`*^9}, {
  3.889528469300623*^9, 3.889528470058614*^9}, {3.912071408740595*^9, 
  3.912071413061755*^9}},ExpressionUUID->"8a2cad12-419c-4822-97e2-\
f2ee066799c1"],

Cell[TextData[{
 "The first-order fully-contracted terms are found to be ",
 StyleBox["15",
  FontSlant->"Italic"],
 " in total, consistently with the formula 2",
 StyleBox["n+3!!",
  FontSlant->"Italic"],
 " with ",
 StyleBox["n=1",
  FontSlant->"Italic"],
 ". Binary contractions belonging to the same fully contracted term (index ",
 StyleBox["i",
  FontSlant->"Italic"],
 " in the array initialization) are denoted by the index ",
 StyleBox["j",
  FontSlant->"Italic"],
 ". The two single particle indices within the same contraction are \
distinguished by the index ",
 StyleBox["k",
  FontSlant->"Italic"],
 ". The process produces no repeated pairs, by construction."
}], "Text",
 CellChangeTimes->{{3.8836835314266734`*^9, 3.8836835815187073`*^9}, {
   3.8895284734892464`*^9, 3.88952848309838*^9}, {3.889528810988242*^9, 
   3.8895288112887807`*^9}, {3.8928028631906576`*^9, 3.892802871599965*^9}, {
   3.911881134541976*^9, 3.9118812354750347`*^9}, 3.911881272452093*^9, {
   3.911881422437512*^9, 3.9118814376624393`*^9}, {3.912073354383882*^9, 
   3.9120733574660673`*^9}, {3.913783002650666*^9, 
   3.913783009306058*^9}},ExpressionUUID->"0a9486f9-8593-4660-8393-\
789162f5e142"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"l", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Acomb", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "20"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "3"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Acomb", "[", 
    RowBox[{"[", "l", "]"}], "]"}], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"3", ",", "4"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"5", ",", "6"}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"g", "=", "1"}], ",", 
    RowBox[{"g", "\[LessEqual]", "5"}], ",", 
    RowBox[{"g", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"growind", " ", "=", " ", "1"}], ";", "\[IndentingNewLine]", 
     RowBox[{"gcolind", " ", "=", " ", "2"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"h", "=", "1"}], ",", 
       RowBox[{"h", "\[LessEqual]", "3"}], ",", 
       RowBox[{"h", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"hrowind", " ", "=", " ", "2"}], ";", "\[IndentingNewLine]", 
        RowBox[{"hcolind", " ", "=", " ", "2"}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Acomb", "[", 
          RowBox[{"[", "l", "]"}], "]"}], " ", "=", " ", 
         RowBox[{"Acomb", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"g", "\[NotEqual]", "1"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"growpiv", " ", "=", " ", 
            RowBox[{
             RowBox[{"Floor", "[", 
              RowBox[{"g", "/", "2"}], "]"}], "+", "1"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"gcolpiv", " ", "=", 
            RowBox[{
             RowBox[{"-", " ", 
              RowBox[{"Floor", "[", 
               RowBox[{"g", "/", "2"}], "]"}]}], "+", 
             RowBox[{"Ceiling", "[", 
              RowBox[{"g", "/", "2"}], "]"}], "+", "1"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Acomb", "[", 
             RowBox[{"[", 
              RowBox[{"l", ",", "growind", ",", "gcolind"}], "]"}], "]"}], 
            "=", " ", 
            RowBox[{"Acomb", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "growpiv", ",", "gcolpiv"}], "]"}], "]"}]}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Acomb", "[", 
             RowBox[{"[", 
              RowBox[{"l", ",", "growpiv", ",", "gcolpiv"}], "]"}], "]"}], 
            " ", "=", " ", 
            RowBox[{"Acomb", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "growind", ",", "gcolind"}], "]"}], 
             "]"}]}]}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"h", "\[NotEqual]", "1"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"hrowpiv", " ", "=", " ", 
            RowBox[{
             RowBox[{"Floor", "[", 
              RowBox[{"h", "/", "2"}], "]"}], "+", "2"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"hcolpiv", " ", "=", 
            RowBox[{
             RowBox[{"-", " ", 
              RowBox[{"Floor", "[", 
               RowBox[{"h", "/", "2"}], "]"}]}], "+", 
             RowBox[{"Ceiling", "[", 
              RowBox[{"h", "/", "2"}], "]"}], "+", "1"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"Atemp1", " ", "=", " ", 
            RowBox[{"Acomb", "[", 
             RowBox[{"[", 
              RowBox[{"l", ",", "hrowind", ",", "hcolind"}], "]"}], "]"}]}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{"Atemp2", "=", " ", 
            RowBox[{"Acomb", "[", 
             RowBox[{"[", 
              RowBox[{"l", ",", "hrowpiv", ",", "hcolpiv"}], "]"}], "]"}]}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Acomb", "[", 
             RowBox[{"[", 
              RowBox[{"l", ",", "hrowind", ",", "hcolind"}], "]"}], "]"}], 
            " ", "=", " ", "Atemp2"}], ";", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Acomb", "[", 
             RowBox[{"[", 
              RowBox[{"l", ",", "hrowpiv", ",", "hcolpiv"}], "]"}], "]"}], 
            " ", "=", " ", "Atemp1"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"l", "++"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"g", "\[Equal]", "5"}], ",", 
       RowBox[{"Print", "[", 
        RowBox[{
        "\"\<Loop \>\"", ",", " ", "g", ",", " ", "\"\< completed and \>\"", 
         ",", " ", 
         RowBox[{"l", "-", "1"}], ",", " ", 
         "\"\< Wick's-theorem contributions generated.\>\""}], "]"}]}], 
      "]"}]}]}], "]"}], ";"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.8738091425145903`*^9, 3.873809410270079*^9}, {
   3.8738094443709345`*^9, 3.873809578503976*^9}, {3.8738804069801064`*^9, 
