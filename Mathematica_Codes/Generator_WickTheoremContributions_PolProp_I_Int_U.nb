   3.873881214896164*^9, 3.8738812366130633`*^9}, {3.8738812692293653`*^9, 
   3.8738814232756824`*^9}, {3.8738814651303086`*^9, 
   3.8738814831603804`*^9}, {3.873881532001392*^9, 3.8738815364285913`*^9}, {
