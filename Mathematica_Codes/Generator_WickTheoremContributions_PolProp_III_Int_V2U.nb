Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"AdisjExcAboveCombFile", "=", 
    RowBox[{"OpenWrite", "[", 
     RowBox[{
     "\"\<E:\\\\Mathematica's AIWT for the Polarization \
Propagator\\\\Contractions\\\\Out_Comb_3_DisjExcAbove_V2U.m\>\"", ",", 
      RowBox[{"PageWidth", "->", "Infinity"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"u", "=", "1"}], ",", 
     RowBox[{"u", "\[LessEqual]", " ", "340"}], ",", 
     RowBox[{"u", "++"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"WriteString", "[", 
       RowBox[{
       "AdisjExcAboveCombFile", ",", "\"\<CombExcAbove[[\>\"", ",", " ", "u", 
        ",", " ", "\"\<]] = \>\"", ",", " ", 
