Cell["\<\
Printing the ensuing conjoint composite fully-contracted terms into files, \
for the carrying-out of the filtration process.\
\>", "Text",
 CellChangeTimes->{{3.8947151231578183`*^9, 3.894715138802438*^9}, {
  3.9119814525080276`*^9, 3.9119815137896814`*^9}, {3.911983649917075*^9, 
  3.911983652683584*^9}, {3.9119841639459877`*^9, 3.911984167011745*^9}, {
  3.914329560975436*^9, 
  3.9143295645236363`*^9}},ExpressionUUID->"f82e507b-835a-4a08-b2eb-\
821d2ae6eb8b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"AconjCompFile", "=", 
    RowBox[{"OpenWrite", "[", 
     RowBox[{
     "\"\<E:\\\\Mathematica's AIWT for the Polarization \
Propagator\\\\Contractions\\\\In_Comb_3_ConjComp_V2U.h\>\"", ",", 
      RowBox[{"PageWidth", "->", "Infinity"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"u", "=", "1"}], ",", 
     RowBox[{"u", "\[LessEqual]", " ", "48384"}], ",", 
     RowBox[{"u", "++"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"WriteString", "[", 
       RowBox[{"AconjCompFile", ",", "\"\<AconjComp[\>\"", ",", " ", 
        RowBox[{"u", "-", "1"}], ",", " ", "\"\<] = {\>\"", ",", " ", 
        RowBox[{"Aconjsort", "[", 
         RowBox[{"[", "u", "]"}], "]"}], ",", "\"\<};\\n\>\""}], "]"}], 
      ";"}]}], "\[IndentingNewLine]", "]"}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Close", "[", "AconjCompFile", "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.890741831453683*^9, 3.890742008781371*^9}, {
   3.890746074974007*^9, 3.890746079115465*^9}, {3.892093113445965*^9, 
   3.8920933369583397`*^9}, {3.892093380254797*^9, 3.8920934201049285`*^9}, {
   3.8920935164521523`*^9, 3.8920936157274017`*^9}, {3.8920937892827215`*^9, 
   3.892093839952821*^9}, {3.892093891095197*^9, 3.8920939299006124`*^9}, {
   3.9119842026278677`*^9, 3.911984230452499*^9}, {3.911993936107671*^9, 
   3.9119939615330114`*^9}, 3.911994164787512*^9, {3.9119963599753513`*^9, 
   3.9119963652842503`*^9}, {3.9119964383966293`*^9, 3.911996443192114*^9}, {
   3.9119978289037714`*^9, 3.911997843996352*^9}, {3.911998015368727*^9, 
   3.911998015747163*^9}, {3.913975790067034*^9, 3.913976081167094*^9}, {
   3.913976242975524*^9, 3.9139762637570105`*^9}, {3.9140589449909363`*^9, 
   3.91405894662018*^9}, {3.914303681236139*^9, 3.9143036822734365`*^9}, {
   3.914328487205469*^9, 3.9143285346050644`*^9}, {3.9143286243730545`*^9, 
   3.9143286705061913`*^9}, {3.9143287011304417`*^9, 3.914328741499685*^9}, {
   3.91433105100957*^9, 3.914331051448552*^9}, {3.914388089416887*^9, 
