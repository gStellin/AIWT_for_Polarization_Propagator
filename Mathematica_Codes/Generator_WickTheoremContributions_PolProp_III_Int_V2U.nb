 RowBox[{
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"u", "=", "1"}], ",", 
     RowBox[{"u", "\[LessEqual]", " ", "328"}], ",", 
     RowBox[{"u", "++"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"WriteString", "[", 
       RowBox[{
       "AdisjBogoliubovCombFile", ",", "\"\<CombBog[[\>\"", ",", " ", "u", 
        ",", " ", "\"\<]] = \>\"", ",", " ", 
        RowBox[{"AdbVertex", "[", 
