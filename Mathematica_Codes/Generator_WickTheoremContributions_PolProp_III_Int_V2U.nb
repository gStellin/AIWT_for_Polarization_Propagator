Cell["\<\
Printing the ensuing disconnected fully-contracted terms into files, for the \
carrying-out of the filtration process.\
\>", "Text",
 CellChangeTimes->{{3.8947151231578183`*^9, 3.894715138802438*^9}, {
  3.9119814525080276`*^9, 3.9119815137896814`*^9}, {3.911983649917075*^9, 
  3.911983652683584*^9}, {3.9119841639459877`*^9, 
  3.911984167011745*^9}},ExpressionUUID->"7f43e48c-4e22-43bb-88e0-\
86a2f74a214e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"AdiscFile", "=", 
    RowBox[{"OpenWrite", "[", 
     RowBox[{
     "\"\<E:\\\\ADG for the Polarization Propagator with Alphabetic indices\\\
\\Contractions\\\\In_Comb_3_Disconnected_V2U.h\>\"", ",", 
      RowBox[{"PageWidth", "->", "Infinity"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"u", "=", "1"}], ",", 
     RowBox[{"u", "\[LessEqual]", " ", "21087"}], ",", 
     RowBox[{"u", "++"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"WriteString", "[", 
       RowBox[{"AdiscFile", ",", "\"\<Adisc[\>\"", ",", " ", 
        RowBox[{"u", "-", "1"}], ",", " ", "\"\<] = {\>\"", ",", " ", 
        RowBox[{"Adiscsort", "[", 
         RowBox[{"[", "u", "]"}], "]"}], ",", "\"\<};\\n\>\""}], "]"}], 
      ";"}]}], "\[IndentingNewLine]", "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"Close", "[", "AdiscFile", "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.890741831453683*^9, 3.890742008781371*^9}, {
