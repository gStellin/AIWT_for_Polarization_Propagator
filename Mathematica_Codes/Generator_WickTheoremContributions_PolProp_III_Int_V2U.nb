 RowBox[{
  RowBox[{
   RowBox[{"AdisjBogoliubovCombFile", "=", 
    RowBox[{"OpenWrite", "[", 
     RowBox[{
     "\"\<E:\\\\Mathematica's AIWT for the Polarization \
