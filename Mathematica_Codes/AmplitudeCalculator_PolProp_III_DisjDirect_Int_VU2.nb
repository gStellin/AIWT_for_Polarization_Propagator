Cell[CellGroupData[{

Cell["\<\
Assignment of the time indices, based on the canonical ordering\
\>", "Subsection",
 CellChangeTimes->{{3.888315861110175*^9, 3.8883159051561947`*^9}, {
  3.8983468473701744`*^9, 
  3.8983468556580143`*^9}},ExpressionUUID->"bc51d001-37ac-4e24-aa85-\
7a70ccc02eb6"],

Cell[TextData[{
 "Times are sorted in ascending order: \[OpenCurlyQuote]5\[CloseCurlyQuote] \
is the latest time and denotes t, \[OpenCurlyQuote]4\[CloseCurlyQuote] \
denotes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "1"], TraditionalForm]],ExpressionUUID->
  "45818797-04f3-495e-bd9f-9b2703083075"],
 ",  \[OpenCurlyQuote]3\[CloseCurlyQuote] denotes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "2"], TraditionalForm]],ExpressionUUID->
  "8c55d9a9-da4c-4820-9657-162e4f89f3e0"],
 " and \[OpenCurlyQuote]2\[CloseCurlyQuote] denotes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "3"], TraditionalForm]],ExpressionUUID->
  "7876dd80-519f-44be-b93e-50cf92764540"],
 " . The earliest time is \[OpenCurlyQuote]1\[CloseCurlyQuote] and denotes t\
\[CloseCurlyQuote]."
