Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NtL", "[", "s_", "]"}], ":=", 
   RowBox[{"(", " ", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
