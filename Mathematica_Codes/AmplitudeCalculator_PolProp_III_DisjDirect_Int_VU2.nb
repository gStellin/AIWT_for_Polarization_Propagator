   3.914400389393113*^9, 3.9144004010725803`*^9}, {3.914475138168889*^9, 
   3.914475148262451*^9}},
 CellLabel->
  "In[110]:=",ExpressionUUID->"f885bfca-f738-46f0-8f85-98b7f091fbc0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", "NcMax"}], ",", 
    RowBox[{"r", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "0"}], ",", 
      RowBox[{"i", "\[LessEqual]", " ", "5"}], ",", " ", 
      RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"SPSequence", "[", 
         RowBox[{"[", 
          RowBox[{"r", ",", 
           RowBox[{
            RowBox[{"2", "i"}], "+", "1"}]}], "]"}], "]"}], " ", "=", " ", 
        RowBox[{"Abs", "[", 
         RowBox[{"GGFSParticle", "[", 
          RowBox[{"[", 
           RowBox[{"r", ",", 
