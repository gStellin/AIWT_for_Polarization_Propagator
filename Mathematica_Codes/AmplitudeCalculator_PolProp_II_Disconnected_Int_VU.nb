Cell[CellGroupData[{

Cell["Definition of the auxiliary arrays", "Subsection",
 CellChangeTimes->{{3.888315173503672*^9, 3.888315249112604*^9}, {
  3.8883153026090937`*^9, 3.8883153149727306`*^9}, {3.888315800792353*^9, 
  3.888315802330164*^9}, {3.9077382535011215`*^9, 3.907738255398263*^9}, {
  3.9079184731747074`*^9, 
  3.9079185042453585`*^9}},ExpressionUUID->"12b958e5-4fd2-41f2-9a2b-\
d891c432de91"],

Cell["\<\
Arrays specifying the Nambu indices (cf. NambuDisc), the operator type (cf. \
SQTypeDisc) and distinguishing internal from external single-particle indices \
(cf. IntExtDisc) are defined, in accordance with the conventions for the \
second-quantization operators in the header of the notebook. In particular, \
to external (internal) single-particle indices the value of \
\[OpenCurlyQuote]1\[CloseCurlyQuote] (\[OpenCurlyQuote]0\[CloseCurlyQuote]) \
is assigned, whereas for second-quantization operators of creation \
(annihilation) type the associated array entry is \[OpenCurlyQuote]0\
\[CloseCurlyQuote] (\[OpenCurlyQuote]1\[CloseCurlyQuote]). For Nambu indices, \
the convention is straightforward.\
\>", "Text",
 CellChangeTimes->{
  3.9077382215659647`*^9, {3.9077382923703613`*^9, 3.9077384065565405`*^9}, {
   3.9077384522680173`*^9, 3.9077384848449383`*^9}, {3.9077430709590244`*^9, 
   3.907743126073769*^9}, {3.9077450424291105`*^9, 3.9077450765315623`*^9}, {
   3.907918517166184*^9, 3.9079188444385033`*^9}, 3.9091515935484114`*^9, {
   3.9092041717880774`*^9, 3.9092041805155473`*^9}, {3.9132169785788927`*^9, 
   3.9132169909095335`*^9}, {3.9216940487946424`*^9, 
   3.921694048812784*^9}},ExpressionUUID->"ef7a44d0-7aa6-40e7-948e-\
fff4913d8d7e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"NambuDisc", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "72"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "5"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", " ", "72"}], ",", 
    RowBox[{"r", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"j", "=", "1"}], ",", 
       RowBox[{"j", "\[LessEqual]", " ", "5"}], ",", 
       RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"k", "=", "1"}], ",", 
          RowBox[{"k", "\[LessEqual]", "2"}], ",", 
          RowBox[{"k", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"CombDisc", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], 
              "\[LessEqual]", " ", "4"}], ",", 
             RowBox[{
              RowBox[{"NambuDisc", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "=", "1"}]}],
             "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"CombDisc", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "\[Equal]", 
              "  ", "5"}], ",", 
             RowBox[{
              RowBox[{"NambuDisc", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "=", 
              RowBox[{"UNambu", "[", 
               RowBox[{"[", 
                RowBox[{"NuIdx", ",", "1"}], "]"}], "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"CombDisc", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "\[Equal]", 
              "  ", "6"}], ",", 
             RowBox[{
              RowBox[{"NambuDisc", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "=", 
              RowBox[{"UNambu", "[", 
               RowBox[{"[", 
                RowBox[{"NuIdx", ",", "2"}], "]"}], "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"CombDisc", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "\[Equal]", 
              "7"}], ",", 
             RowBox[{
              RowBox[{"NambuDisc", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "=", 
              RowBox[{"GPPNambu", "[", 
               RowBox[{"[", 
                RowBox[{"NppIdx", ",", "1"}], "]"}], "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"CombDisc", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "\[Equal]", 
              "8"}], ",", 
             RowBox[{
              RowBox[{"NambuDisc", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "=", 
              RowBox[{"GPPNambu", "[", 
               RowBox[{"[", 
                RowBox[{"NppIdx", ",", "4"}], "]"}], "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"CombDisc", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "\[Equal]", 
              "9"}], ",", 
             RowBox[{
              RowBox[{"NambuDisc", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "=", 
              RowBox[{"GPPNambu", "[", 
               RowBox[{"[", 
                RowBox[{"NppIdx", ",", "3"}], "]"}], "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"CombDisc", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "\[Equal]", 
              "10"}], ",", 
             RowBox[{
              RowBox[{"NambuDisc", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "=", 
              RowBox[{"GPPNambu", "[", 
               RowBox[{"[", 
                RowBox[{"NppIdx", ",", "2"}], "]"}], "]"}]}]}], "]"}], 
           ";"}]}], "\[IndentingNewLine]", "]"}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]}], "Input",
