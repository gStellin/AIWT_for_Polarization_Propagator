   3.888411778188436*^9}, {3.889588714939645*^9, 3.889588725167736*^9}, {
   3.9079188968094006`*^9, 3.907918957686596*^9}, 3.913217058095791*^9, 
   3.9216940525186195`*^9},ExpressionUUID->"290ad14f-d394-47d3-b4b9-\
2bed8713ccdf"],

