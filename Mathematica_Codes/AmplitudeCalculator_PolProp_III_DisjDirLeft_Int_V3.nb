                   RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]], "/", 
                "\[HBar]"}]}]}]}]}], ",", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"GGFAmplitude", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i"}], "]"}], "]"}], " ", "=", 
             RowBox[{
