              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}]}]}], "]"}], 
         ";"}]}], "\[IndentingNewLine]", "]"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "\[LessEqual]", " ", "2"}], ",", 
