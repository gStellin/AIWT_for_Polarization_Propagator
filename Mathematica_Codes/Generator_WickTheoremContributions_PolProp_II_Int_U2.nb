Cell["\<\
The alphabetic single-particle indices of the second-quantization operators \
are converted into positive integers by means of the following map:\
\>", "Text",
 CellChangeTimes->{{3.911880385154636*^9, 3.911880500879594*^9}, {
  3.9191646494867616`*^9, 
  3.9191646558669205`*^9}},ExpressionUUID->"802339e9-2950-4feb-808f-\
dc7f8b722c23"],

Cell[TextData[Cell[BoxData[GridBox[{
   {"e", "f", "g", "h", "a", "b", "d", "c"},
   {"1", "2", "3", "4", "5", "6", "7", "8"}
  },
  GridBoxDividers->{
   "Columns" -> {{True}}, 
    "Rows" -> {{
      True}}}]],ExpressionUUID->"0540ce97-019b-4b39-b1e9-ba02c862ffe0"]], \
"Text",
 CellChangeTimes->{{3.9121549338431396`*^9, 
  3.9121549577229333`*^9}},ExpressionUUID->"a1f88935-032a-40cd-8bb9-\
39db17a902b3"],

Cell["\<\
as such, the single-particle indices are stored into arrays (cf. \
\[OpenCurlyQuote]Acomb\[CloseCurlyQuote], \[OpenCurlyQuote]Acombsort\
\[CloseCurlyQuote], \[OpenCurlyQuote]AdisjBogoDiag\[CloseCurlyQuote] et c.).\
\>", "Text",
 CellChangeTimes->{
  3.9191646656828294`*^9},ExpressionUUID->"c151db15-996b-4251-b3f8-\
66a66fe35a7c"],

Cell[CellGroupData[{

Cell["Generation of the second-order fully-contracted terms", "Section",
 CellChangeTimes->{{3.8746447213615894`*^9, 3.874644731124649*^9}, {
  3.8746447691271086`*^9, 3.87464477328621*^9}, {3.8746449100185723`*^9, 
  3.87464492347766*^9}, {3.883683441766288*^9, 3.8836834625750504`*^9}, {
  3.889528469300623*^9, 3.889528470058614*^9}, {3.912071408740595*^9, 
  3.912071413061755*^9}, {3.912155925123152*^9, 
  3.9121559259303045`*^9}},ExpressionUUID->"a65f2743-cc78-4e55-95a0-\
21fa375017bb"],

Cell[TextData[{
 "The second-order fully-contracted terms are found to be ",
 StyleBox["105",
  FontSlant->"Italic"],
 " in total, consistently with the formula 2",
 StyleBox["n+3!!",
  FontSlant->"Italic"],
 " with ",
 StyleBox["n=2",
  FontSlant->"Italic"],
 ". Binary contractions belonging to the same fully contracted term (index ",
 StyleBox["i",
  FontSlant->"Italic"],
 " in the array initialization) are denoted by the index ",
 StyleBox["j",
  FontSlant->"Italic"],
 ". The two single particle indices within the same contraction are \
distinguished by the index ",
 StyleBox["k",
  FontSlant->"Italic"],
 ". The process produces no repeated pairs, by construction."
}], "Text",
 CellChangeTimes->{{3.8836835314266734`*^9, 3.8836835815187073`*^9}, {
   3.8895284734892464`*^9, 3.88952848309838*^9}, {3.889528810988242*^9, 
   3.8895288112887807`*^9}, {3.8928028631906576`*^9, 3.892802871599965*^9}, {
   3.911881134541976*^9, 3.9118812354750347`*^9}, 3.911881272452093*^9, {
   3.911881422437512*^9, 3.9118814376624393`*^9}, {3.9120733082131915`*^9, 
   3.912073318767561*^9}, {3.9121559360774364`*^9, 3.9121559501008615`*^9}, {
   3.9137829713078756`*^9, 
   3.9137829761140776`*^9}},ExpressionUUID->"bde85c48-390c-42ee-8d12-\
55df0df50599"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"l", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Acomb", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "150"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "4"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Acomb", "[", 
    RowBox[{"[", "l", "]"}], "]"}], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"3", ",", "4"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"5", ",", "6"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"7", ",", "8"}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"g", "=", "1"}], ",", 
    RowBox[{"g", "\[LessEqual]", "7"}], ",", 
    RowBox[{"g", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"growind", " ", "=", " ", "1"}], ";", "\[IndentingNewLine]", 
     RowBox[{"gcolind", " ", "=", " ", "2"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"h", "=", "1"}], ",", 
       RowBox[{"h", "\[LessEqual]", "5"}], ",", 
       RowBox[{"h", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"hrowind", " ", "=", " ", "2"}], ";", "\[IndentingNewLine]", 
        RowBox[{"hcolind", " ", "=", " ", "2"}], ";", "\[IndentingNewLine]", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"i", "=", "1"}], ",", 
          RowBox[{"i", "\[LessEqual]", " ", "3"}], ",", 
          RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"irowind", " ", "=", " ", "3"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"icolind", " ", "=", " ", "2"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Acomb", "[", 
             RowBox[{"[", "l", "]"}], "]"}], " ", "=", " ", 
            RowBox[{"Acomb", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"g", "\[NotEqual]", "1"}], ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"growpiv", " ", "=", " ", 
               RowBox[{
                RowBox[{"Floor", "[", 
                 RowBox[{"g", "/", "2"}], "]"}], "+", "1"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"gcolpiv", " ", "=", 
               RowBox[{
                RowBox[{"-", " ", 
                 RowBox[{"Floor", "[", 
                  RowBox[{"g", "/", "2"}], "]"}]}], "+", 
                RowBox[{"Ceiling", "[", 
                 RowBox[{"g", "/", "2"}], "]"}], "+", "1"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"Acomb", "[", 
                RowBox[{"[", 
                 RowBox[{"l", ",", "growind", ",", "gcolind"}], "]"}], "]"}], 
               "=", " ", 
               RowBox[{"Acomb", "[", 
                RowBox[{"[", 
                 RowBox[{"1", ",", "growpiv", ",", "gcolpiv"}], "]"}], 
                "]"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"Acomb", "[", 
                RowBox[{"[", 
                 RowBox[{"l", ",", "growpiv", ",", "gcolpiv"}], "]"}], "]"}], 
               " ", "=", " ", 
               RowBox[{"Acomb", "[", 
                RowBox[{"[", 
                 RowBox[{"1", ",", "growind", ",", "gcolind"}], "]"}], 
                "]"}]}]}]}], "]"}], ";", "\[IndentingNewLine]", 
