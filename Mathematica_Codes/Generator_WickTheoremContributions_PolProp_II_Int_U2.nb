Cell["\<\
There are only 8 second-order below-dressed disjoint exchange diagrams with \
non-identical one-body vertices. The multiplicity check is fulfilled.\
\>", "Text",
 CellChangeTimes->{{3.9123230368435626`*^9, 3.9123230551958413`*^9}, {
   3.912323659514346*^9, 3.9123236716412516`*^9}, 3.9123313086853094`*^9, {
   3.912333581512753*^9, 3.9123335898394504`*^9}, {3.912333775753584*^9, 
   3.912333776539037*^9}, {3.9123342347764444`*^9, 3.9123342404981174`*^9}, {
   3.912334296029745*^9, 3.9123342966023417`*^9}, {3.9138010034698706`*^9, 
   3.9138010045299683`*^9}},ExpressionUUID->"3f4d1270-3617-4132-88fd-\
a0f73cea5497"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Below-dressed disjoint exchange diagrams with identical one-body vertices\
\>", "Subsection",
 CellChangeTimes->{{3.9123225301750393`*^9, 3.9123225545237913`*^9}, {
  3.9123287170256085`*^9, 3.9123287269030876`*^9}, {3.9123287756441975`*^9, 
  3.9123287890502768`*^9}, {3.912331148095069*^9, 
  3.9123311488457975`*^9}},ExpressionUUID->"5a64df40-04e1-4d54-a346-\
1036068c03e2"],

Cell["\<\
Depending on the components of the one-body potential into play, symmetry \
rules may apply and reduce the total number of fully-contracted terms. When \
the multiplied Nambu components of the one-body potential are identical, \
vertex exchange is possible, hence the filtration process is necessary. \
Specifically, fully contracted terms which are mapped one another by the \
single-particle-index transposition e \[RightTeeArrow]g \[Wedge] f \
\[RightTeeArrow] h are equivalent, thus one of the two can be dropped, \
incrementing the associated multiplicity by unity. In the end of the process, \
4 inequivalent fully-contracted terms corresponding to below-dressed disjoint \
exchange diagrams are found.  \
\>", "Text",
 CellChangeTimes->{{3.8836806708732624`*^9, 3.883680671103075*^9}, {
   3.8836807100445924`*^9, 3.8836809748029747`*^9}, {3.88368106035993*^9, 
   3.88368123630155*^9}, {3.8884066008391533`*^9, 3.8884066027299986`*^9}, {
   3.889531897043619*^9, 3.889531903637968*^9}, {3.8895328025200243`*^9, 
   3.889532803452654*^9}, 3.9118851261633663`*^9, {3.911885313489254*^9, 
   3.9118853244102707`*^9}, {3.911885420747136*^9, 3.9118854315063624`*^9}, {
   3.9118860757937164`*^9, 3.911886076363371*^9}, {3.9118863981279774`*^9, 
   3.911886399679015*^9}, {3.9123232066276617`*^9, 3.9123232476938877`*^9}, {
   3.9123233347954187`*^9, 3.912323606712844*^9}, {3.912335104884133*^9, 
   3.91233512664951*^9}, 3.912335585399894*^9, {3.912336753830852*^9, 
   3.912336763901738*^9}, {3.9123372882726345`*^9, 
   3.912337289974387*^9}},ExpressionUUID->"30ed24cd-6790-4c9b-9970-\
088441f00259"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"AdcebVertex", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "8"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "4"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MultdcebVertex", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "8"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ifrepeat", "=", " ", "False"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Temp", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "4"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"IfTemp", " ", "=", 
    RowBox[{"Table", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "2"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "4"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"s", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"AdcebVertex", "[", 
    RowBox[{"[", "1", "]"}], "]"}], " ", "=", " ", 
   RowBox[{"AdisjExchBelow", "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"MultdcebVertex", "[", 
    RowBox[{"[", "1", "]"}], "]"}], "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"u", "=", "1"}], ",", 
   RowBox[{"u", "\[LessEqual]", "8"}], ",", 
   RowBox[{"u", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "\[LessEqual]", "4"}], ",", 
      RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
