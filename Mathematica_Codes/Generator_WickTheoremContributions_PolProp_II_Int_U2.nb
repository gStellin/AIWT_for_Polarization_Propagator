  3.912073198438121*^9, 3.912073235257908*^9}, {3.9120732842981143`*^9, 
  3.9120732894814386`*^9}, {3.9120734122331514`*^9, 3.9120735423580775`*^9}, {
  3.9121548014500785`*^9, 
  3.91215491376841*^9}},ExpressionUUID->"9a996220-54bd-4c59-a371-\
2cad9a54fb70"],

