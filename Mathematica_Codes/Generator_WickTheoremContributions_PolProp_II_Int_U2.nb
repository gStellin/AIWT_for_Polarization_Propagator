Cell["\<\
From the application of Wick\[CloseCurlyQuote]s theorem to the following \
matrix element (cf. expansion formula of Gorkov\[CloseCurlyQuote]s \
polarization propagator),\
\>", "Text",
 CellChangeTimes->{
  3.9191646354051304`*^9},ExpressionUUID->"28b7c540-9ece-4529-acd9-\
ee23d4ea06d6"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["\[CapitalPi]", "acdb"], 
    RowBox[{
     SubscriptBox["g", "1"], 
     SubscriptBox["g", "3"], 
     SubscriptBox["g", "4"], 
     SubscriptBox["g", "2"]}]], TraditionalForm]],ExpressionUUID->
  "dc30e730-ed01-46e5-bc5d-2afda52a38ee"],
 " (t,t\[CloseCurlyQuote])",
 Cell[BoxData[
  FormBox[
   SubscriptBox["|", 
    RowBox[{"second", " ", "order"}]], TraditionalForm]],ExpressionUUID->
  "35bef11e-8453-4ab4-9c82-e475a515d88a"],
 "     = -\[ImaginaryI] (",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{
     FractionBox[
      RowBox[{"-", "\[ImaginaryI]"}], "\[HBar]"], ")"}], "2"], 
   TraditionalForm]],ExpressionUUID->"b9680e3c-825f-4246-94e4-63d763d7d447"],
 " ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", 
    RowBox[{"2", "!"}]], TraditionalForm]],ExpressionUUID->
  "f9394c85-d00c-4e05-93d0-3571994a53dc"],
 " ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{"\[DifferentialD]", 
    FormBox[
     SubscriptBox["t", "1"],
     TraditionalForm]}]}]],ExpressionUUID->
  "583b7430-541c-4e25-97de-1789fca03d5f"],
 " ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{"\[DifferentialD]", 
    FormBox[
     SubscriptBox["t", "2"],
     TraditionalForm]}]}]],ExpressionUUID->
  "484cf059-4033-40de-bec9-dba2945c79c0"],
 "  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[LeftAngleBracket]", 
    SubscriptBox["\[CapitalPhi]", "0"]}], TraditionalForm]],ExpressionUUID->
  "bd7df040-c7ee-4fd8-bfc3-dfae21737b5c"],
 "| T{ ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "1"]}], TraditionalForm]],ExpressionUUID->
  "5a2e830c-0c38-4fc7-a922-8170d3fa6517"],
 ") ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "2"]}], TraditionalForm]],ExpressionUUID->
  "b400f251-6eb0-4ff9-a567-32490da1176a"],
 ") ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["A", "Ia"], 
    SubscriptBox["g", "1"]], TraditionalForm]],ExpressionUUID->
  "2b1309aa-98b0-4f10-8644-c7769a11dbdb"],
 "(t)",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["A", "Ib"], 
    SubscriptBox["g", "2"]], TraditionalForm]],ExpressionUUID->
  "73775f4e-d028-417a-84ea-66f4f3131adc"],
 "(t\[CloseCurlyQuote])",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["A", "Id"], 
    RowBox[{"\[Dagger]", " ", 
     SubscriptBox["g", "4"]}]], TraditionalForm]],ExpressionUUID->
  "aecd0a68-caa7-4af4-95c8-997f5c629831"],
 "(t\[CloseCurlyQuote])",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["A", "Ic"], 
    RowBox[{"\[Dagger]", " ", 
     SubscriptBox["g", "3"]}]], TraditionalForm]],ExpressionUUID->
  "41bc1c87-624e-41c7-b5d8-119450049e17"],
 "(t)| ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalPhi]", "0"], TraditionalForm]],ExpressionUUID->
  "caca442b-71a6-451a-a757-41c1625e1063"],
 "\[RightAngleBracket]"
}], "Text",
 CellChangeTimes->{
  3.9191652022516193`*^9, {3.9191690921978426`*^9, 
   3.919169096991004*^9}},ExpressionUUID->"f55324de-15bb-42ca-a3b0-\
3cb932032a7b"],

Cell[TextData[{
 "the fully-contracted terms consisting of 8 second-quantization operators \
are generated. The one-body potential insertions, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "1"]}], TraditionalForm]],ExpressionUUID->
  "bd95d652-52f6-4807-a7c9-0e92d9b83496"],
 ") and ",
