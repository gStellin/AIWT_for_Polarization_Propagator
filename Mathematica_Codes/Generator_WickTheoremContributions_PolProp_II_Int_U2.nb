 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"u", "=", "1"}], ",", 
    RowBox[{"u", "\[LessEqual]", "8"}], ",", 
    RowBox[{"u", "++"}], ",", 
    RowBox[{"Print", "[", 
     RowBox[{"\"\<CombDirLeft[[\>\"", ",", "u", ",", "\"\<]]=\>\"", ",", 
      RowBox[{"AdisjDirLeft", "[", 
       RowBox[{"[", "u", "]"}], "]"}], ",", "\"\<;\>\""}], "]"}]}], "]"}], 
