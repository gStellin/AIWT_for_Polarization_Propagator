    RowBox[{"u", "=", "1"}], ",", 
    RowBox[{"u", "\[LessEqual]", "8"}], ",", 
    RowBox[{"u", "++"}], ",", 
    RowBox[{"Print", "[", 
     RowBox[{"\"\<CombExcAbove[[\>\"", ",", "u", ",", "\"\<]]=\>\"", ",", 
      RowBox[{"AdisjExchAbove", "[", 
