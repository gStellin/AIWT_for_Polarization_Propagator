Cell[CellGroupData[{

Cell["\<\
Disjoint Bogoliubov diagrams with dressed single-particle propagators on the \
diagonal and the antidiagonal\
\>", "Section",
 CellChangeTimes->{{3.8747474873699455`*^9, 3.8747475586269774`*^9}, {
  3.8836821843140464`*^9, 3.883682185030684*^9}, {3.8886425005080795`*^9, 
