  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "2"]}], TraditionalForm]],ExpressionUUID->
  "fff04b67-5656-42f0-aeca-f96e43db6287"],
 "), take the form"
}], "Text",
 CellChangeTimes->{
  3.9191646460974193`*^9, {3.919165245979292*^9, 
   3.9191653026397467`*^9}},ExpressionUUID->"374d2f71-a098-48d7-aa13-\
9b7b0f2fa53c"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "1"]}], TraditionalForm]],ExpressionUUID->
  "950c583a-5092-402e-915c-2bee08964ef1"],
 ") = ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", "2"], TraditionalForm]],ExpressionUUID->
  "18c17e2c-cdc5-41c5-bb1a-7fae16e643b8"],
 Cell[BoxData[
  RowBox[{
   UnderscriptBox["\[Sum]", "ef"], 
   RowBox[{"[", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       SubscriptBox["u", "ef"], "11"], 
      SuperscriptBox[
       SubscriptBox["a", "e"], "\[Dagger]"], 
      RowBox[{"(", 
       SubscriptBox["t", "1"], ")"}], 
      SubscriptBox["a", "f"], 
      RowBox[{"(", 
       SubscriptBox["t", "1"], ")"}]}], "+", 
     RowBox[{
      SuperscriptBox[
       SubscriptBox["u", "ef"], "22"], 
      SubscriptBox["a", 
       OverscriptBox["e", "_"]], 
      RowBox[{"(", 
       SubscriptBox["t", "1"], ")"}], 
      SuperscriptBox[
       SubscriptBox["a", 
        OverscriptBox["f", "_"]], "\[Dagger]"], 
      RowBox[{"(", 
       SubscriptBox["t", "1"], ")"}]}], "+", 
     RowBox[{
      SuperscriptBox[
       SubscriptBox["u", "ef"], "12"], 
      SuperscriptBox[
       SubscriptBox["a", "e"], "\[Dagger]"], 
      RowBox[{"(", 
       SubscriptBox["t", "1"], ")"}], 
      SuperscriptBox[
       SubscriptBox["a", 
        OverscriptBox["f", "_"]], "\[Dagger]"], 
      RowBox[{"(", 
       SubscriptBox["t", "1"], ")"}]}], "+", 
     RowBox[{
      SuperscriptBox[
       SubscriptBox["u", "ef"], "21"], 
      SubscriptBox["a", 
       OverscriptBox["e", "_"]], 
      RowBox[{"(", 
       SubscriptBox["t", "1"], ")"}], 
      SubscriptBox["a", "f"], 
      RowBox[{"(", 
       SubscriptBox["t", "1"], ")"}]}]}], "]"}]}]],ExpressionUUID->
  "147676e5-30ba-4d42-a836-f4b2a067372f"],
 ","
}], "Text",
 CellChangeTimes->{
  3.9191652414329586`*^9},ExpressionUUID->"601f8d78-4b57-4b3e-92d1-\
4d585940810b"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "2"]}], TraditionalForm]],ExpressionUUID->
  "aba120d4-ef2c-4db2-b9c5-6647601b7ea0"],
 ") = ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", "2"], TraditionalForm]],ExpressionUUID->
  "449a6ce8-56ce-44c1-b415-6f1d8bb6a939"],
 Cell[BoxData[
  RowBox[{
   UnderscriptBox["\[Sum]", "gh"], 
   RowBox[{"[", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       SubscriptBox["u", "gh"], "11"], 
      SuperscriptBox[
       SubscriptBox["a", "g"], "\[Dagger]"], 
      RowBox[{"(", 
       SubscriptBox["t", "2"], ")"}], 
      SubscriptBox["a", "h"], 
      RowBox[{"(", 
       SubscriptBox["t", "2"], ")"}]}], "+", 
     RowBox[{
      SuperscriptBox[
       SubscriptBox["u", "gh"], "22"], 
      SubscriptBox["a", 
       OverscriptBox["g", "_"]], 
      RowBox[{"(", 
       SubscriptBox["t", "2"], ")"}], 
      SuperscriptBox[
       SubscriptBox["a", 
        OverscriptBox["h", "_"]], "\[Dagger]"], 
      RowBox[{"(", 
       SubscriptBox["t", "2"], ")"}]}], "+", 
     RowBox[{
      SuperscriptBox[
       SubscriptBox["u", "gh"], "12"], 
      SuperscriptBox[
       SubscriptBox["a", "g"], "\[Dagger]"], 
      RowBox[{"(", 
       SubscriptBox["t", "2"], ")"}], 
      SuperscriptBox[
       SubscriptBox["a", 
        OverscriptBox["h", "_"]], "\[Dagger]"], 
      RowBox[{"(", 
       SubscriptBox["t", "2"], ")"}]}], "+", 
     RowBox[{
      SuperscriptBox[
       SubscriptBox["u", "gh"], "21"], 
      SubscriptBox["a", 
       OverscriptBox["g", "_"]], 
      RowBox[{"(", 
       SubscriptBox["t", "2"], ")"}], 
      SubscriptBox["a", "h"], 
      RowBox[{"(", 
       SubscriptBox["t", "2"], ")"}]}]}], "]"}]}]],ExpressionUUID->
  "7964902b-0d26-47da-ad97-1bb360dcd1d7"],
 "."
}], "Text",
 CellChangeTimes->{
  3.9191652254580545`*^9},ExpressionUUID->"2d8e1c0c-71ba-4466-9bff-\
f11de6e5a3c6"],

Cell[TextData[{
 "Due to the presence of two one-body interaction vertices, the number of \
distinct fully-contracted terms of ",
 StyleBox["8",
  FontSlant->"Italic"],
 " second quantization operators at second order corresponds to 7",
 StyleBox["!! = 105",
  FontSlant->"Italic"],
 ". The results of the generation process hold identically for all the 4 \
Nambu components of the one-body potential and are the same for each of the ",
 StyleBox["16",
  FontSlant->"Italic"],
 " Nambu components of Gorkov\[CloseCurlyQuote]s polarization propagator.  A \
significant part of these Wick\[CloseCurlyQuote]s-theorem contributions has \
to be discarded, since it corresponds either to disconnected diagrams or to \
exchange diagrams that are cancelled by the subtractive term of the \
polarization propagator.  At second order, no conjoint diagram containing two \
one-body interaction vertices exists. Additionally, since the one-body \
potential is not invariant under permutation of the two indices, the \
filtration process accounts only for inter-vertex transpositions of \
single-particle indices."
}], "Text",
 CellChangeTimes->{{3.874645469364807*^9, 3.874645558141898*^9}, {
  3.8746455892271357`*^9, 3.8746458332056046`*^9}, {3.8746520484004583`*^9, 
  3.8746520621013403`*^9}, {3.8836800758523192`*^9, 3.883680077052704*^9}, {
  3.8895283433205495`*^9, 3.889528365465126*^9}, {3.9118800207592287`*^9, 
  3.9118800274714775`*^9}, {3.9118800633231573`*^9, 3.911880196411795*^9}, {
