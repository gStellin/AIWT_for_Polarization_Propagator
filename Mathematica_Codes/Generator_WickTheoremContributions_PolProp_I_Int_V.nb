Cell["\<\
From the application of Wick\[CloseCurlyQuote]s theorem to the following \
matrix element (cf. expansion formula of Gorkov\[CloseCurlyQuote]s \
polarization propagator),\
\>", "Text",
 CellChangeTimes->{
  3.9191643410208225`*^9},ExpressionUUID->"0c8d31b6-acc1-4c5c-80a1-\
a088713c8b3c"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["\[CapitalPi]", "acdb"], 
    RowBox[{
     SubscriptBox["g", "1"], 
     SubscriptBox["g", "3"], 
     SubscriptBox["g", "4"], 
     SubscriptBox["g", "2"]}]], TraditionalForm]],ExpressionUUID->
  "43903d55-64c6-43ba-997b-11dd89fbd924"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"t", ",", 
      RowBox[{"t", "'"}]}], ")"}], 
    SubscriptBox["|", 
     RowBox[{"first", " ", "order"}]]}], TraditionalForm]],ExpressionUUID->
  "b4f306e5-2431-482f-b417-4f78e5b715b0"],
 "     = -\[ImaginaryI] ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"-", "\[ImaginaryI]"}], "\[HBar]"], TraditionalForm]],
  ExpressionUUID->"326bff77-e764-48e1-9d4b-5254bd01cdf6"],
 " ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", 
    RowBox[{"1", "!"}]], TraditionalForm]],ExpressionUUID->
  "18a93c81-fdb8-4cfc-a13a-8fe77a14d284"],
 " ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{"\[DifferentialD]", 
    FormBox[
     SubscriptBox["t", "1"],
     TraditionalForm]}]}]],ExpressionUUID->
  "bf02db64-d1a1-4e01-9229-8a2b80c696a0"],
 "  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[LeftAngleBracket]", 
    SubscriptBox["\[CapitalPhi]", "0"]}], TraditionalForm]],ExpressionUUID->
  "8f4a80d2-3a95-43da-80a8-8f477cccc6e9"],
 "| T{ ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["V", "_"], "(", 
    SubscriptBox["t", "1"]}], TraditionalForm]],ExpressionUUID->
  "60b9082d-e20e-4918-8e9c-ffb191c0fdf0"],
 ") ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["A", "Ia"], 
    SubscriptBox["g", "1"]], TraditionalForm]],ExpressionUUID->
  "ba291b4e-4d04-4d64-9fec-7ab5fdce3fbd"],
 "(t)",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["A", "Ib"], 
    SubscriptBox["g", "2"]], TraditionalForm]],ExpressionUUID->
  "2811f0f9-edfa-49cd-b377-3bd05928d345"],
 "(t\[CloseCurlyQuote])",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["A", "Id"], 
    RowBox[{"\[Dagger]", " ", 
     SubscriptBox["g", "4"]}]], TraditionalForm]],ExpressionUUID->
  "89358e73-7b69-4ba7-8c6b-b43d6e30faf0"],
 "(t\[CloseCurlyQuote])",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["A", "Ic"], 
    RowBox[{"\[Dagger]", " ", 
     SubscriptBox["g", "3"]}]], TraditionalForm]],ExpressionUUID->
  "8b983228-88df-43dc-aec2-eec04c1adbcf"],
 "(t)| ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalPhi]", "0"], TraditionalForm]],ExpressionUUID->
  "bcf3695e-301a-4090-ae14-30d06ab9d952"],
 "\[RightAngleBracket]",
 Cell[BoxData[
  FormBox[
   SubscriptBox["", "c"], TraditionalForm]],ExpressionUUID->
  "b3899b1a-76a6-41bd-be2b-9d87e6bf958a"]
}], "Text",
 CellChangeTimes->{{3.9191644119997215`*^9, 3.9191644679723177`*^9}, {
  3.919169033469865*^9, 
