  3.919164484121252*^9},ExpressionUUID->"084258bf-86c6-4a0a-a94c-\
04a30470ebe7"],

Cell[TextData[{
 "Due to the presence of a two-body interaction vertex, the number of \
distinct fully-contracted terms of ",
 StyleBox["8",
  FontSlant->"Italic"],
 " second quantization operators at first order corresponds to ",
 StyleBox["7!! = 105",
  FontSlant->"Italic"],
 ". The result is the same for each of the ",
 StyleBox["16",
  FontSlant->"Italic"],
 " Nambu components of Gorkov\[CloseCurlyQuote]s polarization propagator.  A \
significant part of these Wick\[CloseCurlyQuote]s-theorem contributions has \
to be discarded, since it corresponds either to disconnected diagrams or to \
exchange diagrams that are cancelled by the subtractive term of the \
polarization propagator."
}], "Text",
 CellChangeTimes->{{3.874645469364807*^9, 3.874645558141898*^9}, {
   3.8746455892271357`*^9, 3.8746458332056046`*^9}, {3.8746520484004583`*^9, 
   3.8746520621013403`*^9}, {3.8836800758523192`*^9, 3.883680077052704*^9}, {
   3.8895283433205495`*^9, 3.889528365465126*^9}, {3.9118800207592287`*^9, 
   3.9118800274714775`*^9}, {3.9118800633231573`*^9, 3.911880196411795*^9}, {
   3.9120685309910316`*^9, 3.9120685468340797`*^9}, 
   3.912073298453509*^9},ExpressionUUID->"424f4e1d-ab2c-4e8a-ae2e-\
4d716a4bd3d5"],

