           RowBox[{
            RowBox[{"AdisjBogoDiag", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], 
            "\[GreaterEqual]", " ", "3"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
