Cell[CellGroupData[{

Cell["Filtration of the fully-contracted terms", "Subsection",
 CellChangeTimes->{{3.874644843789677*^9, 3.8746448545752873`*^9}, {
   3.883112065177337*^9, 3.883112118360941*^9}, {3.8831146011227875`*^9, 
   3.8831146201744213`*^9}, {3.883115184479356*^9, 3.8831151965813236`*^9}, {
   3.8884058729915524`*^9, 3.8884058731821747`*^9}, {3.892800153537215*^9, 
   3.8928001610648518`*^9}, {3.897041751372193*^9, 3.8970417738128204`*^9}, {
   3.8970432846114845`*^9, 3.897043286022911*^9}, 
   3.911883818478182*^9},ExpressionUUID->"33f56aef-678b-441e-99fb-\
bcddabaa700a"],

Cell[TextData[{
 "Filtration of the right-dressed disjoint direct diagrams. At first order, \
transpositions between single-particle indices of different vertices \
(external permutations) are not possible and the overall corresponding \
combinatorial factor is ",
 StyleBox["1!",
  FontSlant->"Italic"],
 ". On the other hand, transposition between single-particle index of the \
same two-body vertex are available. Fully-contracted terms which are mapped \
one another by the permutation ",
 StyleBox["p \[RightTeeArrow] q",
  FontSlant->"Italic"],
 "  and ",
 StyleBox["r \[RightTeeArrow] s",
  FontSlant->"Italic"],
 "  and ",
 StyleBox["p \[RightTeeArrow] q",
  FontSlant->"Italic"],
 ", ",
 StyleBox["r \[RightTeeArrow] s",
  FontSlant->"Italic"],
 " are identified and summed, eventually canceling out the ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"2", "!"}], ")"}], "2"],
    FontSlant->"Italic"], TraditionalForm]],ExpressionUUID->
  "fa70c98b-a1df-41ac-befb-da291596f319"],
 " at the denominator, arising from the partial antisymmetry of the  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox[
     RowBox[{" ", "V"}], "_"], "pqrs"], TraditionalForm]],ExpressionUUID->
  "b2a38e0f-240f-4c12-b6b6-bab14ecf9ed5"],
 " interaction vertex. The cancellation is only partial when one-body \
propagators linking a vertex to itself are present."
}], "Text",
 CellChangeTimes->{{3.8836806708732624`*^9, 3.883680671103075*^9}, {
   3.8836807100445924`*^9, 3.8836809748029747`*^9}, {3.88368106035993*^9, 
   3.88368123630155*^9}, {3.8884066008391533`*^9, 3.8884066027299986`*^9}, {
   3.889531897043619*^9, 3.889531903637968*^9}, {3.8895328025200243`*^9, 
   3.889532803452654*^9}, 3.9118851261633663`*^9, {3.911885313489254*^9, 
   3.9118853244102707`*^9}},ExpressionUUID->"cf2709ae-3277-47b4-915e-\
e5aaa1c3882b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"AdcdrVertex", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "12"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "4"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MultdcdrVertex", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "12"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ifrepeat", "=", " ", "False"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Temp", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "4"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "4"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"IfTemp", " ", "=", 
    RowBox[{"Table", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "4"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "4"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"s", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"AdcdrVertex", "[", 
    RowBox[{"[", "1", "]"}], "]"}], " ", "=", " ", 
   RowBox[{"AdisjDirRight", "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"MultdcdrVertex", "[", 
    RowBox[{"[", "1", "]"}], "]"}], "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"u", "=", "1"}], ",", 
   RowBox[{"u", "\[LessEqual]", "12"}], ",", 
   RowBox[{"u", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "\[LessEqual]", "4"}], ",", 
      RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"j", "=", "1"}], ",", 
        RowBox[{"j", "\[LessEqual]", "2"}], ",", 
        RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjDirRight", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "1"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "i", ",", "j"}], "]"}], "]"}], "=", "2"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjDirRight", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "2"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "i", ",", "j"}], "]"}], "]"}], "=", "1"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjDirRight", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], 
            "\[GreaterEqual]", " ", "3"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "i", ",", "j"}], "]"}], "]"}], "=", 
            RowBox[{"AdisjDirRight", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}]}]}], "]"}], ";",
          "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjDirRight", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "1"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", "2"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjDirRight", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "2"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", "1"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjDirRight", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "3"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", "4"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjDirRight", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "4"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", "3"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
