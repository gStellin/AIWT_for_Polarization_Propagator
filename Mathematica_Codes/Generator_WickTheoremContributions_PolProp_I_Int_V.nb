Cell["\<\
The alphabetic single-particle indices of the second-quantization operators \
are converted into positive integers by means of the following map:\
\>", "Text",
 CellChangeTimes->{{3.911880385154636*^9, 3.911880500879594*^9}, 
   3.919164363690241*^9},ExpressionUUID->"1db73c85-9740-4000-8b2b-\
eaf1e86f04b1"],

Cell[TextData[Cell[BoxData[GridBox[{
   {"p", "q", "s", "r", "a", "b", "d", "c"},
   {"1", "2", "3", "4", "5", "6", "7", "8"}
  },
  GridBoxDividers->{"Columns" -> {{True}}, "Rows" -> {{True}}}]],
 TextAlignment->
  Center,ExpressionUUID->"51fa7e33-dc62-4688-a5ce-053d885e9adc"]], "Text",
 CellChangeTimes->{{3.8746528633189774`*^9, 3.8746529425611305`*^9}, {
   3.8895283862467823`*^9, 3.889528411462181*^9}, 
   3.911880364486044*^9},ExpressionUUID->"431bc351-8d07-4194-9f25-\
87167379f253"],

Cell["\<\
as such, the single-particle indices are stored into arrays (cf. \
\[OpenCurlyQuote]Acomb\[CloseCurlyQuote], \[OpenCurlyQuote]Acombsort\
\[CloseCurlyQuote], \[OpenCurlyQuote]AdisjBogoDiag\[CloseCurlyQuote] et c.).\
\>", "Text",
 CellChangeTimes->{
  3.9191643742688785`*^9},ExpressionUUID->"6c3c787f-a018-4616-ae3a-\
8e072d9070d0"],

Cell[CellGroupData[{

Cell["Generation of the first-order fully-contracted terms", "Section",
 CellChangeTimes->{{3.8746447213615894`*^9, 3.874644731124649*^9}, {
  3.8746447691271086`*^9, 3.87464477328621*^9}, {3.8746449100185723`*^9, 
  3.87464492347766*^9}, {3.883683441766288*^9, 3.8836834625750504`*^9}, {
  3.889528469300623*^9, 3.889528470058614*^9}, {3.912071408740595*^9, 
  3.912071413061755*^9}},ExpressionUUID->"a270b8cb-a73c-4ecd-b52c-\
3f86fcc05597"],

Cell[TextData[{
 "The first-order fully-contracted terms are found to be ",
 StyleBox["105",
  FontSlant->"Italic"],
 " in total, consistently with the formula ",
 StyleBox["4n+3!!",
  FontSlant->"Italic"],
 " with ",
 StyleBox["n=1",
  FontSlant->"Italic"],
 ". Binary contractions belonging to the same fully contracted term (index ",
 StyleBox["i",
  FontSlant->"Italic"],
 " in the array initialization) are denoted by the index ",
 StyleBox["j",
  FontSlant->"Italic"],
 ". The two single particle indices within the same contraction are \
distinguished by the index ",
 StyleBox["k",
  FontSlant->"Italic"],
 ". The process produces no repeated pairs, by construction."
}], "Text",
 CellChangeTimes->{{3.8836835314266734`*^9, 3.8836835815187073`*^9}, {
   3.8895284734892464`*^9, 3.88952848309838*^9}, {3.889528810988242*^9, 
   3.8895288112887807`*^9}, {3.8928028631906576`*^9, 3.892802871599965*^9}, {
   3.911881134541976*^9, 3.9118812354750347`*^9}, 3.911881272452093*^9, {
   3.911881422437512*^9, 3.9118814376624393`*^9}, {3.9120733082131915`*^9, 
   3.912073318767561*^9}, {3.913782986964424*^9, 
   3.913782991202458*^9}},ExpressionUUID->"f1246bbb-d30d-40e9-a9a2-\
9fa72bbe3b17"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"l", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Acomb", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "150"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "4"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Acomb", "[", 
    RowBox[{"[", "l", "]"}], "]"}], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"3", ",", "4"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"5", ",", "6"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"7", ",", "8"}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"g", "=", "1"}], ",", 
    RowBox[{"g", "\[LessEqual]", "7"}], ",", 
    RowBox[{"g", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"growind", " ", "=", " ", "1"}], ";", "\[IndentingNewLine]", 
     RowBox[{"gcolind", " ", "=", " ", "2"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"h", "=", "1"}], ",", 
       RowBox[{"h", "\[LessEqual]", "5"}], ",", 
       RowBox[{"h", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"hrowind", " ", "=", " ", "2"}], ";", "\[IndentingNewLine]", 
        RowBox[{"hcolind", " ", "=", " ", "2"}], ";", "\[IndentingNewLine]", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"i", "=", "1"}], ",", 
          RowBox[{"i", "\[LessEqual]", " ", "3"}], ",", 
          RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"irowind", " ", "=", " ", "3"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"icolind", " ", "=", " ", "2"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Acomb", "[", 
             RowBox[{"[", "l", "]"}], "]"}], " ", "=", " ", 
            RowBox[{"Acomb", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"g", "\[NotEqual]", "1"}], ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"growpiv", " ", "=", " ", 
               RowBox[{
                RowBox[{"Floor", "[", 
                 RowBox[{"g", "/", "2"}], "]"}], "+", "1"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"gcolpiv", " ", "=", 
               RowBox[{
                RowBox[{"-", " ", 
                 RowBox[{"Floor", "[", 
                  RowBox[{"g", "/", "2"}], "]"}]}], "+", 
                RowBox[{"Ceiling", "[", 
                 RowBox[{"g", "/", "2"}], "]"}], "+", "1"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"Acomb", "[", 
                RowBox[{"[", 
                 RowBox[{"l", ",", "growind", ",", "gcolind"}], "]"}], "]"}], 
               "=", " ", 
               RowBox[{"Acomb", "[", 
                RowBox[{"[", 
                 RowBox[{"1", ",", "growpiv", ",", "gcolpiv"}], "]"}], 
                "]"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"Acomb", "[", 
                RowBox[{"[", 
                 RowBox[{"l", ",", "growpiv", ",", "gcolpiv"}], "]"}], "]"}], 
               " ", "=", " ", 
               RowBox[{"Acomb", "[", 
                RowBox[{"[", 
                 RowBox[{"1", ",", "growind", ",", "gcolind"}], "]"}], 
                "]"}]}]}]}], "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"h", "\[NotEqual]", "1"}], ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"hrowpiv", " ", "=", " ", 
               RowBox[{
                RowBox[{"Floor", "[", 
                 RowBox[{"h", "/", "2"}], "]"}], "+", "2"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"hcolpiv", " ", "=", 
               RowBox[{
                RowBox[{"-", " ", 
                 RowBox[{"Floor", "[", 
                  RowBox[{"h", "/", "2"}], "]"}]}], "+", 
                RowBox[{"Ceiling", "[", 
                 RowBox[{"h", "/", "2"}], "]"}], "+", "1"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"Atemp1", " ", "=", " ", 
               RowBox[{"Acomb", "[", 
                RowBox[{"[", 
                 RowBox[{"l", ",", "hrowind", ",", "hcolind"}], "]"}], 
                "]"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{"Atemp2", "=", " ", 
               RowBox[{"Acomb", "[", 
                RowBox[{"[", 
                 RowBox[{"l", ",", "hrowpiv", ",", "hcolpiv"}], "]"}], 
                "]"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"Acomb", "[", 
                RowBox[{"[", 
                 RowBox[{"l", ",", "hrowind", ",", "hcolind"}], "]"}], "]"}], 
               " ", "=", " ", "Atemp2"}], ";", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"Acomb", "[", 
                RowBox[{"[", 
                 RowBox[{"l", ",", "hrowpiv", ",", "hcolpiv"}], "]"}], "]"}], 
               " ", "=", " ", "Atemp1"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"i", "\[NotEqual]", "1"}], ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"irowpiv", " ", "=", " ", 
               RowBox[{
                RowBox[{"Floor", "[", 
                 RowBox[{"i", "/", "2"}], "]"}], "+", "3"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"icolpiv", " ", "=", 
               RowBox[{
                RowBox[{"-", " ", 
                 RowBox[{"Floor", "[", 
                  RowBox[{"i", "/", "2"}], "]"}]}], "+", 
                RowBox[{"Ceiling", "[", 
                 RowBox[{"i", "/", "2"}], "]"}], "+", "1"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"Atemp1", " ", "=", " ", 
               RowBox[{"Acomb", "[", 
                RowBox[{"[", 
                 RowBox[{"l", ",", "irowind", ",", "icolind"}], "]"}], 
                "]"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{"Atemp2", "=", " ", 
               RowBox[{"Acomb", "[", 
                RowBox[{"[", 
                 RowBox[{"l", ",", "irowpiv", ",", "icolpiv"}], "]"}], 
                "]"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"Acomb", "[", 
                RowBox[{"[", 
                 RowBox[{"l", ",", "irowind", ",", "icolind"}], "]"}], "]"}], 
               " ", "=", " ", "Atemp2"}], ";", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"Acomb", "[", 
                RowBox[{"[", 
                 RowBox[{"l", ",", "irowpiv", ",", "icolpiv"}], "]"}], "]"}], 
               " ", "=", " ", "Atemp1"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"l", "++"}]}]}], "]"}]}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"g", "\[Equal]", "7"}], ",", 
