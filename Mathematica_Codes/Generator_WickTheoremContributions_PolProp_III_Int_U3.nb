Cell["\<\
There are only 369 third-order disconnected diagrams with non-identical \
one-body vertex. The multiplicity check is fulfilled.\
\>", "Text",
 CellChangeTimes->{{3.9123230368435626`*^9, 3.9123230551958413`*^9}, {
  3.912323659514346*^9, 3.9123236716412516`*^9}, {3.9138694169573116`*^9, 
  3.9138694173210125`*^9}, {3.913869908793223*^9, 
  3.913869909599675*^9}},ExpressionUUID->"d92c0d93-46c2-4cc3-99ef-\
250b9c9fa63e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Disconnected diagrams with two identical one-body vertices", \
"Subsection",
 CellChangeTimes->{{3.874644843789677*^9, 3.8746448545752873`*^9}, {
   3.883112065177337*^9, 3.883112118360941*^9}, {3.8831146011227875`*^9, 
   3.8831146201744213`*^9}, {3.883115184479356*^9, 3.8831151965813236`*^9}, {
   3.8884058729915524`*^9, 3.8884058731821747`*^9}, {3.892800153537215*^9, 
   3.8928001610648518`*^9}, {3.897041751372193*^9, 3.8970417738128204`*^9}, {
   3.8970432846114845`*^9, 3.897043286022911*^9}, 3.911883818478182*^9, {
   3.912323001395213*^9, 3.9123230134791594`*^9}, {3.9138695237696795`*^9, 
   3.913869524529063*^9}},ExpressionUUID->"29e0394f-82bc-44cb-899a-\
b9c4ab483516"],

Cell["\<\
Depending on the components of the one-body potential into play, symmetry \
rules may apply and reduce the total number of fully-contracted terms. When \
the multiplied Nambu components of the one-body potential are identical, \
vertex exchange is possible, hence the filtration process is necessary. \
Specifically, fully contracted terms which are mapped one another by the \
single-particle-index transposition e \[RightTeeArrow]g \[Wedge] f \
\[RightTeeArrow] h are equivalent, thus one of the two can be dropped, \
incrementing the associated multiplicity by unity. At the end of the process, \
207 inequivalent fully-contracted terms corresponding to disconnected \
diagrams are found.  \
\>", "Text",
 CellChangeTimes->{{3.8836806708732624`*^9, 3.883680671103075*^9}, {
   3.8836807100445924`*^9, 3.8836809748029747`*^9}, {3.88368106035993*^9, 
   3.88368123630155*^9}, {3.8884066008391533`*^9, 3.8884066027299986`*^9}, {
   3.889531897043619*^9, 3.889531903637968*^9}, {3.8895328025200243`*^9, 
   3.889532803452654*^9}, 3.9118851261633663`*^9, {3.911885313489254*^9, 
   3.9118853244102707`*^9}, {3.911885420747136*^9, 3.9118854315063624`*^9}, {
   3.9118860757937164`*^9, 3.911886076363371*^9}, {3.9118863981279774`*^9, 
   3.911886399679015*^9}, {3.9123232066276617`*^9, 3.9123232476938877`*^9}, {
   3.9123233347954187`*^9, 3.912323606712844*^9}, {3.9138698125256085`*^9, 
   3.913869823067107*^9}},ExpressionUUID->"0f6e3b59-daa5-42f0-b112-\
d98641e572ca"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"AdVertex", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "369"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "5"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MultdVertex", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "369"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ifrepeat", "=", " ", "False"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Temp", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "5"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"IfTemp", " ", "=", 
    RowBox[{"Table", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "2"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "5"}], "}"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"s", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"AdVertex", "[", 
    RowBox[{"[", "1", "]"}], "]"}], " ", "=", " ", 
   RowBox[{"Adisc", "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"MultdVertex", "[", 
    RowBox[{"[", "1", "]"}], "]"}], "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"u", "=", "1"}], ",", 
   RowBox[{"u", "\[LessEqual]", "369"}], ",", 
   RowBox[{"u", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "\[LessEqual]", "5"}], ",", 
      RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"j", "=", "1"}], ",", 
        RowBox[{"j", "\[LessEqual]", "2"}], ",", 
        RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"Temp", "[", 
           RowBox[{"[", 
            RowBox[{"1", ",", "i", ",", "j"}], "]"}], "]"}], "=", 
          RowBox[{"Adisc", "[", 
           RowBox[{"[", 
            RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Adisc", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "1"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", "3"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Adisc", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "2"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", "4"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Adisc", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "3"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", "1"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Adisc", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "4"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", "2"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Adisc", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], " ", 
            "\[GreaterEqual]", " ", "5"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", 
            RowBox[{"Adisc", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}]}]}], "]"}], 
         ";"}]}], "\[IndentingNewLine]", "]"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "\[LessEqual]", " ", "2"}], ",", 
      RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Temp", "[", 
           RowBox[{"[", 
            RowBox[{"i", ",", "1", ",", "1"}], "]"}], "]"}], " ", ">", " ", 
