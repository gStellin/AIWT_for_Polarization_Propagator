Cell[CellGroupData[{

Cell["\<\
Left-and-right-dressed disjoint direct diagrams with three identical one-body \
vertices\
\>", "Subsection",
 CellChangeTimes->{{3.9123225301750393`*^9, 3.9123225545237913`*^9}, {
  3.9123287170256085`*^9, 3.9123287269030876`*^9}, {3.912328804026425*^9, 
  3.9123288049892793`*^9}, {3.913783820070137*^9, 3.9137838212572823`*^9}, {
  3.9137850088879194`*^9, 3.9137850105498586`*^9}, {3.913799031009083*^9, 
  3.91379903503605*^9}},ExpressionUUID->"ff1686f1-7f18-40e8-b3f0-\
347599212f9c"],

Cell["\<\
Depending on the components of the one-body potential into play, symmetry \
rules may apply and reduce the total number of fully-contracted terms. When \
the multiplied Nambu components of the one-body potential are identical, \
vertex exchange is possible, hence the filtration process is necessary. When \
the three one-body vertices are identical, the fully contracted terms which \
are mapped one another by the single-particle-index transpositions \
\>", "Text",
 CellChangeTimes->{{3.8836806708732624`*^9, 3.883680671103075*^9}, {
   3.8836807100445924`*^9, 3.8836809748029747`*^9}, {3.88368106035993*^9, 
   3.88368123630155*^9}, {3.8884066008391533`*^9, 3.8884066027299986`*^9}, {
   3.889531897043619*^9, 3.889531903637968*^9}, {3.8895328025200243`*^9, 
   3.889532803452654*^9}, 3.9118851261633663`*^9, {3.911885313489254*^9, 
   3.9118853244102707`*^9}, {3.911885420747136*^9, 3.9118854315063624`*^9}, {
   3.9118860757937164`*^9, 3.911886076363371*^9}, {3.9118863981279774`*^9, 
   3.911886399679015*^9}, {3.9123232066276617`*^9, 3.9123232476938877`*^9}, {
   3.9123233347954187`*^9, 3.912323606712844*^9}, {3.912335104884133*^9, 
   3.91233512664951*^9}, 3.912335585399894*^9, {3.912336753830852*^9, 
   3.912336763901738*^9}, {3.912339194942795*^9, 3.9123392110274544`*^9}, {
   3.9123395015250535`*^9, 3.912339502808386*^9}, {3.9123396313792577`*^9, 
   3.912339631865156*^9}, {3.913783857041258*^9, 3.913783884990827*^9}, {
   3.913785033160533*^9, 3.9137852374980774`*^9}, {3.9137852718199944`*^9, 
   3.9137853325774336`*^9}, {3.91378652405511*^9, 
   3.913786536077306*^9}},ExpressionUUID->"b4ab6d89-6ffa-4ade-8042-\
55505a611d1d"],

Cell["\<\
e \[RightTeeArrow]g \[Wedge] f \[RightTeeArrow] h  \[Congruent] (eg)(fh)(i)(j),
e \[RightTeeArrow]i \[Wedge] f \[RightTeeArrow] j \[Congruent] (ei)(fj)(g)(h),
g \[RightTeeArrow]i \[Wedge] h \[RightTeeArrow] j \[Congruent] (gi)(hj)(e)(f),
e \[RightTeeArrow]g \[Wedge] f \[RightTeeArrow] h \[Wedge] g\[RightTeeArrow] \
i \[Wedge] h\[RightTeeArrow] j \[Wedge] i\[RightTeeArrow]e \[Wedge] j\
\[RightTeeArrow] f \[Congruent] (egi)(fhj),
e \[RightTeeArrow]i \[Wedge] f \[RightTeeArrow] j \[Wedge] g\[RightTeeArrow] \
e \[Wedge] h\[RightTeeArrow] f \[Wedge] i\[RightTeeArrow]g \[Wedge] j\
\[RightTeeArrow] h \[Congruent] (ige)(jhf),\
\>", "Text",
 CellChangeTimes->{{3.9137853296492443`*^9, 3.9137855932454247`*^9}, {
  3.913798671719838*^9, 3.9137986740010157`*^9}},
 TextAlignment->Center,ExpressionUUID->"6242dd12-33b6-41f2-b037-350d95328e57"],

Cell["\<\
are equivalent, thus one of the six can be dropped, incrementing the \
associated multiplicity by 5. In the end of the process, 16 inequivalent \
fully-contracted terms corresponding to left-and-right-dressed disjoint \
direct diagrams are found.  \
\>", "Text",
 CellChangeTimes->{
  3.913785320942859*^9, {3.913785616366067*^9, 3.9137856374662666`*^9}, {
   3.9137967984286804`*^9, 3.9137968005453215`*^9}, {3.913799018059394*^9, 
   3.913799043213264*^9}},ExpressionUUID->"a3ae59dc-8914-480c-9288-\
828c41324755"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"AdcdVertex", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "96"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "5"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MultdcdVertex", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "96"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ifrepeat", "=", " ", "False"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Temp", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "6"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "5"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"IfTemp", " ", "=", 
    RowBox[{"Table", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "6"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "5"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"s", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"AdcdVertex", "[", 
    RowBox[{"[", "1", "]"}], "]"}], " ", "=", " ", 
   RowBox[{"AdisjDirect", "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"MultdcdVertex", "[", 
    RowBox[{"[", "1", "]"}], "]"}], "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"u", "=", "1"}], ",", 
   RowBox[{"u", "\[LessEqual]", "96"}], ",", 
   RowBox[{"u", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "\[LessEqual]", "5"}], ",", 
      RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"j", "=", "1"}], ",", 
        RowBox[{"j", "\[LessEqual]", "2"}], ",", 
        RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"Temp", "[", 
           RowBox[{"[", 
            RowBox[{"1", ",", "i", ",", "j"}], "]"}], "]"}], "=", 
          RowBox[{"AdisjDirect", "[", 
           RowBox[{"[", 
            RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjDirect", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "1"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", "3"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjDirect", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "2"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", "4"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjDirect", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "3"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", "1"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjDirect", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "4"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", "2"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjDirect", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], " ", 
            "\[GreaterEqual]", " ", "5"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", 
            RowBox[{"AdisjDirect", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}]}]}], "]"}], ";",
          "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjDirect", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "1"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"3", ",", "i", ",", "j"}], "]"}], "]"}], "=", "5"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjDirect", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "2"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"3", ",", "i", ",", "j"}], "]"}], "]"}], "=", "6"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjDirect", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "5"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"3", ",", "i", ",", "j"}], "]"}], "]"}], "=", "1"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjDirect", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "6"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"3", ",", "i", ",", "j"}], "]"}], "]"}], "=", "2"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"AdisjDirect", "[", 
                RowBox[{"[", 
                 RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], " ", 
               "\[GreaterEqual]", " ", "3"}], " ", "&&", " ", 
              RowBox[{
               RowBox[{"AdisjDirect", "[", 
                RowBox[{"[", 
                 RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], " ", 
               "\[LessEqual]", " ", "4"}]}], ")"}], "||", 
            RowBox[{
             RowBox[{"AdisjDirect", "[", 
              RowBox[{"[", 
               RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], " ", 
             "\[GreaterEqual]", " ", "7"}]}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"3", ",", "i", ",", "j"}], "]"}], "]"}], "=", 
            RowBox[{"AdisjDirect", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}]}]}], "]"}], ";",
          "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjDirect", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "3"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"4", ",", "i", ",", "j"}], "]"}], "]"}], "=", "5"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjDirect", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "4"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"4", ",", "i", ",", "j"}], "]"}], "]"}], "=", "6"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjDirect", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "5"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"4", ",", "i", ",", "j"}], "]"}], "]"}], "=", "3"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjDirect", "[", 
