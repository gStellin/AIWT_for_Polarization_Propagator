Cell[CellGroupData[{

Cell["Disconnected diagrams with non-identical one-body vertices", \
"Subsection",
 CellChangeTimes->{{3.9123225301750393`*^9, 
  3.9123225545237913`*^9}},ExpressionUUID->"868a1b80-fadd-4a34-8644-\
2f219ae79180"],

Cell["\<\
Depending on the components of the one-body potential into play, symmetry \
rules may apply and reduce the total number of fully-contracted terms. When \
the multiplied Nambu components of the one-body potential are distinct, no \
vertex exchange is possible. Additionally, since single-particle index \
transpositions within each one-body vertex are forbidden, no filtration \
process is necessary. Thus, the number of inequivalent disconnected \
contributions with non-identical vertices at third order remains equal to 369.\
\>", "Text",
 CellChangeTimes->{{3.912322579269453*^9, 3.9123226345921354`*^9}, {
  3.9123226697432995`*^9, 3.9123228694040194`*^9}, {3.912323377321495*^9, 
  3.9123233835289555`*^9}, {3.913869301304163*^9, 3.913869301825597*^9}, {
  3.9138693386729126`*^9, 
  3.9138693678436775`*^9}},ExpressionUUID->"dd8ac751-6562-40bc-b03e-\
1765b69f76d2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"u", "=", "1"}], ",", 
    RowBox[{"u", "\[LessEqual]", "369"}], ",", 
    RowBox[{"u", "++"}], ",", 
    RowBox[{"Print", "[", 
     RowBox[{"\"\<CombDisc[[\>\"", ",", "u", ",", "\"\<]]=\>\"", ",", 
      RowBox[{"Adisc", "[", 
       RowBox[{"[", "u", "]"}], "]"}], ",", "\"\<;\>\""}], "]"}]}], "]"}], 
  ";"}]], "Input",
