Cell[CellGroupData[{

Cell["\<\
Disjoint exchange diagrams with dressed single-particle propagators above and \
below\
\>", "Section",
 CellChangeTimes->{{3.8747474873699455`*^9, 3.8747475586269774`*^9}, {
  3.8836821843140464`*^9, 3.883682185030684*^9}, {3.8886425005080795`*^9, 
  3.8886425041635475`*^9}, {3.912328474878409*^9, 
  3.9123284988476944`*^9}},ExpressionUUID->"9986e7d7-e98b-4401-ba51-\
d56dda89cbc7"],

Cell["\<\
Exchange diagrams with unperturbed 1-body propagators above and below are \
processed. Their initial number is 96 in total.\
\>", "Text",
 CellChangeTimes->{{3.8836813753146152`*^9, 3.88368147043666*^9}, {
   3.8836820487185183`*^9, 3.88368205024879*^9}, {3.883682180609577*^9, 
   3.883682181425793*^9}, {3.8895326177197933`*^9, 3.8895326190004883`*^9}, {
   3.8927832371377015`*^9, 3.892783237556256*^9}, {3.911906600155179*^9, 
   3.911906604269761*^9}, {3.912324076983011*^9, 3.912324077222091*^9}, {
   3.912328595074086*^9, 3.9123286041109376`*^9}, 3.9123286714046226`*^9, 
   3.9138017007083597`*^9, {3.913802116285923*^9, 
   3.9138021167444572`*^9}},ExpressionUUID->"18d07b75-0fae-4890-9f0a-\
fa7691a064d3"],

Cell[CellGroupData[{

Cell["\<\
Above-and-below-dressed disjoint exchange diagrams with non-identical \
one-body vertices\
\>", "Subsection",
 CellChangeTimes->{{3.9123225301750393`*^9, 3.9123225545237913`*^9}, {
  3.9123286967354116`*^9, 3.9123287107977743`*^9}, {3.9123287715426073`*^9, 
  3.9123287814673014`*^9}, {3.912331157081521*^9, 
  3.9123311600113945`*^9}},ExpressionUUID->"4e568192-1619-48dc-82c9-\
551ac44e5952"],

Cell["\<\
Depending on the components of the one-body potential into play, symmetry \
rules may apply and reduce the total number of fully-contracted terms. When \
the multiplied Nambu components of the one-body potential are distinct, no \
vertex exchange is possible. Additionally, since single-particle index \
transpositions within each one-body vertex are forbidden, no filtration \
process is necessary. Thus, the number of inequivalent \
above-and-below-dressed disjoint exchange contributions with non-identical \
vertices at third order remains equal to 96.\
\>", "Text",
 CellChangeTimes->{{3.912322579269453*^9, 3.9123226345921354`*^9}, {
  3.9123226697432995`*^9, 3.9123228694040194`*^9}, {3.912323377321495*^9, 
  3.9123233835289555`*^9}, {3.9123331180668077`*^9, 3.912333133784379*^9}, {
  3.9123337248637705`*^9, 3.912333725851756*^9}, {3.912334200112067*^9, 
  3.912334205774393*^9}, {3.912334269934724*^9, 3.9123342744885716`*^9}, {
  3.912334319172452*^9, 3.912334321962988*^9}, {3.9138017019546523`*^9, 
  3.9138017112152605`*^9}, {3.9138021117872734`*^9, 
  3.9138021120737877`*^9}},ExpressionUUID->"64501c9f-6c8b-4a3f-b827-\
3daa3b770fa0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"u", "=", "1"}], ",", 
    RowBox[{"u", "\[LessEqual]", "96"}], ",", 
    RowBox[{"u", "++"}], ",", 
    RowBox[{"Print", "[", 
     RowBox[{"\"\<CombExchange[[\>\"", ",", "u", ",", "\"\<]]=\>\"", ",", 
      RowBox[{"AdisjExchange", "[", 
