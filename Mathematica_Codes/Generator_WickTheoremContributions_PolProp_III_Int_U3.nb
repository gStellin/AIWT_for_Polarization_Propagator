  3.919169488597029*^9}},ExpressionUUID->"0d97c519-2c03-41a4-bd59-\
e2f545d30be6"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["\[CapitalPi]", "acdb"], 
    RowBox[{
     SubscriptBox["g", "1"], 
     SubscriptBox["g", "3"], 
     SubscriptBox["g", "4"], 
     SubscriptBox["g", "2"]}]], TraditionalForm]],ExpressionUUID->
  "faca09da-8985-4ad3-bb3a-c9cdbb1c8fb7"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"t", ",", 
      RowBox[{"t", "'"}]}], ")"}], 
    SubscriptBox["|", 
     RowBox[{"third", " ", "order"}]]}], TraditionalForm]],ExpressionUUID->
  "3985c6b8-f3fc-4453-a59a-eed831d15b93"],
 "     = +\[ImaginaryI] ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     FractionBox[
      RowBox[{"-", "\[ImaginaryI]"}], "\[HBar]"], ")"}], "3"], 
   TraditionalForm]],ExpressionUUID->"b0145488-09cd-4b88-8d6e-f2733b642111"],
