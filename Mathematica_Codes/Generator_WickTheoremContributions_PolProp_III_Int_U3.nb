 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"u", "=", "1"}], ",", 
    RowBox[{"u", "\[LessEqual]", "48"}], ",", 
    RowBox[{"u", "++"}], ",", 
    RowBox[{"Print", "[", 
     RowBox[{"\"\<CombBogDiag[[\>\"", ",", "u", ",", "\"\<]]=\>\"", ",", 
