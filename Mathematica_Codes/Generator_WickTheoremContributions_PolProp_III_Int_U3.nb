  3.9123284424706826`*^9}},ExpressionUUID->"2cdcc9e2-b053-4af0-b5cc-\
5c2a908440c2"],

Cell["\<\
Bogoliubov diagrams with perturbed 1-body propagators on the diagonal and \
antidiagonal are processed. Their initial number is 96 in total.\
\>", "Text",
 CellChangeTimes->{{3.8836813753146152`*^9, 3.88368147043666*^9}, {
  3.8836820487185183`*^9, 3.88368205024879*^9}, {3.883682180609577*^9, 
  3.883682181425793*^9}, {3.8895326177197933`*^9, 3.8895326190004883`*^9}, {
