Cell["\<\
There are only 96 third-order diagonally-and-antidiagonally-dressed disjoint \
Bogoliubov diagrams with non-identical one-body vertices. The multiplicity \
check is fulfilled.\
\>", "Text",
 CellChangeTimes->{{3.9123230368435626`*^9, 3.9123230551958413`*^9}, {
   3.912323659514346*^9, 3.9123236716412516`*^9}, 3.9123313086853094`*^9, {
   3.912333581512753*^9, 3.9123335898394504`*^9}, {3.912333775753584*^9, 
   3.912333776539037*^9}, {3.9123342347764444`*^9, 3.9123342404981174`*^9}, {
   3.912334296029745*^9, 3.9123342966023417`*^9}, {3.91233438912913*^9, 
   3.9123343973071785`*^9}, {3.9123347539072723`*^9, 
   3.9123347544756784`*^9}, {3.9123348453590345`*^9, 3.912334850687954*^9}, {
   3.9138044582287064`*^9, 3.913804461334514*^9}, {3.9138677046035824`*^9, 
   3.913867710294999*^9}},ExpressionUUID->"c90a4a95-d6b9-415e-9d1a-\
c49e917e0aab"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Diagonally-and-antidiagonally-dressed disjoint Bogoliubov diagrams with two \
identical one-body vertices\
\>", "Subsection",
 CellChangeTimes->{{3.9123225301750393`*^9, 3.9123225545237913`*^9}, {
  3.9123287170256085`*^9, 3.9123287269030876`*^9}, {3.9123287756441975`*^9, 
  3.9123287890502768`*^9}, {3.912331181315509*^9, 3.912331195115821*^9}, {
  3.9123312308819084`*^9, 3.912331239541175*^9}, {3.9138709389211893`*^9, 
  3.9138709395968823`*^9}},ExpressionUUID->"5afbe75d-1465-4ff1-a5ed-\
8488936eb347"],

Cell["\<\
Depending on the components of the one-body potential into play, symmetry \
rules may apply and reduce the total number of fully-contracted terms. When \
the multiplied Nambu components of the one-body potential are identical, \
vertex exchange is possible, hence the filtration process is necessary. \
Specifically, fully contracted terms which are mapped one another by the \
single-particle-index transposition e \[RightTeeArrow]g \[Wedge] f \
\[RightTeeArrow] h are equivalent, thus one of the two can be dropped, \
incrementing the associated multiplicity by unity. In the end of the process, \
48 inequivalent fully-contracted terms corresponding to \
diagonally-and-antidiagonally-dressed disjoint Bogoliubov diagrams are found. \
 \
\>", "Text",
 CellChangeTimes->{{3.8836806708732624`*^9, 3.883680671103075*^9}, {
   3.8836807100445924`*^9, 3.8836809748029747`*^9}, {3.88368106035993*^9, 
   3.88368123630155*^9}, {3.8884066008391533`*^9, 3.8884066027299986`*^9}, {
   3.889531897043619*^9, 3.889531903637968*^9}, {3.8895328025200243`*^9, 
   3.889532803452654*^9}, 3.9118851261633663`*^9, {3.911885313489254*^9, 
   3.9118853244102707`*^9}, {3.911885420747136*^9, 3.9118854315063624`*^9}, {
   3.9118860757937164`*^9, 3.911886076363371*^9}, {3.9118863981279774`*^9, 
   3.911886399679015*^9}, {3.9123232066276617`*^9, 3.9123232476938877`*^9}, {
   3.9123233347954187`*^9, 3.912323606712844*^9}, {3.912335104884133*^9, 
   3.91233512664951*^9}, 3.912335585399894*^9, 
   3.9138677185745673`*^9},ExpressionUUID->"93265bc8-ed5e-471e-8400-\
98fe0d5589e8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"AdcbVertex", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "96"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "5"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MultdcbVertex", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "96"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ifrepeat", "=", " ", "False"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Temp", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "5"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"IfTemp", " ", "=", 
    RowBox[{"Table", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "2"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "5"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"s", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"AdcbVertex", "[", 
    RowBox[{"[", "1", "]"}], "]"}], " ", "=", " ", 
   RowBox[{"AdisjBogoliubov", "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"MultdcbVertex", "[", 
    RowBox[{"[", "1", "]"}], "]"}], "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"u", "=", "1"}], ",", 
   RowBox[{"u", "\[LessEqual]", "96"}], ",", 
   RowBox[{"u", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "\[LessEqual]", "5"}], ",", 
      RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"j", "=", "1"}], ",", 
        RowBox[{"j", "\[LessEqual]", "2"}], ",", 
        RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"Temp", "[", 
           RowBox[{"[", 
            RowBox[{"1", ",", "i", ",", "j"}], "]"}], "]"}], "=", 
          RowBox[{"AdisjBogoliubov", "[", 
           RowBox[{"[", 
            RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjBogoliubov", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "1"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", "3"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjBogoliubov", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "2"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", "4"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjBogoliubov", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "3"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", "1"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjBogoliubov", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "4"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", "2"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjBogoliubov", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], " ", 
            "\[GreaterEqual]", " ", "5"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", 
            RowBox[{"AdisjBogoliubov", "[", 
