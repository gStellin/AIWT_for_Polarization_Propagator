Cell[CellGroupData[{

Cell["Selection of the Nambu component of the one-body potential", "Section",
 CellChangeTimes->{{3.9120816659877415`*^9, 
  3.9120817133455973`*^9}},ExpressionUUID->"0c63de61-424a-4267-9e99-\
8811448dafb8"],

Cell[TextData[{
 "The analytical results presented henceforth refer to an element of the \
product between ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "1"]}], TraditionalForm]],ExpressionUUID->
  "319db858-0947-458f-973d-a5cfb0cf4a21"],
 "), ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "2"]}], TraditionalForm]],ExpressionUUID->
  "1d17779d-0cdd-4ea4-a0d3-81c57476d89b"],
 ") and the second-quantization operators with external single-particle \
indices. At second order, such elements are specified by the two pairs of  \
Nambu indices that determine the component ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], 
    RowBox[{
     SubscriptBox["g", "5"], 
     SubscriptBox["g", "6"]}]], TraditionalForm]],ExpressionUUID->
  "d5c1d8bc-f1ab-4991-a10d-0bebeb9503bf"],
 " (",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "gh"], 
    RowBox[{
     SubscriptBox["g", "7"], 
     SubscriptBox["g", "8"]}]], TraditionalForm]],ExpressionUUID->
  "464c050d-dfc8-4c45-a5c3-9f5522796531"],
 ") of the auxiliary one-body potential ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "1"]}], TraditionalForm]],ExpressionUUID->
  "3052f799-300b-4f09-be75-5c33534e2d4e"],
 ") (",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "2"]}], TraditionalForm]],ExpressionUUID->
  "a7ee171e-2f9c-475a-b4c5-5fdb9a3cb617"],
 ")). The indices are stored as { ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "5"], TraditionalForm]],ExpressionUUID->
  "37c28b23-90cd-4edb-8368-a1541b966d72"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "6"], TraditionalForm]],ExpressionUUID->
  "d0b57e96-a293-4ff2-a8fb-96e71c182fed"],
 ",",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    SubscriptBox["g", "7"]}], TraditionalForm]],ExpressionUUID->
  "b4bcf7ad-708c-4bfb-82be-8279f07f14ce"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "8"], TraditionalForm]],ExpressionUUID->
  "874a77a1-92b6-4828-bcd2-31c27331cf8f"],
 "} in the array \[OpenCurlyQuote]UNambu\[CloseCurlyQuote], together with the \
associated multiplicity arising from the product between ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "1"]}], TraditionalForm]],ExpressionUUID->
  "32d59322-cec5-413d-a837-329d859b3e79"],
 ") and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "2"]}], TraditionalForm]],ExpressionUUID->
  "19853e28-f078-47b8-9262-ba94af73a94c"],
 "). Since the single-particle indices are summed, the products ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "12"], TraditionalForm]],ExpressionUUID->
  "34621281-7db7-46fb-862e-90cfcaa07576"],
 " ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "gh"], "21"], TraditionalForm]],ExpressionUUID->
  "a2bfca83-d0f2-4114-88c9-ce1df117374a"],
 " and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "21"], TraditionalForm]],ExpressionUUID->
  "dc7316b0-57bf-4f4d-aa8c-a3adfe36fd05"],
 " ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "gh"], "12"], TraditionalForm]],ExpressionUUID->
  "ce8fa363-f1df-4b28-91c6-0654c2464835"],
 " give rise to identical contributions, hence are summed together, resulting \
in a multiplicity equal to 2. The same occurs for all other contributions \
with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "5"], TraditionalForm]],ExpressionUUID->
  "ade72056-7abd-4785-9bf9-4b7238f5942f"],
 " \[NotEqual] ",
 Cell[BoxData[
