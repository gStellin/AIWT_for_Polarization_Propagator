Cell[CellGroupData[{

Cell["Definition of the auxiliary arrays", "Subsection",
 CellChangeTimes->{{3.888315173503672*^9, 3.888315249112604*^9}, {
  3.8883153026090937`*^9, 3.8883153149727306`*^9}, {3.888315800792353*^9, 
  3.888315802330164*^9}, {3.9077382535011215`*^9, 3.907738255398263*^9}, {
  3.9079184731747074`*^9, 
  3.9079185042453585`*^9}},ExpressionUUID->"05c5da97-2c89-4e2a-bd79-\
cab01895efa4"],

Cell["\<\
Arrays specifying the Nambu indices (cf. NambuDirLeft), the operator type \
(cf. SQTypeDirLeft) and distinguishing internal from external single-particle \
indices (cf. IntExtDirLeft) are defined, in accordance with the conventions \
for the second-quantization operators in the header of the notebook. In \
particular, to external (internal) single-particle indices the value of \
\[OpenCurlyQuote]1\[CloseCurlyQuote] (\[OpenCurlyQuote]0\[CloseCurlyQuote]) \
is assigned, whereas for second-quantization operators of creation \
(annihilation) type the associated array entry is \[OpenCurlyQuote]0\
\[CloseCurlyQuote] (\[OpenCurlyQuote]1\[CloseCurlyQuote]). For Nambu indices, \
the convention is straightforward.\
\>", "Text",
 CellChangeTimes->{
  3.9077382215659647`*^9, {3.9077382923703613`*^9, 3.9077384065565405`*^9}, {
   3.9077384522680173`*^9, 3.9077384848449383`*^9}, {3.9077430709590244`*^9, 
   3.907743126073769*^9}, {3.9077450424291105`*^9, 3.9077450765315623`*^9}, {
   3.907918517166184*^9, 3.9079188444385033`*^9}, 3.9091515935484114`*^9, {
   3.9092041717880774`*^9, 3.9092041805155473`*^9}, {3.9127770903451953`*^9, 
   3.9127771066731534`*^9}, {3.913696746674406*^9, 3.91369675949473*^9}, {
   3.9136984628570733`*^9, 
   3.913698478422288*^9}},ExpressionUUID->"85efa537-d3b9-40b7-ad32-\
4ab15a66cf99"],

