Cell[CellGroupData[{

Cell["Initialization of Gorkov-Green\[CloseCurlyQuote]s functions", \
"Subsection",
 CellChangeTimes->{{3.888315173503672*^9, 3.888315249112604*^9}, {
  3.9082537791702285`*^9, 
  3.9082537877198505`*^9}},ExpressionUUID->"344ebded-122c-475c-97c1-\
cabb13b52452"],

Cell["\<\
An anomalous  (or \[OpenCurlyQuote]2\[CloseCurlyQuote]) Nambu index is \
introduced whenever a homogeneous pair of second-quantization operators is \
found, consistently with the definition of the one-body Gorkov propagators \
(cf. Som\[AGrave] et al, 2011). In Bogoliubov diagrams, involute \
single-particle indices do appear, since at least an anomalous contraction of \
external single-particle indices is present. In this case, involute \
single-particle indices are mapped into negative natural numbers. \
\>", "Text",
 CellChangeTimes->{{3.8883172996209154`*^9, 3.8883174034984384`*^9}, {
   3.8883176851044188`*^9, 3.888317943793604*^9}, 3.914410058627873*^9, {
   3.919020092241804*^9, 
   3.919020125076315*^9}},ExpressionUUID->"4a6261c5-64ca-47c0-bdc3-\
b20dc69c1cc9"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"GGFNambu", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "NcMax"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "5"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
