        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", 
         RowBox[{
          RowBox[{"GGFTotalPolynomial", "[", 
           RowBox[{"[", "r", "]"}], "]"}], "+", 
          RowBox[{"GGFPolynomial", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", "j"}], "]"}], "]"}]}]}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
