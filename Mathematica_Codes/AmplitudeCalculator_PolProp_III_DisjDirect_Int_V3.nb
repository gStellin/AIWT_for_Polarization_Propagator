                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"GGFNambu", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], "=", "1"}], 
              ";", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"GGFNambu", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}], "=", "2"}], 
              ";"}]}], "\[IndentingNewLine]", "]"}], ";"}]}], 
         "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{"Contraction", " ", "between", " ", "a", " ", "non"}], "-", 
          RowBox[{
          "involute", " ", "annihilation", " ", "operator", 
           "\[IndentingNewLine]", "followed", " ", "by", " ", "an", " ", 
           "involute", " ", "annihilation", " ", "operator"}]}], " ", "*)"}], 
        " ", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"SQTypeDir", "[", 
             RowBox[{"[", 
              RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], "\[Equal]", 
            "1"}], " ", "&&", " ", 
           RowBox[{
            RowBox[{"SQTypeDir", "[", 
             RowBox[{"[", 
              RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}], "\[Equal]", 
            "1"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"NambuDir", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], "==", "2"}],
               "&&", " ", 
              RowBox[{
               RowBox[{"NambuDir", "[", 
