Cell[CellGroupData[{

Cell["Assignment of the time indices, based on the time ordering", \
"Subsection",
 CellChangeTimes->{{3.888315861110175*^9, 
  3.8883159051561947`*^9}},ExpressionUUID->"c6b3fede-0e5a-4e0d-8ca5-\
39ea0ccd263c"],

Cell["\<\
It is convenient to assign the times (associated with the single-particle and \
the Nambu indices) only once the time ordering is established. This permits \
to evaluate the Gorkov-Green\[CloseCurlyQuote]s functions more rapidly, \
exploiting the order of the natural numbers 1, 2, 3, 4 and 5. The time \
indices appearing henceforth are, thus, relative times (= time-ordering \
dependent), whereas the absolute times (cf. the convention in the opening) \
correspond to the time classes. Times are sorted in ascending order: \
\[OpenCurlyQuote]5\[CloseCurlyQuote] is the latest time and \
\[OpenCurlyQuote]1\[CloseCurlyQuote] is the earliest one. \
\>", "Text",
 CellChangeTimes->{{3.888316744033399*^9, 3.88831696819341*^9}, {
  3.888317011995018*^9, 3.8883170646181097`*^9}, {3.898083048931562*^9, 
  3.898083051441782*^9}, {3.898242771811307*^9, 
  3.898242772119399*^9}},ExpressionUUID->"1ea48544-aa9e-43ac-ae8c-\
b9c79f27078d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"T", " ", "=", " ", "6"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"r", "=", "1"}], ",", 
     RowBox[{"r", "\[LessEqual]", " ", "304"}], ",", " ", 
     RowBox[{"r", "++"}], ",", " ", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "\[LessEqual]", " ", "8"}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"j", "=", "1"}], ",", 
         RowBox[{"j", "\[LessEqual]", "2"}], ",", 
         RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "1"}], " ", "||", " ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "2"}], "||", " ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "3"}], " ", "||", "  ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "4"}]}], " ", ",", 
            RowBox[{
             RowBox[{"GGFTime", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "=", 
             RowBox[{"TimeClassOrdPlus", "[", 
              RowBox[{"[", 
               RowBox[{"T", ",", "4"}], "]"}], "]"}]}]}], "]"}], ";", " ", 
          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{"Time", " ", "Class", " ", "4"}], " ", "=", " ", 
            SubscriptBox["t", "1"]}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "5"}], " ", "||", " ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "6"}], "||", " ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "7"}], "||", "  ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "8"}]}], " ", ",", 
            RowBox[{
             RowBox[{"GGFTime", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "=", 
             RowBox[{"TimeClassOrdPlus", "[", 
              RowBox[{"[", 
               RowBox[{"T", ",", "3"}], "]"}], "]"}]}]}], "]"}], ";", " ", 
          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{"Time", " ", "Class", " ", "3"}], " ", "=", " ", 
            SubscriptBox["t", "2"]}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
