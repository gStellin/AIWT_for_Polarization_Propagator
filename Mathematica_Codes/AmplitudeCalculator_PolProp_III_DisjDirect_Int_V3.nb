      RowBox[{"i", ",", "1", ",", "304"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SPSequence", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
