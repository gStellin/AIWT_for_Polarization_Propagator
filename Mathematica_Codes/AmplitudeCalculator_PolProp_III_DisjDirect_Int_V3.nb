 RowBox[{
  RowBox[{
   RowBox[{"GGFSParticle", " ", "=", " ", 
    RowBox[{"Table", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "304"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", "1", ",", "8"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", "304"}], ",", " ", 
    RowBox[{"r", "++"}], ",", " ", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "\[LessEqual]", " ", "8"}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{"Canonical", " ", "contractions"}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{"Contraction", " ", "between", " ", "a", " ", "non"}], "-", 
         RowBox[{
         "involute", " ", "annihilation", " ", "operator", 
          "\[IndentingNewLine]", "followed", " ", "by", " ", "an", " ", 
          "involute", " ", "annihilation", " ", "operator"}]}], " ", "*)"}], 
       " ", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"SQTypeDir", "[", 
             RowBox[{"[", 
              RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], "\[Equal]", 
            "1"}], " ", "&&", " ", 
           RowBox[{
            RowBox[{"SQTypeDir", "[", 
             RowBox[{"[", 
              RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}], "\[Equal]", 
