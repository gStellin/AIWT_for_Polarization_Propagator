             RowBox[{
              RowBox[{
               RowBox[{"NambuDir", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], "\[Equal]", 
               " ", "1"}], " ", "&&", " ", 
              RowBox[{
               RowBox[{"NambuDir", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}], "\[Equal]", 
               "2"}]}], " ", ",", "\[IndentingNewLine]", 
