Cell[CellGroupData[{

Cell["\<\
Calculation of the amplitude associated to Goldstone diagrams with alphabetic \
indices\
\>", "Subsection",
 CellChangeTimes->{{3.888315861110175*^9, 3.8883159051561947`*^9}, {
  3.888315988711161*^9, 3.888316043821027*^9}, {3.888316084808132*^9, 
  3.888316094409692*^9}, {3.908001735572657*^9, 3.908001740251663*^9}, {
  3.9082509561005807`*^9, 
  3.908250965625879*^9}},ExpressionUUID->"41f6ab39-8a2a-4c28-849d-\
3d719b067cee"],

Cell[TextData[{
 "The four time integrals are evaluated in two steps. First, one computes the \
integral over ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "1"], TraditionalForm]],ExpressionUUID->
  "35efa7ab-7935-4df6-8d9b-e673d85be56f"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "2"], TraditionalForm]],ExpressionUUID->
  "d6a2fe8e-5a22-44ac-8a61-5a63a579c6bc"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "3"], TraditionalForm]],ExpressionUUID->
  "168cf011-4f9d-43a1-bf1d-e415cbc6f8be"],
 "  (dummy times), by solving a linear system with a parameter (the fourth \
frequency). At third order, the frequency variables which are evaluated after \
integration by ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "1"], TraditionalForm]],ExpressionUUID->
  "a5ebc014-df5e-4f7c-8bc2-05562d1903fd"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "2"], TraditionalForm]],ExpressionUUID->
  "7964b53f-b757-4627-b377-a3c7724b7cd5"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "3"], TraditionalForm]],ExpressionUUID->
  "cf31b8be-87af-4c73-b150-f7e9740b323d"],
 "  are labeled as \[Gamma], \[Epsilon] and \[Iota]. Consequently, the time \
differences multiplying \[Gamma], \[Epsilon] and \[Iota] must contain the \
times ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["t", 
     RowBox[{"1", " "}]], ","}], TraditionalForm]],ExpressionUUID->
  "67374909-a1b9-4d59-bf33-5374c78ae617"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "2"], TraditionalForm]],ExpressionUUID->
  "e288c643-3806-4a22-8a5f-72d008ea85f3"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "3"], TraditionalForm]],ExpressionUUID->
  "ea6f6f64-878f-4599-981d-069655bc0d89"],
 ", otherwise integration fails. Next, the integration over (t-t\
\[CloseCurlyQuote]) is performed, solving a single linear equation, obtained \
by equating the coefficient of (t-t\[CloseCurlyQuote]) in the total \
polynomial to zero. Note that the time interval that multiplies \[Digamma]  \
must contain either t or t\[CloseCurlyQuote]. However, t and t\
\[CloseCurlyQuote] shall not appear together in that time interval, otherwise \
the time ordering of the corresponding Goldstone diagram becomes undefined \
(or ambiguously defined). Consequently, in the denominators of the energy \
representation, multiple \[OpenCurlyQuote]omegas\[CloseCurlyQuote] may \
appear, depending on the topology of the unoriented Goldstone diagram. \
Besides, the time interval multiplying \[Digamma]  shall never coincide with \
the time interval multiplying \[Gamma] ,\[Iota] and \[Epsilon], otherwise the \
implemented time sequence is ill-defined."
}], "Text",
 CellChangeTimes->{{3.88831632426582*^9, 3.888316355447603*^9}, {
   3.888316407167918*^9, 3.8883165187772655`*^9}, {3.888316549145891*^9, 
   3.888316725014002*^9}, {3.8921261744276867`*^9, 3.892126176144218*^9}, {
   3.8980862869710255`*^9, 3.898086320953068*^9}, {3.8982421237906313`*^9, 
   3.8982421340044584`*^9}, {3.940396293830358*^9, 3.9403964913762336`*^9}, 
   3.94592677432308*^9},ExpressionUUID->"debd244c-f42d-0f48-9a02-\
227f18a4aca1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"GGFTotalPolynomial", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "1", ",", "304"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", " ", "304"}], ",", " ", 
    RowBox[{"r", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"j", "=", "1"}], ",", 
       RowBox[{"j", "\[LessEqual]", "8"}], ",", 
       RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", 
         RowBox[{
          RowBox[{"GGFTotalPolynomial", "[", 
           RowBox[{"[", "r", "]"}], "]"}], "+", 
          RowBox[{"GGFPolynomial", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", "j"}], "]"}], "]"}]}]}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"T", "\[Equal]", "1"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
         RowBox[{
          RowBox[{"GGFTotalPolynomial", "[", 
           RowBox[{"[", "r", "]"}], "]"}], " ", "+", " ", 
          RowBox[{"\[Omega]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdMinus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "5"}], "]"}], "]"}]], "-", 
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdMinus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
          RowBox[{"\[Iota]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "5"], "-", 
             SubscriptBox["t", "4"]}], ")"}]}], "-", 
          RowBox[{"\[Gamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "4"], "-", 
             SubscriptBox["t", "3"]}], ")"}]}], "-", 
          RowBox[{"\[Epsilon]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "3"], "-", 
             SubscriptBox["t", "2"]}], ")"}]}], "-", 
          RowBox[{"\[Digamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "2"], "-", 
             SubscriptBox["t", "1"]}], ")"}]}]}]}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"T", "\[Equal]", "2"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
         RowBox[{
          RowBox[{"GGFTotalPolynomial", "[", 
           RowBox[{"[", "r", "]"}], "]"}], " ", "+", " ", 
          RowBox[{"\[Omega]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdMinus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "5"}], "]"}], "]"}]], "-", 
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdMinus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
          RowBox[{"\[Iota]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "5"], "-", 
             SubscriptBox["t", "4"]}], ")"}]}], "-", 
          RowBox[{"\[Gamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "4"], "-", 
             SubscriptBox["t", "3"]}], ")"}]}], "-", 
          RowBox[{"\[Epsilon]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "3"], "-", 
             SubscriptBox["t", "2"]}], ")"}]}], "-", 
          RowBox[{"\[Digamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "2"], "-", 
             SubscriptBox["t", "1"]}], ")"}]}]}]}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"T", "\[Equal]", "3"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
         RowBox[{
          RowBox[{"GGFTotalPolynomial", "[", 
           RowBox[{"[", "r", "]"}], "]"}], " ", "+", " ", 
          RowBox[{"\[Omega]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdMinus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "5"}], "]"}], "]"}]], "-", 
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdMinus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
          RowBox[{"\[Iota]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "5"], "-", 
             SubscriptBox["t", "4"]}], ")"}]}], "-", 
          RowBox[{"\[Gamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "4"], "-", 
             SubscriptBox["t", "3"]}], ")"}]}], "-", 
          RowBox[{"\[Epsilon]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "3"], "-", 
             SubscriptBox["t", "2"]}], ")"}]}], "-", 
          RowBox[{"\[Digamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "2"], "-", 
             SubscriptBox["t", "1"]}], ")"}]}]}]}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"T", "\[Equal]", "4"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
         RowBox[{
          RowBox[{"GGFTotalPolynomial", "[", 
           RowBox[{"[", "r", "]"}], "]"}], " ", "+", " ", 
          RowBox[{"\[Omega]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdMinus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "5"}], "]"}], "]"}]], "-", 
