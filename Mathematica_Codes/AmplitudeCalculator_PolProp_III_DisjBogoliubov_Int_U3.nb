               RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "=", "2"}]}], 
           "]"}], ";", " ", 
          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{"Time", " ", "Class", " ", "2"}], " ", "=", " ", 
            SubscriptBox["t", "3"]}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "]"}], 
              "\[Equal]", "8"}], " ", "||", " ", 
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "]"}], 
              "\[Equal]", "9"}]}], ",", 
            RowBox[{
             RowBox[{"GGFTime", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "=", "1"}]}], 
           "]"}], ";", " ", 
          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{"Time", " ", "Class", " ", "1"}], " ", "=", " ", 
            RowBox[{"t", "'"}]}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "]"}], 
              "\[Equal]", "7"}], " ", "||", " ", 
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "]"}], 
              "\[Equal]", "10"}]}], ",", 
            RowBox[{
             RowBox[{"GGFTime", "[", 
