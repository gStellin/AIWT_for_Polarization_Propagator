Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NtL", "[", "s_", "]"}], ":=", 
   RowBox[{"(", " ", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"s", "\[Equal]", "1"}], ",", " ", 
       RowBox[{"Return", "[", "\"\<e\>\"", "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"s", "\[Equal]", 
        RowBox[{"-", "1"}]}], ",", " ", 
       RowBox[{"Return", "[", 
        RowBox[{"OverBar", "[", "\"\<e\>\"", "]"}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"s", "\[Equal]", "2"}], ",", " ", 
       RowBox[{"Return", "[", "\"\<f\>\"", "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"s", "\[Equal]", 
        RowBox[{"-", "2"}]}], ",", " ", 
