          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{"Time", " ", "Class", " ", "3"}], " ", "=", " ", 
            SubscriptBox["t", "2"]}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
