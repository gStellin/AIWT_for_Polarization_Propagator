             "\[Equal]", "2"}], "  ", "&&", "  ", 
            RowBox[{
             RowBox[{"GGFNambu", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}], "\[Equal]", 
             "2"}]}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"GGFAmplitude", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i"}], "]"}], "]"}], " ", "=", 
             RowBox[{
              RowBox[{"-", 
               RowBox[{"StringForm", "[", 
                RowBox[{"\"\<``\>\"", ",", 
                 RowBox[{"Superscript", "[", 
                  RowBox[{
                   RowBox[{"Superscript", "[", 
                    RowBox[{
                    RowBox[{"Subscript", "[", 
                    RowBox[{"\[CapitalUpsilon]", ",", 
                    RowBox[{"NtL", "[", 
                    RowBox[{"GGFSParticle", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], "]"}]}], 
                    "]"}], ",", 
                    RowBox[{"GGFNambu", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}]}], "]"}], 
                   ",", 
                   SubscriptBox["k", "i"]}], "]"}]}], "]"}]}], 
              RowBox[{"StringForm", "[", 
               RowBox[{"\"\<``\>\"", ",", 
                RowBox[{"Superscript", "[", 
                 RowBox[{
                  RowBox[{"Superscript", "[", 
                   RowBox[{
                    RowBox[{"Subscript", "[", 
                    RowBox[{
                    RowBox[{"OverBar", "[", "\[CapitalUpsilon]", "]"}], ",", 
