               RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "=", "5"}]}], 
           "]"}], ";"}]}], 
        RowBox[{"(*", "  ", 
         RowBox[{
          RowBox[{"Time", " ", "Class", " ", "5"}], " ", "=", " ", "t"}], " ",
          "*)"}], "\[IndentingNewLine]", "]"}]}], "]"}]}], "]"}], ";"}], 
