   RowBox[{"u", "++"}], ",", 
   RowBox[{"Print", "[", 
    RowBox[{"u", ",", " ", "\"\<    \>\"", ",", 
     RowBox[{"GGFTime", "[", 
      RowBox[{"[", "u", "]"}], "]"}]}], "]"}]}], "]"}]], "Input",
