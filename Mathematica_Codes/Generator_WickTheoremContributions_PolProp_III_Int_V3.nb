Cell["\<\
Printing the ensuing disconnected fully-contracted terms into files, for the \
carrying-out of the filtration process.\
\>", "Text",
 CellChangeTimes->{{3.8947151231578183`*^9, 3.894715138802438*^9}, {
  3.9119814525080276`*^9, 3.9119815137896814`*^9}, {3.911983649917075*^9, 
  3.911983652683584*^9}, {3.9119841639459877`*^9, 
  3.911984167011745*^9}},ExpressionUUID->"ab13ffa7-ff8d-4a76-ba20-\
245703b47c59"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"AdiscFile", "=", 
    RowBox[{"OpenWrite", "[", 
     RowBox[{
     "\"\<D:\\\\Mathematica's AIWT for the Polarization \
Propagator\\\\Contractions\\\\In_Comb_3_Disc_V3.h\>\"", ",", 
      RowBox[{"PageWidth", "\[Rule]", "Infinity"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"u", "=", "1"}], ",", 
     RowBox[{"u", "\[LessEqual]", " ", "146961"}], ",", 
     RowBox[{"u", "++"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"WriteString", "[", 
       RowBox[{"AdiscFile", ",", "\"\<Acombdisc[\>\"", ",", " ", 
        RowBox[{"u", "-", "1"}], ",", " ", "\"\<] ={\>\"", ",", " ", 
        RowBox[{"Adisc", "[", 
         RowBox[{"[", "u", "]"}], "]"}], ",", "\"\<};\\n\>\""}], "]"}], 
      ";"}]}], "\[IndentingNewLine]", "]"}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Close", "[", "AdiscFile", "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.890741831453683*^9, 3.890742008781371*^9}, {
   3.890746074974007*^9, 3.890746079115465*^9}, {3.892093113445965*^9, 
