Cell[CellGroupData[{

Cell["Separation between skeleton and composite diagrams", "Subsection",
 CellChangeTimes->{{3.874644843789677*^9, 3.8746448545752873`*^9}, {
  3.889778687121766*^9, 3.8897786991771154`*^9}, {3.911898216018196*^9, 
  3.911898239200224*^9}},ExpressionUUID->"d39ff378-a17c-4628-b547-\
5f82d255f598"],

Cell["\<\
Contributions which correspond to a first or second-order conjoint diagram \
with  dressed one-body propagators are separated from the skeleton \
third-order diagrams. Composite (skeleton) diagrams are found to be 718,848 \
(311,040) in total. \
\>", "Text",
 CellChangeTimes->{{3.883680330036955*^9, 3.8836804885586143`*^9}, {
  3.8836805700695734`*^9, 3.883680650666025*^9}, {3.892114247327975*^9, 
  3.892114254704054*^9}, {3.911898128554555*^9, 3.9118981954843397`*^9}, {
  3.9119817484990664`*^9, 
  3.9119817994193535`*^9}},ExpressionUUID->"36ee2be1-93d9-4b5b-ac3d-\
2be989bce9f6"],

