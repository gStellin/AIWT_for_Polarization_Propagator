            RowBox[{"r", ",", "j"}], "]"}], "]"}]}]}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"T", "\[Equal]", "1"}], ",", 
       RowBox[{
        RowBox[{"GGFTotalPolynomial", "[", 
         RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "+", " ", 
         RowBox[{"\[Omega]", 
