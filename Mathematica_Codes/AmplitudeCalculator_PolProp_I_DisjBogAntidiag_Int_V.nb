             RowBox[{"TimeClassOrdMinus", "[", 
              RowBox[{"[", 
               RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
         RowBox[{"\[Epsilon]", 
          RowBox[{"(", 
