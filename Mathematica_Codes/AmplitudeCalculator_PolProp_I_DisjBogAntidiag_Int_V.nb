            SubscriptBox["t", 
             RowBox[{"TimeClassOrdPlus", "[", 
              RowBox[{"[", 
               RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
         RowBox[{"\[Epsilon]", 
          RowBox[{"(", 
           RowBox[{
            SubscriptBox["t", "2"], "-", 
