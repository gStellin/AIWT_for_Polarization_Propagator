         RowBox[{"\[Digamma]", 
          RowBox[{"(", 
           RowBox[{
            SubscriptBox["t", "3"], "-", 
            SubscriptBox["t", "2"]}], ")"}]}]}]}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"T", "\[Equal]", "2"}], ",", 
