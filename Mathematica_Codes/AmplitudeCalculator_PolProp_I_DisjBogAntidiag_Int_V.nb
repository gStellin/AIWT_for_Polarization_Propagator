         RowBox[{"\[Omega]", 
          RowBox[{"(", 
           RowBox[{
            SubscriptBox["t", 
             RowBox[{"TimeClassOrdPlus", "[", 
              RowBox[{"[", 
               RowBox[{"T", ",", "3"}], "]"}], "]"}]], "-", 
            SubscriptBox["t", 
             RowBox[{"TimeClassOrdPlus", "[", 
              RowBox[{"[", 
               RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
         RowBox[{"\[Epsilon]", 
          RowBox[{"(", 
           RowBox[{
            SubscriptBox["t", "3"], "-", 
            SubscriptBox["t", "2"]}], ")"}]}], "-", 
         RowBox[{"\[Digamma]", 
          RowBox[{"(", 
           RowBox[{
            SubscriptBox["t", "2"], "-", 
            SubscriptBox["t", "1"]}], ")"}]}]}]}]}], "]"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}]}], "Input",
