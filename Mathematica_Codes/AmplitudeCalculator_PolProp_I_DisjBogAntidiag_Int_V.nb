4fb51a7bb178"],

Cell[TextData[{
 "Times are sorted in ascending order: \[OpenCurlyQuote]3\[CloseCurlyQuote] \
is the latest time and denotes t, \[OpenCurlyQuote]2\[CloseCurlyQuote] \
denotes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "1"], TraditionalForm]],ExpressionUUID->
  "7c790b0b-7bbb-42d6-82d8-11d1e131c037"],
 "  and \[OpenCurlyQuote]1\[CloseCurlyQuote] and denotes t\[CloseCurlyQuote]."
}], "Text",
