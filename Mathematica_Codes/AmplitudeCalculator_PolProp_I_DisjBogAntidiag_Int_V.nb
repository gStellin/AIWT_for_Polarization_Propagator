            SubscriptBox["t", 
             RowBox[{"TimeClassOrdPlus", "[", 
              RowBox[{"[", 
               RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
         RowBox[{"\[Epsilon]", 
          RowBox[{"(", 
           RowBox[{
            SubscriptBox["t", "2"], "-", 
            SubscriptBox["t", "1"]}], ")"}]}], "-", 
         RowBox[{"\[Digamma]", 
          RowBox[{"(", 
           RowBox[{
            SubscriptBox["t", "3"], "-", 
            SubscriptBox["t", "2"]}], ")"}]}]}]}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"T", "\[Equal]", "3"}], ",", 
       RowBox[{
        RowBox[{"GGFTotalPolynomial", "[", 
         RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
