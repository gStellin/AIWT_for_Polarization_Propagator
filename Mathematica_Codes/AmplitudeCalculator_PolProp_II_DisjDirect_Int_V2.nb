Cell[TextData[{
 "Times are sorted in ascending order: \[OpenCurlyQuote]4\[CloseCurlyQuote] \
is the latest time and denotes t, \[OpenCurlyQuote]3\[CloseCurlyQuote] \
denotes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "1"], TraditionalForm]],ExpressionUUID->
  "377d8974-fc75-4ad8-a136-0647008118af"],
 ",  \[OpenCurlyQuote]2\[CloseCurlyQuote] denotes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "2"], TraditionalForm]],ExpressionUUID->
  "2e1632dd-7832-451a-ad9e-a00fc3683c5c"],
 " . The earliest time is \[OpenCurlyQuote]1\[CloseCurlyQuote] and denotes t\
\[CloseCurlyQuote]."
}], "Text",
