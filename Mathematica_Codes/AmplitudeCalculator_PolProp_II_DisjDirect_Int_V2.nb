          RowBox[{"\[Digamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "2"], "-", 
             SubscriptBox["t", "1"]}], ")"}]}]}]}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
