Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"r", "=", "1"}], ",", 
     RowBox[{"r", "\[LessEqual]", " ", "NcMax"}], ",", " ", 
     RowBox[{"r", "++"}], ",", " ", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "\[LessEqual]", " ", "5"}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"j", "=", "1"}], ",", 
         RowBox[{"j", "\[LessEqual]", "2"}], ",", 
         RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "1"}], " ", "||", " ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "2"}]}], ",", 
            RowBox[{
             RowBox[{"GGFTime", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "=", "4"}]}], 
           "]"}], ";", " ", 
          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{"Time", " ", "Class", " ", "4"}], " ", "=", " ", 
            SubscriptBox["t", "1"]}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "3"}], " ", "||", " ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "4"}]}], ",", 
            RowBox[{
             RowBox[{"GGFTime", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "=", "3"}]}], 
           "]"}], ";", " ", 
          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{"Time", " ", "Class", " ", "3"}], " ", "=", " ", 
            SubscriptBox["t", "2"]}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "5"}], " ", "||", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "6"}]}], ",", 
            RowBox[{
             RowBox[{"GGFTime", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "=", "2"}]}], 
           "]"}], ";", " ", 
          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{"Time", " ", "Class", " ", "2"}], " ", "=", " ", 
            SubscriptBox["t", "3"]}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "8"}], " ", "||", " ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "9"}]}], ",", 
            RowBox[{
             RowBox[{"GGFTime", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "=", "1"}]}], 
           "]"}], ";", " ", 
          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{"Time", " ", "Class", " ", "1"}], " ", "=", " ", 
            RowBox[{"t", "'"}]}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "7"}], " ", "||", " ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "10"}]}], ",", 
            RowBox[{
             RowBox[{"GGFTime", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "=", "5"}]}], 
           "]"}], ";"}]}], 
        RowBox[{"(*", "  ", 
         RowBox[{
          RowBox[{"Time", " ", "Class", " ", "5"}], " ", "=", " ", "t"}], " ",
          "*)"}], "\[IndentingNewLine]", "]"}]}], "]"}]}], "]"}], ";"}], 
  "  "}]], "Input",
