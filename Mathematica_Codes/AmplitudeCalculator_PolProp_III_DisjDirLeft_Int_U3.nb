      RowBox[{"j", ",", "1", ",", "5"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"GGFSParticle", " ", "=", " ", 
    RowBox[{"Table", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "NcMax"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", "1", ",", "5"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", "NcMax"}], ",", " ", 
    RowBox[{"r", "++"}], ",", " ", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "\[LessEqual]", " ", "5"}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{"Canonical", " ", "contractions"}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{"Contraction", " ", "between", " ", "a", " ", "non"}], "-", 
         RowBox[{
         "involute", " ", "annihilation", " ", "operator", 
          "\[IndentingNewLine]", "followed", " ", "by", " ", "an", " ", 
          "involute", " ", "annihilation", " ", "operator"}]}], " ", "*)"}], 
       " ", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"SQTypeDirLeft", "[", 
             RowBox[{"[", 
              RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], "\[Equal]", 
            "1"}], " ", "&&", " ", 
           RowBox[{
            RowBox[{"SQTypeDirLeft", "[", 
             RowBox[{"[", 
              RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}], "\[Equal]", 
            "1"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
