       RowBox[{"s", "\[Equal]", "3"}], ",", " ", 
       RowBox[{"Return", "[", "\"\<g\>\"", "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"s", "\[Equal]", 
        RowBox[{"-", "3"}]}], ",", " ", 
       RowBox[{"Return", "[", 
        RowBox[{"OverBar", "[", "\"\<g\>\"", "]"}], "]"}]}], "]"}], ";", 
