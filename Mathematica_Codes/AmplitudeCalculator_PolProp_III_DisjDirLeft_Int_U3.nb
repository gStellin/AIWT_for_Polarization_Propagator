Cell[CellGroupData[{

Cell["\<\
Calculation of the amplitude associated to Goldstone diagrams with alphabetic \
indices\
\>", "Subsection",
 CellChangeTimes->{{3.888315861110175*^9, 3.8883159051561947`*^9}, {
  3.888315988711161*^9, 3.888316043821027*^9}, {3.888316084808132*^9, 
  3.888316094409692*^9}, {3.908001735572657*^9, 3.908001740251663*^9}, {
  3.9082509561005807`*^9, 
  3.908250965625879*^9}},ExpressionUUID->"03dc0765-d7f9-4d43-81e9-\
ab19a4e80ba9"],

Cell[TextData[{
 "The four time integrals are evaluated in two steps. First, one computes the \
integral over ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "1"], TraditionalForm]],ExpressionUUID->
  "6786cae1-401d-4415-ae57-9b20c53b75f2"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "2"], TraditionalForm]],ExpressionUUID->
  "feb1eed4-d22d-4a61-b2e4-33181e8995ba"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "3"], TraditionalForm]],ExpressionUUID->
  "3ac384b8-6be2-4938-a87c-19dc0bef0030"],
 "  (dummy times), by solving a linear system with a parameter (the fourth \
frequency). At third order, the frequency variables which are evaluated after \
integration by ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "1"], TraditionalForm]],ExpressionUUID->
  "584e801c-bf1b-482b-96bd-1c3393a2e9a2"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "2"], TraditionalForm]],ExpressionUUID->
  "7dfe5e17-22b5-4431-bde4-163335ed80c3"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "3"], TraditionalForm]],ExpressionUUID->
  "ed121204-614b-43a6-ac82-2f862c933216"],
 "  are labeled as \[Gamma], \[Epsilon] and \[Iota]. Consequently, the time \
differences multiplying \[Gamma], \[Epsilon] and \[Iota] must contain the \
times ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["t", 
     RowBox[{"1", " "}]], ","}], TraditionalForm]],ExpressionUUID->
  "de4b0183-58ec-4cf7-8a3e-dfa8dc4362b4"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "2"], TraditionalForm]],ExpressionUUID->
  "e462baed-2d90-48c8-b1b3-c2dc783d3b15"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "3"], TraditionalForm]],ExpressionUUID->
  "8755b2ff-d795-4b2c-9686-854c7160c621"],
 ", otherwise integration fails. Next, the integration over (t-t\
\[CloseCurlyQuote]) is performed, solving a single linear equation, obtained \
by equating the coefficient of (t-t\[CloseCurlyQuote]) in the total \
polynomial to zero. Note that the time interval that multiplies \[Digamma]  \
must contain either t or t\[CloseCurlyQuote]. However, t and t\
\[CloseCurlyQuote] shall not appear together in that time interval, otherwise \
the time ordering of the corresponding Goldstone diagram becomes undefined \
(or ambiguously defined). Consequently, in the denominators of the energy \
representation, multiple \[OpenCurlyQuote]omegas\[CloseCurlyQuote] may \
appear, depending on the topology of the unoriented Goldstone diagram. \
Besides, the time interval multiplying \[Digamma]  shall never coincide with \
the time interval multiplying \[Gamma] ,\[Iota] and \[Epsilon], otherwise the \
implemented time sequence is ill-defined."
}], "Text",
 CellChangeTimes->{{3.88831632426582*^9, 3.888316355447603*^9}, {
   3.888316407167918*^9, 3.8883165187772655`*^9}, {3.888316549145891*^9, 
   3.888316725014002*^9}, {3.8921261744276867`*^9, 3.892126176144218*^9}, {
   3.8980862869710255`*^9, 3.898086320953068*^9}, {3.8982421237906313`*^9, 
   3.8982421340044584`*^9}, {3.940396293830358*^9, 3.9403964913762336`*^9}, 
   3.945926865886772*^9},ExpressionUUID->"5c4d8327-9911-fb41-8381-\
b29740b2949f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"GGFTotalPolynomial", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "1", ",", "NcMax"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", " ", "NcMax"}], ",", " ", 
    RowBox[{"r", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"j", "=", "1"}], ",", 
       RowBox[{"j", "\[LessEqual]", "5"}], ",", 
       RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", 
