    RowBox[{"u", ",", " ", "\"\< \>\"", ",", 
     RowBox[{
      RowBox[{"GGFMult", "[", 
       RowBox[{"[", "u", "]"}], "]"}], "/", "8"}], ",", "\"\< \>\"", ",", 
