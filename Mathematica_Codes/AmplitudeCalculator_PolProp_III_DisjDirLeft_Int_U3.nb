Cell[BoxData[
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", " ", "NcMax"}], ",", " ", 
    RowBox[{"r", "++"}], ",", " ", "\[IndentingNewLine]", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "\[LessEqual]", " ", "5"}], ",", 
      RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"GGFTime", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], " ", ">", " ", 
          RowBox[{"GGFTime", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]}], ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"GGFAmplitude", "[", 
            RowBox[{"[", 
             RowBox[{"r", ",", "i"}], "]"}], "]"}], " ", "=", 
           RowBox[{
            RowBox[{"StringForm", "[", 
             RowBox[{"\"\<``\>\"", ",", 
              RowBox[{"Superscript", "[", 
               RowBox[{
                RowBox[{"Superscript", "[", 
                 RowBox[{
                  RowBox[{"Subscript", "[", 
                   RowBox[{"\[Chi]", ",", 
                    RowBox[{"NtL", "[", 
                    RowBox[{"GGFSParticle", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], "]"}]}], 
                   "]"}], ",", 
                  RowBox[{"GGFNambu", "[", 
                   RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}]}], "]"}], 
                ",", 
                SubscriptBox["k", "i"]}], "]"}]}], "]"}], 
            RowBox[{"StringForm", "[", 
             RowBox[{"\"\<``\>\"", ",", 
              RowBox[{"Superscript", "[", 
               RowBox[{
                RowBox[{"Superscript", "[", 
                 RowBox[{
                  RowBox[{"Subscript", "[", 
                   RowBox[{
                    RowBox[{"OverBar", "[", "\[Chi]", "]"}], ",", 
                    RowBox[{"NtL", "[", 
                    RowBox[{"GGFSParticle", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}], "]"}]}], 
                   "]"}], ",", 
                  RowBox[{"GGFNambu", "[", 
                   RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]}], "]"}], 
                ",", 
                SubscriptBox["k", "i"]}], "]"}]}], "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"GGFPolynomial", "[", 
