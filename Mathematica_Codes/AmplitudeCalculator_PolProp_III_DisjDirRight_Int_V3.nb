                SubscriptBox["t", 
                 RowBox[{"GGFTime", "[", 
                  RowBox[{"[", 
                   RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]], "/", 
                "\[HBar]"}]}]}]}]}]}], "]"}]}], "]"}], ";"}]}], 
     "\[IndentingNewLine]", "]"}]}], "]"}], ";"}]], "Input",
