Cell[CellGroupData[{

Cell["Definition of the auxiliary arrays", "Subsection",
 CellChangeTimes->{{3.888315173503672*^9, 3.888315249112604*^9}, {
  3.888315302609094*^9, 3.8883153149727306`*^9}, {3.888315800792353*^9, 
  3.888315802330164*^9}, {3.9077382535011215`*^9, 3.907738255398263*^9}, {
  3.907918473174707*^9, 
  3.907918504245359*^9}},ExpressionUUID->"95d0e446-5995-454c-8acb-\
242548b921c3"],

Cell["\<\
Arrays specifying the Nambu indices (cf. NambuDirRight), the operator type \
(cf. SQTypeDirRight) and distinguishing internal from external \
single-particle indices (cf. IntExtDirRight) are defined, in accordance with \
the conventions for the second-quantization operators in the header of the \
notebook. In particular, to external (internal) single-particle indices the \
value of \[OpenCurlyQuote]1\[CloseCurlyQuote] (\[OpenCurlyQuote]0\
\[CloseCurlyQuote]) is assigned, whereas for second-quantization operators of \
creation (annihilation) type the associated array entry is \[OpenCurlyQuote]0\
\[CloseCurlyQuote] (\[OpenCurlyQuote]1\[CloseCurlyQuote]). For Nambu indices, \
the convention is straightforward.\
\>", "Text",
 CellChangeTimes->{
  3.907738221565965*^9, {3.907738292370362*^9, 3.9077384065565405`*^9}, {
   3.907738452268018*^9, 3.9077384848449388`*^9}, {3.9077430709590244`*^9, 
   3.907743126073769*^9}, {3.9077450424291105`*^9, 3.907745076531563*^9}, {
   3.907918517166184*^9, 3.9079188444385037`*^9}, 3.9091515935484114`*^9, {
   3.9092041717880774`*^9, 3.9092041805155473`*^9}, {3.909825793352968*^9, 
   3.909825806952718*^9}, {3.909836579919314*^9, 3.909836589037108*^9}, {
   3.909838758257552*^9, 3.909838766404265*^9}, {3.919162215703902*^9, 
   3.919162230095312*^9}},ExpressionUUID->"803f5f0a-f2e2-4b24-a46d-\
f9f276df5033"],

