                 SubscriptBox["\[CapitalOmega]", "0"]}], ")"}], 
               RowBox[{
                SubscriptBox["t", 
                 RowBox[{"GGFTime", "[", 
                  RowBox[{"[", 
                   RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]], "/", 
                "\[HBar]"}]}]}]}]}], ",", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"GGFAmplitude", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i"}], "]"}], "]"}], " ", "=", 
             RowBox[{
              RowBox[{"StringForm", "[", 
               RowBox[{"\"\<``\>\"", ",", 
                RowBox[{"Superscript", "[", 
                 RowBox[{
                  RowBox[{"Superscript", "[", 
