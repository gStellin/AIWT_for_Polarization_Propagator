              "\[LessEqual]", " ", "12"}], ",", 
             RowBox[{
              RowBox[{"NambuDirRight", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "=", "1"}]}],
             "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
