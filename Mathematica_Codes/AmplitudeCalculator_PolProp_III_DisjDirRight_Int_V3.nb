                  ",", 
                  SubscriptBox["k", "i"]}], "]"}]}], "]"}]}]}], " ", ";", 
            "\[IndentingNewLine]", " ", 
            RowBox[{
             RowBox[{"GGFPolynomial", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i"}], "]"}], "]"}], " ", "=", 
             RowBox[{
              RowBox[{
               RowBox[{"+", 
                RowBox[{"(", " ", 
                 RowBox[{
                  SubscriptBox["\[CapitalOmega]", 
