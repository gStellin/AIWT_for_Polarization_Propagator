              RowBox[{
               RowBox[{"NambuBogAntidiag", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}], "\[Equal]", 
               "2"}]}], ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"IntExtBogAntidiag", "[", 
