             SubscriptBox["t", "4"], "-", 
             SubscriptBox["t", "3"]}], ")"}]}], "-", 
          RowBox[{"\[Epsilon]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "3"], "-", 
             SubscriptBox["t", "2"]}], ")"}]}], "-", 
          RowBox[{"\[Digamma]", 
           RowBox[{"(", 
