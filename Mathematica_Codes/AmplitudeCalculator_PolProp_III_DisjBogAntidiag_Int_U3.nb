     TraditionalForm], "t", 
    RowBox[{"t", "'"}], 
    RowBox[{"t", "'"}], "t"},
   {"2", "2", "3", "3", "4", "4", "5", "1", "1", "5"}
  },
  GridBoxDividers->{"Columns" -> {{True}}, "Rows" -> {{True}}}]],
 TextAlignment->
  Center,ExpressionUUID->"421ee3bd-fc64-49f0-b3f8-0a626c6b40e5"]], "Text",
 CellChangeTimes->{{3.912442764149543*^9, 3.9124428630736017`*^9}, {
  3.9145269498268366`*^9, 
  3.914526984621898*^9}},ExpressionUUID->"2f98d557-7289-4593-a8ce-\
bdb05efaf59d"],

Cell[TextData[{
 "Single-particle indices \[OpenCurlyQuote]b\[CloseCurlyQuote] and \
\[OpenCurlyQuote]d\[CloseCurlyQuote] in Bogoliubov fully-contracted terms are \
involute. For their numeric counterpart, the following convention is adopted: \
\nIndex > 0 \[DoubleRightArrow] ",
 StyleBox["standard",
  FontSlant->"Italic"],
 "\nIndex < 0 \[DoubleRightArrow] ",
 StyleBox["involute",
  FontSlant->"Italic"],
 "."
}], "Text",
 CellChangeTimes->{{3.8874623260617847`*^9, 3.8874623745747523`*^9}, {
   3.88746257423927*^9, 3.887462578566905*^9}, {3.888312600987131*^9, 
   3.8883126358497353`*^9}, {3.91129488637901*^9, 3.9112950440113215`*^9}, 
   3.9144100582670283`*^9, {3.9144109029147243`*^9, 
   3.9144109032935266`*^9}},ExpressionUUID->"fd35a5e7-1a31-4510-b78b-\
887a8d206cf9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Selection of the Nambu component of the one-body potential", "Section",
 CellChangeTimes->{{3.9120816659877415`*^9, 
  3.9120817133455973`*^9}},ExpressionUUID->"dfd5be5e-abd0-4700-a61e-\
197b1710accb"],

Cell[TextData[{
 "The analytical results presented henceforth refer to an element of the \
product between ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "1"]}], TraditionalForm]],ExpressionUUID->
  "95f72f91-ee9f-4d12-9e23-efb30077992d"],
 "), ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "2"]}], TraditionalForm]],ExpressionUUID->
  "8b8aca35-e51b-4abb-aca8-dcd1de75fff0"],
 "),",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{"U", "(", 
     SubscriptBox["t", "3"]}]}], TraditionalForm]],ExpressionUUID->
  "b7ccdd14-50c7-450c-ac0f-79476cfacc9e"],
 ")  and the second-quantization operators with external single-particle \
indices. At third order, such elements are specified by the two pairs of  \
Nambu indices that determine the component ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], 
    RowBox[{
     SubscriptBox["g", "5"], 
     SubscriptBox["g", "6"]}]], TraditionalForm]],ExpressionUUID->
  "b12310ff-5311-413f-9dd7-75747d977d45"],
 " (",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "gh"], 
    RowBox[{
     SubscriptBox["g", "7"], 
     SubscriptBox["g", "8"]}]], TraditionalForm]],ExpressionUUID->
  "d5f1a38a-2ddd-4908-8726-930caccdb657"],
 "and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ij"], 
    RowBox[{
     SubscriptBox["g", "9"], 
     SubscriptBox["g", "10"]}]], TraditionalForm]],ExpressionUUID->
  "be087dcf-c5f0-4cc1-94bd-902fd5a5f17a"],
 ") of the auxiliary one-body potential ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "1"]}], TraditionalForm]],ExpressionUUID->
  "7e8c51b1-7f84-4c9f-9478-e9aee0f1defb"],
 ") (",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "2"]}], TraditionalForm]],ExpressionUUID->
  "74d7bdf3-8de9-4b57-9f75-4b390b4b7e55"],
 ") and ",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{"U", "(", 
     SubscriptBox["t", "3"]}]}], TraditionalForm]],ExpressionUUID->
  "6a1bf294-96cd-42e5-806b-a3c553f6dabc"],
 ")). The indices are stored as { ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "5"], TraditionalForm]],ExpressionUUID->
  "edb5b10a-1ad7-40ad-ae94-04ca6f0f17f9"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "6"], TraditionalForm]],ExpressionUUID->
  "d48fa178-b91a-45a1-b32e-51fba7df5940"],
 ",",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    SubscriptBox["g", "7"]}], TraditionalForm]],ExpressionUUID->
  "0fbcbbdf-057d-4798-99e6-e3a5d2b09f31"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "8"], TraditionalForm]],ExpressionUUID->
  "7a1b2c6a-4236-4e2f-8365-8fc3dfd5945a"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "9"], TraditionalForm]],ExpressionUUID->
  "c1063fa8-c2cb-42b9-a8be-8c0e624dee34"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "10"], TraditionalForm]],ExpressionUUID->
  "408c36e2-96fb-4fe0-8288-89a45d3db727"],
 "} in the array \[OpenCurlyQuote]UNambu\[CloseCurlyQuote], together with the \
associated multiplicity arising from the product between ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "1"]}], TraditionalForm]],ExpressionUUID->
  "258ccd18-0abe-4979-9425-32ba1cee7703"],
 "), ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "2"]}], TraditionalForm]],ExpressionUUID->
  "7916654c-2559-4d01-a09a-12900fee3198"],
 ") and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "3"]}], TraditionalForm]],ExpressionUUID->
  "65d307c0-d0e3-4e79-b38c-4922dd25eccc"],
 "). Since the single-particle indices are summed, the products ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "12"], TraditionalForm]],ExpressionUUID->
  "4a9ff0fe-afeb-431c-a81f-d01a5833fca8"],
 " ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "gh"], "21"], TraditionalForm]],ExpressionUUID->
  "1aea2463-613b-4097-a684-b974761c1e87"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ij"], "22"], TraditionalForm]],ExpressionUUID->
  "21712c4f-12a5-498d-8f09-03b214dafa2b"],
 " , ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     SubscriptBox["u", "ij"], "22"], 
    SuperscriptBox[
     SubscriptBox["u", "ef"], "21"]}], TraditionalForm]],ExpressionUUID->
  "fc387731-30b4-4ea2-b96a-b6f1c9a93d96"],
 " ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "gh"], "12"], TraditionalForm]],ExpressionUUID->
  "8307d474-645d-4f4f-8e45-53b7b03b2951"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     SubscriptBox["u", "ij"], "22"], 
    SuperscriptBox[
     SubscriptBox["u", "gh"], "12"], " ", 
    SuperscriptBox[
     SubscriptBox["u", "ef"], "21"]}], TraditionalForm]],ExpressionUUID->
  "fa2d83c2-a9fe-41ec-bbbe-3a15e95b0398"],
 " et c. give rise to identical contributions, hence are summed together, \
resulting in a multiplicity equal to 6. The same occurs for all other \
contributions with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "5"], TraditionalForm]],ExpressionUUID->
  "4cb69f6a-02fb-470b-9ba9-2ddcdb1a0c05"],
 " \[NotEqual] ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["g", "7"], " ", "\[NotEqual]"}], TraditionalForm]],
  ExpressionUUID->"3373bfc0-dd2f-4967-9607-2d3b9a89dcc3"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "9"], TraditionalForm]],ExpressionUUID->
  "1687fb3d-48da-4c87-9bc5-d7df6c42fb65"],
 " and/or ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "6"], TraditionalForm]],ExpressionUUID->
  "bad77787-92e2-4fd1-a78f-a346e98e7ddd"],
 "\[NotEqual] ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "8"], TraditionalForm]],ExpressionUUID->
  "099cc378-ec34-4e79-b6be-52c75b491967"],
 "\[NotEqual] ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "10"], TraditionalForm]],ExpressionUUID->
  "f80c7b4c-e44d-48e1-9518-86852e58a3cd"],
 ". Similarly, the contributions  ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "11"], TraditionalForm]],ExpressionUUID->
  "02e625b9-1790-45b2-9ced-4c72cfd04081"],
 " ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "gh"], "22"], TraditionalForm]],ExpressionUUID->
  "e79f08ff-1091-4bab-b193-e69a3fe4cb65"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ij"], "22"], TraditionalForm]],ExpressionUUID->
  "9a7c7922-930e-4a40-a9e7-348a2992a3b8"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     SubscriptBox["u", "ij"], "22"], 
    SuperscriptBox[
     SubscriptBox["u", "ef"], "11"]}], TraditionalForm]],ExpressionUUID->
  "023c4fc7-577d-433e-85ff-85ef78f78969"],
 " ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "gh"], "22"], TraditionalForm]],ExpressionUUID->
  "80da4e2d-240e-42a0-b27f-7f130360a6ff"],
 " produce identical contributions and are summed up, yielding a multiplicity \
equal to 2. As a result,  the component ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "11"], TraditionalForm]],ExpressionUUID->
  "5598594a-439c-4121-9991-6b844a9673ac"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "gh"], "11"], TraditionalForm]],ExpressionUUID->
  "8885065c-acd0-4911-9eb9-73bdfdc41ab5"],
 " ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ij"], "11"], TraditionalForm]],ExpressionUUID->
  "94bd96f5-5bb5-4fec-b5cb-e93153680ce7"],
 " and is encoded by \[OpenCurlyQuote]UNambu[[1]]\[CloseCurlyQuote] , ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "12"], TraditionalForm]],ExpressionUUID->
  "a7e55fd5-d0fa-416a-8bcf-211ee8d6b794"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "gh"], "12"], TraditionalForm]],ExpressionUUID->
  "2d97bab7-ff4a-4faa-9917-c14815ba930f"],
 " ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ij"], "12"], TraditionalForm]],ExpressionUUID->
  "d738b6e7-d3eb-4dba-86bc-b8bd5bfdca5c"],
 "  is mapped to \[OpenCurlyQuote]UNambu[[2]]\[CloseCurlyQuote], ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "21"], TraditionalForm]],ExpressionUUID->
  "b6d69084-e329-4e13-aa60-9d010817d046"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     SubscriptBox["u", "gh"], "21"], 
    SuperscriptBox[
     SubscriptBox["u", "ij"], "21"]}], TraditionalForm]],ExpressionUUID->
  "21ca5d16-186b-4ab7-8f08-079e70c51bd1"],
 " to \[OpenCurlyQuote]UNambu[[3]]\[CloseCurlyQuote] and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "22"], TraditionalForm]],ExpressionUUID->
  "9c6feb97-348a-4b5e-8466-51943a30fea1"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "gh"], "22"], TraditionalForm]],ExpressionUUID->
  "2359efa1-0a44-4fd0-9320-8e576504109c"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ij"], "22"], TraditionalForm]],ExpressionUUID->
  "ad5e0a80-000b-4ead-9173-12a555e79491"],
 "  to \[OpenCurlyQuote]UNambu[[4]]\[CloseCurlyQuote] and are associated with \
multiplicity 1. Analogously,  the component ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "11"], TraditionalForm]],ExpressionUUID->
  "347e5ac3-023f-4418-a5af-5ebd37f14e2c"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "gh"], "11"], TraditionalForm]],ExpressionUUID->
  "a8efbe94-aa71-4ca7-90b2-6f2e79ce2255"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ij"], "12"], TraditionalForm]],ExpressionUUID->
  "44026f9b-b094-47e1-bc94-de0ef9ea48e1"],
 " and is encoded by \[OpenCurlyQuote]UNambu[[5]]\[CloseCurlyQuote]",
 Cell[BoxData[
  FormBox[
   RowBox[{",", " ", 
    RowBox[{
     FormBox[
      SuperscriptBox[
       SubscriptBox["u", "ef"], "11"],
      TraditionalForm], 
     SuperscriptBox[
      SubscriptBox["u", "gh"], "12"]}]}], TraditionalForm]],ExpressionUUID->
  "ac994d91-eb6a-47bc-b36d-3706c1b5a2e9"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ij"], "12"], TraditionalForm]],ExpressionUUID->
  "1f087064-d492-4e86-b14a-f6b0a74fb773"],
 " is mapped to \[OpenCurlyQuote]UNambu[[6]]\[CloseCurlyQuote] et c. and the \
associated multiplicity is equal to 2, since only two of the vertices are \
identical. Finally, the component ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "11"], TraditionalForm]],ExpressionUUID->
  "a913c928-77ea-4fa7-bcd4-595f0215446f"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "gh"], "12"], TraditionalForm]],ExpressionUUID->
  "cf9017eb-405c-4d1f-a52d-c3cfac9f2e08"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ij"], "21"], TraditionalForm]],ExpressionUUID->
  "dbb7b1b3-45ec-41f0-8161-9982f258bf76"],
 " is encoded by  \[OpenCurlyQuote]UNambu[[17]]\[CloseCurlyQuote], ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "11"], TraditionalForm]],ExpressionUUID->
  "26953d9e-273f-4eb2-a505-08988c7abaf2"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "gh"], "12"], TraditionalForm]],ExpressionUUID->
  "37fa10e0-59f6-4cf0-8a8d-53fceffbbc43"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ij"], "22"], TraditionalForm]],ExpressionUUID->
  "f38c7314-8789-429a-817e-015f00385567"],
 "  by  \[OpenCurlyQuote]UNambu[[18]]\[CloseCurlyQuote], ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "11"], TraditionalForm]],ExpressionUUID->
  "3ccce28c-996e-4794-9cb7-af2b1d5c07cf"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "gh"], "21"], TraditionalForm]],ExpressionUUID->
  "36021cd4-9d86-4fd4-a137-cc38cb1f6cd2"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ij"], "22"], TraditionalForm]],ExpressionUUID->
  "8439713c-0d5b-4f57-8dbf-2d71bdcb2df0"],
 "  by  \[OpenCurlyQuote]UNambu[[19]]\[CloseCurlyQuote] and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "12"], TraditionalForm]],ExpressionUUID->
  "b0b041a2-7a35-491a-8262-454a0e729200"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "gh"], "21"], TraditionalForm]],ExpressionUUID->
  "f47f03c5-2370-40d9-8121-e9f567f10618"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ij"], "22"], TraditionalForm]],ExpressionUUID->
  "5ba69ef5-1f06-4f1e-8c03-09798977384b"],
 "  by  \[OpenCurlyQuote]UNambu[[20]]\[CloseCurlyQuote], their multiplicity \
being equal to 6 as the three vertices are non-identical."
}], "Text",
 CellChangeTimes->CompressedData["
