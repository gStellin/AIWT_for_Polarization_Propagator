                  ",", 
                  SubscriptBox["k", "i"]}], "]"}]}], "]"}]}]}], " ", ";", 
            "\[IndentingNewLine]", " ", 
            RowBox[{
             RowBox[{"GGFPolynomial", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i"}], "]"}], "]"}], " ", "=", 
             RowBox[{
              RowBox[{
               RowBox[{"+", 
                RowBox[{"(", " ", 
                 RowBox[{
                  SubscriptBox["\[CapitalOmega]", 
                   SubscriptBox["k", "i"]], "-", 
                  SubscriptBox["\[CapitalOmega]", "0"]}], ")"}]}], 
               RowBox[{
                SubscriptBox["t", 
                 RowBox[{"GGFTime", "[", 
                  RowBox[{"[", 
                   RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}]], "/", 
                "\[HBar]"}]}], "-", 
              RowBox[{
               RowBox[{"(", " ", 
                RowBox[{
                 SubscriptBox["\[CapitalOmega]", 
                  SubscriptBox["k", "i"]], "-", 
                 SubscriptBox["\[CapitalOmega]", "0"]}], ")"}], 
               RowBox[{
                SubscriptBox["t", 
                 RowBox[{"GGFTime", "[", 
                  RowBox[{"[", 
                   RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]], "/", 
                "\[HBar]"}]}]}]}]}], ",", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"GGFAmplitude", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i"}], "]"}], "]"}], " ", "=", 
             RowBox[{
              RowBox[{"StringForm", "[", 
               RowBox[{"\"\<``\>\"", ",", 
                RowBox[{"Superscript", "[", 
                 RowBox[{
                  RowBox[{"Superscript", "[", 
                   RowBox[{
