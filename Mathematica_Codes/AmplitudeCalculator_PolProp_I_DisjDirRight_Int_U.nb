Cell[CellGroupData[{

Cell["Selection of the Nambu component of the one-body potential", "Section",
 CellChangeTimes->{{3.9120816659877415`*^9, 
  3.9120817133455973`*^9}},ExpressionUUID->"b751355b-9567-4eac-bcee-\
9ed85974b184"],

Cell[TextData[{
 "The analytical results presented henceforth refer to an element of the \
product between ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "1"]}], TraditionalForm]],ExpressionUUID->
  "b4c5403c-cce0-4604-931f-64a72563eee3"],
 ") and the second-quantization operators with external single-particle \
indices. At first order, such elements are specified by the two indices that \
determine the Nambu component, ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], 
    RowBox[{
     SubscriptBox["g", "5"], 
     SubscriptBox["g", "6"]}]], TraditionalForm]],ExpressionUUID->
  "0d5ffd8e-af98-4dd7-b25d-bd2c12adca81"],
 " , of the auxiliary one-body potential ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "1"]}], TraditionalForm]],ExpressionUUID->
  "7b0c052c-080b-409b-b0f3-8e2f711c7612"],
 "), ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "5"], TraditionalForm]],ExpressionUUID->
  "5c9e1058-fcea-4860-a226-db213967f035"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "6"], TraditionalForm]],ExpressionUUID->
  "a571a6e6-c7a5-4e90-9a0d-24c99bce7afe"],
 ", stored in the array \[OpenCurlyQuote]UNambu\[CloseCurlyQuote]. As a \
result,  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "5"], TraditionalForm]],ExpressionUUID->
  "d8aa23ee-24b4-4beb-a9cd-adfdbe4c66b2"],
 "=1 and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["g", "6"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "a296aa52-5563-435a-b1d0-77b64d496e19"],
 " denote the component ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "11"], TraditionalForm]],ExpressionUUID->
  "6192afdf-9742-4835-9e65-56646a6549f2"],
 " and is encoded by \[OpenCurlyQuote]UNambu[[1]]\[CloseCurlyQuote] . \
Analogously,  ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "22"], TraditionalForm]],ExpressionUUID->
  "a8ba1ae7-a4e9-4a4f-9e8b-452073ca5285"],
 " is mapped to \[OpenCurlyQuote]UNambu[[4]]\[CloseCurlyQuote], ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "21"], TraditionalForm]],ExpressionUUID->
  "4ee7817d-6072-4dc4-80b9-4cc3d3c5ef93"],
 " to \[OpenCurlyQuote]UNambu[[3]]\[CloseCurlyQuote] and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "12"], TraditionalForm]],ExpressionUUID->
  "2652a02e-6afd-47a3-8f4e-8ffbd6e81ae0"],
 " to \[OpenCurlyQuote]UNambu[[2]]\[CloseCurlyQuote] ."
}], "Text",
 CellChangeTimes->{{3.9120817763864603`*^9, 3.9120818052616024`*^9}, {
