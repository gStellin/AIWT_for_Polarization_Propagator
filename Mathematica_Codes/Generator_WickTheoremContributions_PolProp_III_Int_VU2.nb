Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["\[CapitalPi]", "acdb"], 
    RowBox[{
     SubscriptBox["g", "1"], 
     SubscriptBox["g", "3"], 
     SubscriptBox["g", "4"], 
     SubscriptBox["g", "2"]}]], TraditionalForm]],ExpressionUUID->
  "ebacd277-e712-4b7d-b4d6-c7810a2fd43f"],
 " ",
