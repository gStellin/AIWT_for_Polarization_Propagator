Cell["\<\
Diagonally-dressed disjoint Bogoliubov diagrams with non-identical one-body \
vertices\
\>", "Subsection",
 CellChangeTimes->{{3.874644843789677*^9, 3.8746448545752873`*^9}, {
   3.883112065177337*^9, 3.883112118360941*^9}, {3.8831146011227875`*^9, 
