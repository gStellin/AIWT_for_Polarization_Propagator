Cell[CellGroupData[{

Cell["Generation of the third-order fully-contracted terms", "Section",
 CellChangeTimes->{{3.8746447213615894`*^9, 3.874644731124649*^9}, {
  3.8746447691271086`*^9, 3.87464477328621*^9}, {3.8746449100185723`*^9, 
  3.87464492347766*^9}, {3.883683441766288*^9, 3.8836834625750504`*^9}, {
  3.9118970005751615`*^9, 3.911897006408928*^9}, {3.913781331153411*^9, 
  3.9137813323708644`*^9}},ExpressionUUID->"7b4618c9-2120-4875-ad14-\
4614c122580d"],

Cell[TextData[{
 "The third-order contractions  are found to be ",
 StyleBox["10,395",
  FontSlant->"Italic"],
 " in total, consistently with the formula 3",
 StyleBox["n+2!!",
  FontSlant->"Italic"],
 " with ",
 StyleBox["n=3",
  FontSlant->"Italic"],
 ". Binary contractions belonging to the same fully contracted term (index ",
 StyleBox["i",
  FontSlant->"Italic"],
 " in the array initialization) are denoted by the index ",
 StyleBox["j",
  FontSlant->"Italic"],
 ". The two single particle indices within the same contraction are \
distinguished by the index ",
 StyleBox["k",
  FontSlant->"Italic"],
 ". The process produces no repeated pairs, by construction."
}], "Text",
 CellChangeTimes->{{3.8836835314266734`*^9, 3.8836835815187073`*^9}, {
   3.9118970276182923`*^9, 3.91189705203018*^9}, {3.9118972450460634`*^9, 
   3.9118972459640284`*^9}, 3.911903067850914*^9, 3.9137813468779016`*^9, {
