Cell[BoxData[{
 RowBox[{
  RowBox[{"AccVertex", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "1920"}], "}"}], ",", 
     RowBox[{"{", 
