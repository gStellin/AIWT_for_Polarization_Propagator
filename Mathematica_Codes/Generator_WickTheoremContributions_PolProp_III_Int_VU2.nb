  RowBox[{
   RowBox[{"AdisjExchangeCombFile", "=", 
    RowBox[{"OpenWrite", "[", 
     RowBox[{
     "\"\<E:\\\\Mathematica's AIWT for the Polarization \
Propagator\\\\Contractions\\\\Out_Comb_3_DisjExchange_VU2_UEq_2.m\>\"", ",", 
      RowBox[{"PageWidth", "->", "Infinity"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"u", "=", "1"}], ",", 
     RowBox[{"u", "\[LessEqual]", " ", "120"}], ",", 
     RowBox[{"u", "++"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"WriteString", "[", 
       RowBox[{
       "AdisjExchangeCombFile", ",", "\"\<CombExchange[[\>\"", ",", " ", "u", 
