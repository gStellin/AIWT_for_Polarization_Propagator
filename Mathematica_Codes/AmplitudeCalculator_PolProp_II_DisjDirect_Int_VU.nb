Cell[BoxData[
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"u", "=", "1"}], ",", 
   RowBox[{"u", "\[LessEqual]", " ", "16"}], ",", 
   RowBox[{"u", "++"}], ",", 
   RowBox[{"Print", "[", 
    RowBox[{"u", ",", " ", "\"\<    \>\"", ",", 
     RowBox[{"GGFTime", "[", 
      RowBox[{"[", "u", "]"}], "]"}]}], "]"}]}], "]"}]], "Input",
