Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NtL", "[", "s_", "]"}], ":=", 
   RowBox[{"(", " ", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"s", "\[Equal]", "1"}], ",", " ", 
       RowBox[{"Return", "[", "\"\<p\>\"", "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"s", "\[Equal]", 
