              "\[LessEqual]", " ", "4"}], ",", 
             RowBox[{
              RowBox[{"NambuSkel", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "=", "1"}]}],
             "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
