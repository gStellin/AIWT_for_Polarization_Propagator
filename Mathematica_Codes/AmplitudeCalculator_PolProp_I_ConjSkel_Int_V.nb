              RowBox[{"CombSkel", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "\[Equal]", 
              "5"}], ",", 
             RowBox[{
              RowBox[{"NambuSkel", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "=", 
