              RowBox[{"[", 
               RowBox[{"T", ",", "3"}], "]"}], "]"}]], "-", 
            SubscriptBox["t", 
             RowBox[{"TimeClassOrdMinus", "[", 
              RowBox[{"[", 
               RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
         RowBox[{"\[Epsilon]", 
