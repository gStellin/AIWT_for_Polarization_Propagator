              RowBox[{"GPPNambu", "[", 
               RowBox[{"[", 
                RowBox[{"NppIdx", ",", "2"}], "]"}], "]"}]}]}], "]"}], 
           ";"}]}], "\[IndentingNewLine]", "]"}], ";"}]}], 
