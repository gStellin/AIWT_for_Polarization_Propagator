                RowBox[{"NppIdx", ",", "1"}], "]"}], "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"CombSkel", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "\[Equal]", 
