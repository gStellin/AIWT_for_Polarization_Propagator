  FormBox[
   SuperscriptBox[
    SubscriptBox["\[CapitalPi]", "acdb"], 
    RowBox[{
     SubscriptBox["g", "1"], 
     SubscriptBox["g", "3"], 
     SubscriptBox["g", "4"], 
     SubscriptBox["g", "2"]}]], TraditionalForm]],ExpressionUUID->
