  3.912081014119247*^9}},ExpressionUUID->"bd31ac3d-e57d-42fe-9999-\
cb8246d3be89"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Selection of the Nambu component of the one-body potential", "Section",
 CellChangeTimes->{{3.9120816659877415`*^9, 
  3.9120817133455973`*^9}},ExpressionUUID->"b9fa9781-a388-40e1-a69a-\
f9a9cb50d54f"],

Cell[TextData[{
 "The analytical results presented henceforth refer to an element of the \
product between ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "1"]}], TraditionalForm]],ExpressionUUID->
  "f9d4d47d-6e4b-4f44-94c8-c28d868fa9c1"],
 "), ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "2"]}], TraditionalForm]],ExpressionUUID->
  "5fbd6417-f3ff-4071-b468-4b7c6189113e"],
 ") and the second-quantization operators with external single-particle \
indices. At second order, such elements are specified by the two pairs of  \
Nambu indices that determine the component ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], 
    RowBox[{
     SubscriptBox["g", "5"], 
     SubscriptBox["g", "6"]}]], TraditionalForm]],ExpressionUUID->
  "87d8ee19-aeb4-49c7-9ab3-65218909b036"],
 " (",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "gh"], 
    RowBox[{
     SubscriptBox["g", "7"], 
     SubscriptBox["g", "8"]}]], TraditionalForm]],ExpressionUUID->
  "310593f1-8da2-486a-b77a-334739c5244c"],
 ") of the auxiliary one-body potential ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "1"]}], TraditionalForm]],ExpressionUUID->
  "778d9117-f375-497c-ac2b-646eeebbb8f1"],
 ") (",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "2"]}], TraditionalForm]],ExpressionUUID->
  "7937e1a9-4bfb-4bef-9c64-a17cc9685dff"],
 ")). The indices are stored as { ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "5"], TraditionalForm]],ExpressionUUID->
  "1c6f273b-5380-4896-9cf5-619ee058fb3f"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "6"], TraditionalForm]],ExpressionUUID->
  "f361fad7-644d-4313-85c4-b8357feada7e"],
 ",",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    SubscriptBox["g", "7"]}], TraditionalForm]],ExpressionUUID->
  "075ad88a-8df7-4b8c-949e-7635de5c2359"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "8"], TraditionalForm]],ExpressionUUID->
  "88713d2f-b562-4d5c-90c7-7dbed4a6e651"],
 "} in the array \[OpenCurlyQuote]UNambu\[CloseCurlyQuote], together with the \
associated multiplicity arising from the product between ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "1"]}], TraditionalForm]],ExpressionUUID->
  "5a18af68-8979-4d1f-80b1-986c0c09f188"],
 ") and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "2"]}], TraditionalForm]],ExpressionUUID->
  "d1f6566b-c550-4914-861d-b08e16152a8c"],
 "). Since the single-particle indices are summed, the products ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "12"], TraditionalForm]],ExpressionUUID->
  "1b19b9c1-63f9-4453-b128-d63df250153e"],
 " ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "gh"], "21"], TraditionalForm]],ExpressionUUID->
  "9fd53ede-3c76-4e1b-96c4-64ee2fd3969e"],
 " and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "21"], TraditionalForm]],ExpressionUUID->
  "328d364e-5091-4d2b-9a6a-7ca1adb9d9ea"],
 " ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "gh"], "12"], TraditionalForm]],ExpressionUUID->
  "7e6eaefd-f0b2-4656-9e75-a6727e2bb7a4"],
 " give rise to identical contributions, hence are summed together, resulting \
in a multiplicity equal to 2. The same occurs for all other contributions \
with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "5"], TraditionalForm]],ExpressionUUID->
  "cd4f28df-203b-4f00-b29d-3f9d3f256217"],
 " \[NotEqual] ",
 Cell[BoxData[
  FormBox[
