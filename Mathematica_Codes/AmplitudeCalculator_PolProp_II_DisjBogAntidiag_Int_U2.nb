Cell[CellGroupData[{

Cell["\<\
Calculation of the amplitude associated to Goldstone diagrams with alphabetic \
indices\
\>", "Subsection",
 CellChangeTimes->{{3.888315861110175*^9, 3.8883159051561947`*^9}, {
  3.8883159887111607`*^9, 3.888316043821027*^9}, {3.888316084808132*^9, 
  3.888316094409692*^9}, {3.9080017355726566`*^9, 3.9080017402516623`*^9}, {
  3.9082509561005807`*^9, 
  3.9082509656258793`*^9}},ExpressionUUID->"37e29fcc-0560-492b-ba8b-\
4ce3ee1e619b"],

Cell[TextData[{
 "The three time integrals are evaluated in two steps. First, one computes \
the integrals over ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "1"], TraditionalForm]],ExpressionUUID->
  "578827b1-b16c-4347-b0ce-b3c0aa379f41"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "2"], TraditionalForm]],ExpressionUUID->
  "a0c091c9-a2bb-4a4b-9934-8182e115c8ca"],
 " (dummy times), by solving a linear system with a parameter (the third \
frequency). At second order, the frequency variables which are evaluated \
after integration by ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "1"], TraditionalForm]],ExpressionUUID->
  "fb39c6ae-a2c0-4126-985c-8c815ae2f006"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "2"], TraditionalForm]],ExpressionUUID->
  "3f03e296-8cc9-4a20-bec0-ae75e80c6c35"],
 " are labeled as \[Gamma] and \[Epsilon]. Consequently, the time differences \
multiplying \[Gamma] and \[Epsilon] must contain the times ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", 
    RowBox[{"1", " "}]], TraditionalForm]],ExpressionUUID->
  "e0e9cb3b-3621-494f-b215-ab1602bd2bc6"],
 "and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "2"], TraditionalForm]],ExpressionUUID->
  "68365f81-1ad8-47b4-b672-94195051b213"],
 ", otherwise the integration fails. Next, the integration over (t-t\
\[CloseCurlyQuote]) is performed by solving a single linear equation, \
obtained by equating the coefficient of (t-t\[CloseCurlyQuote]) in the total \
polynomial to zero. Note that the time interval that multiplies \[Digamma]  \
must contain t and/or t\[CloseCurlyQuote].  However, t and \
t\[CloseCurlyQuote] shall not appear together in that time interval, \
otherwise the time ordering of the corresponding Goldstone diagram becomes \
undefined (or ambiguously defined). Consequently, in the denominators of the \
energy representation, multiple \[OpenCurlyQuote]omegas\[CloseCurlyQuote] may \
appear, depending on the topology of the unoriented Goldstone diagram. \
Besides, the time interval multiplying \[Digamma]  shall never coincide with \
the one multiplying \[Gamma] or \[Epsilon], otherwise the implemented time \
sequence is ill-defined."
}], "Text",
 CellChangeTimes->{{3.8883163242658205`*^9, 3.8883163554476023`*^9}, {
   3.8883164071679173`*^9, 3.8883165187772655`*^9}, {3.888316549145891*^9, 
   3.888316725014002*^9}, {3.8921261744276867`*^9, 3.8921261761442184`*^9}, {
   3.9399911443863597`*^9, 3.939991398095018*^9}, {3.939991454698805*^9, 
   3.9399914925585866`*^9}, {3.9399959309668074`*^9, 3.939995946544898*^9}, 
   3.945836275525977*^9, 3.945925566339361*^9, 
   3.945925629224594*^9},ExpressionUUID->"a56e30b5-3e70-42e5-9fbc-\
c9bfc1375f5e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"GGFTotalPolynomial", " ", "=", " ", 
    RowBox[{"Table", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"r", ",", "1", ",", "NcMax"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", " ", "NcMax"}], ",", " ", 
    RowBox[{"r", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"j", "=", "1"}], ",", 
       RowBox[{"j", "\[LessEqual]", "4"}], ",", 
       RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", 
         RowBox[{
          RowBox[{"GGFTotalPolynomial", "[", 
           RowBox[{"[", "r", "]"}], "]"}], "+", 
          RowBox[{"GGFPolynomial", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", "j"}], "]"}], "]"}]}]}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"T", "\[Equal]", "1"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
         RowBox[{
          RowBox[{"GGFTotalPolynomial", "[", 
           RowBox[{"[", "r", "]"}], "]"}], " ", "+", " ", 
          RowBox[{"\[Omega]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdMinus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "4"}], "]"}], "]"}]], "-", 
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdMinus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
          RowBox[{"\[Gamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "3"], "-", 
             SubscriptBox["t", "2"]}], ")"}]}], "-", 
          RowBox[{"\[Epsilon]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "2"], "-", 
             SubscriptBox["t", "1"]}], ")"}]}], "-", 
          RowBox[{"\[Digamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "4"], "-", 
             SubscriptBox["t", "3"]}], ")"}]}]}]}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"T", "\[Equal]", "2"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
         RowBox[{
          RowBox[{"GGFTotalPolynomial", "[", 
           RowBox[{"[", "r", "]"}], "]"}], " ", "+", " ", 
          RowBox[{"\[Omega]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdMinus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "4"}], "]"}], "]"}]], "-", 
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdMinus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
          RowBox[{"\[Gamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "4"], "-", 
             SubscriptBox["t", "3"]}], ")"}]}], "-", 
          RowBox[{"\[Epsilon]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "2"], "-", 
             SubscriptBox["t", "1"]}], ")"}]}], "-", 
          RowBox[{"\[Digamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "3"], "-", 
             SubscriptBox["t", "2"]}], ")"}]}]}]}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"T", "\[Equal]", "3"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
         RowBox[{
          RowBox[{"GGFTotalPolynomial", "[", 
           RowBox[{"[", "r", "]"}], "]"}], " ", "+", " ", 
          RowBox[{"\[Omega]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdMinus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "4"}], "]"}], "]"}]], "-", 
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdMinus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
          RowBox[{"\[Gamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "4"], "-", 
             SubscriptBox["t", "3"]}], ")"}]}], "-", 
          RowBox[{"\[Epsilon]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "3"], "-", 
             SubscriptBox["t", "2"]}], ")"}]}], "-", 
          RowBox[{"\[Digamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "2"], "-", 
             SubscriptBox["t", "1"]}], ")"}]}]}]}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"T", "\[Equal]", "4"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
         RowBox[{
          RowBox[{"GGFTotalPolynomial", "[", 
           RowBox[{"[", "r", "]"}], "]"}], " ", "+", " ", 
          RowBox[{"\[Omega]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdMinus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "4"}], "]"}], "]"}]], "-", 
             SubscriptBox["t", 
