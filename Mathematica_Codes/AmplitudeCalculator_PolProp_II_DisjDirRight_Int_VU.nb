   3.912751456414852*^9}, {3.9127519256588497`*^9, 3.9127519416916256`*^9}, {
   3.9127544660388017`*^9, 3.9127544812504034`*^9}, {3.912924002414775*^9, 
   3.9129240026082554`*^9}, {3.9129243314637256`*^9, 3.9129243421346216`*^9}, 
   3.9129253950349083`*^9, {3.912932039662629*^9, 3.912932068933645*^9}, {
   3.913205856666641*^9, 3.91320585715388*^9}, {3.913207038484579*^9, 
   3.9132070389862733`*^9}, 3.9132071209628496`*^9, {3.913217472366561*^9, 
