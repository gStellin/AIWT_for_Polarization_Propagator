Cell[CellGroupData[{

Cell["Selection of the Nambu component of the one-body potential", "Section",
 CellChangeTimes->{{3.9120816659877415`*^9, 
  3.9120817133455973`*^9}},ExpressionUUID->"a308ae95-1391-49a2-aa82-\
447d95bea4ce"],

Cell[TextData[{
 "The analytical results presented henceforth refer to an element of the \
product between ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["V", "_"], "(", 
     SubscriptBox["t", "1"], ")"}], ",", 
    RowBox[{"U", "(", 
     SubscriptBox["t", "2"]}]}], TraditionalForm]],ExpressionUUID->
  "b08b87c9-ba68-4781-92eb-6076723acac3"],
 ") and the second-quantization operators with external single-particle \
indices. The elements of  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "2"]}], TraditionalForm]],ExpressionUUID->
  "9f7cd8de-9cfb-4ff2-b953-adb3924357ed"],
 ") are specified by the two indices that determine the Nambu component, ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], 
    RowBox[{
     SubscriptBox["g", "5"], 
     SubscriptBox["g", "6"]}]], TraditionalForm]],ExpressionUUID->
  "50b10e27-c56d-40df-a86c-9b8a8be67fb5"],
 " , of the auxiliary one-body potential ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "2"]}], TraditionalForm]],ExpressionUUID->
  "5a33e42c-b75b-401f-b715-8d18b4cf9666"],
 "), ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "5"], TraditionalForm]],ExpressionUUID->
  "7654f529-f812-49d1-998e-463dcfc313a3"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "6"], TraditionalForm]],ExpressionUUID->
  "34e12fed-9e6e-4093-afcb-431cfe7d282c"],
 ", stored in the array \[OpenCurlyQuote]UNambu\[CloseCurlyQuote]. As a \
result,  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "5"], TraditionalForm]],ExpressionUUID->
  "2d17867e-f62a-46ce-aa47-f8cfc5006914"],
 "=1 and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["g", "6"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "25a45373-02e0-410d-80aa-2dfd96d6672c"],
 " denote the component ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "11"], TraditionalForm]],ExpressionUUID->
  "07e38c1d-ccf5-4fb9-8881-f9c0a32ffd7e"],
 " and is encoded by \[OpenCurlyQuote]UNambu[[1]]\[CloseCurlyQuote] . \
Analogously,  ",
 Cell[BoxData[
  FormBox[
