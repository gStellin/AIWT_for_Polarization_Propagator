                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "]"}], 
              "\[Equal]", "4"}]}], " ", ",", 
            RowBox[{
             RowBox[{"GGFTime", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "=", "2"}]}], 
           "]"}], ";", " ", 
          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{"Time", " ", "Class", " ", "2"}], " ", "=", " ", 
            SubscriptBox["t", "1"]}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "]"}], 
              "\[Equal]", "6"}], " ", "||", " ", 
             RowBox[{
              RowBox[{"Abs", "[", 
