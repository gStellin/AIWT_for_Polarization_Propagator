             RowBox[{
              RowBox[{"CombBogDiag", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "\[Equal]", 
              "  ", "7"}], ",", 
             RowBox[{
              RowBox[{"NambuBogDiag", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "=", 
              RowBox[{"UNambu", "[", 
