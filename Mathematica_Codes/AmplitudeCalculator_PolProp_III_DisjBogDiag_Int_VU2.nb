 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"u", "=", "1"}], ",", 
   RowBox[{"u", "\[LessEqual]", " ", "NcMax"}], ",", 
   RowBox[{"u", "++"}], ",", 
