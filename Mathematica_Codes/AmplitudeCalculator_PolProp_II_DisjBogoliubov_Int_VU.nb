Cell[CellGroupData[{

Cell["Gorkov\[CloseCurlyQuote]s Polarization Propagator", "Section",
 CellChangeTimes->{{3.888315173503672*^9, 3.888315249112604*^9}, {
  3.9077381956757917`*^9, 3.907738210921955*^9}, {3.9077382748518915`*^9, 
