         RowBox[{"u", ",", "2", ",", "2"}], "]"}], "]"}], "\[Equal]", "1"}], 
      " ", "&&", " ", 
      RowBox[{
       RowBox[{"GGFNambu", "[", 
        RowBox[{"[", 
         RowBox[{"u", ",", "3", ",", "1"}], "]"}], "]"}], "\[Equal]", "1"}], 
      " ", "&&", " ", 
      RowBox[{
       RowBox[{"GGFNambu", "[", 
        RowBox[{"[", 
         RowBox[{"u", ",", "3", ",", "2"}], "]"}], "]"}], "\[Equal]", "1"}], 
      " ", "&&", " ", 
      RowBox[{
       RowBox[{"GGFNambu", "[", 
        RowBox[{"[", 
         RowBox[{"u", ",", "4", ",", "1"}], "]"}], "]"}], "\[Equal]", "1"}], 
      " ", "&&", " ", 
      RowBox[{
       RowBox[{"GGFNambu", "[", 
        RowBox[{"[", 
         RowBox[{"u", ",", "4", ",", "2"}], "]"}], "]"}], "\[Equal]", "1"}], 
      " ", "&&", 
      RowBox[{
       RowBox[{"GGFNambu", "[", 
        RowBox[{"[", 
         RowBox[{"u", ",", "5", ",", "1"}], "]"}], "]"}], "\[Equal]", "1"}], 
      " ", "&&", " ", 
      RowBox[{
       RowBox[{"GGFNambu", "[", 
        RowBox[{"[", 
         RowBox[{"u", ",", "5", ",", "2"}], "]"}], "]"}], "\[Equal]", "1"}]}],
      ",", 
     RowBox[{"Print", "[", 
      RowBox[{"u", ",", " ", "\"\<    \>\"", ",", 
       RowBox[{"GGFFeynmanAmplitude", "[", 
        RowBox[{"[", "u", "]"}], "]"}], ",", "\"\<\\n\>\""}], "]"}]}], 
    "]"}]}], "]"}]], "Input",
