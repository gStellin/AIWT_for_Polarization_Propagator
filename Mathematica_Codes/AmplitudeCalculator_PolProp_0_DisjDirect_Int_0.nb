           RowBox[{"[", "r", "]"}], "]"}], "+", 
          RowBox[{"GGFPolynomial", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", "j"}], "]"}], "]"}]}]}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"TimeClassOrdPlus", "[", 
            RowBox[{"[", 
             RowBox[{"T", ",", "2"}], "]"}], "]"}], "\[Equal]", " ", "2"}], 
          " ", "&&", " ", 
          RowBox[{
           RowBox[{"TimeClassOrdPlus", "[", 
            RowBox[{"[", 
             RowBox[{"T", ",", "1"}], "]"}], "]"}], "\[Equal]", "1"}]}], 
         ")"}], "||", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"TimeClassOrdPlus", "[", 
            RowBox[{"[", 
             RowBox[{"T", ",", "2"}], "]"}], "]"}], "\[Equal]", " ", "1"}], 
