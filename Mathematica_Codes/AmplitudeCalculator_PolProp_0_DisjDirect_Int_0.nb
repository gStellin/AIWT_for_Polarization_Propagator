Cell["Definition of the Nambu component", "Subsection",
 CellChangeTimes->{{3.888315173503672*^9, 3.888315249112604*^9}, {
  3.8883153026090937`*^9, 3.8883153149727306`*^9}, {3.888315800792353*^9, 
  3.888315802330164*^9}, {3.9077382535011215`*^9, 
  3.907738255398263*^9}},ExpressionUUID->"1dbd5ca1-6813-4784-906e-\
e077e4b05cc4"],

Cell["\<\
Four Nambu indices specify univocally each of the 16 Nambu components of the \
polarization propagator. Normal (anomalous) components possess an even (even \
or odd) number of \[OpenCurlyQuote]1\[CloseCurlyQuote] and \[OpenCurlyQuote]2\
\[CloseCurlyQuote] indices. In total, there are 6 normal (indices 1-6 of \
GPPNambu) and 10 anomalous components (indices 7-16 of GPPNambu) . Once \
\[OpenCurlyQuote]NppIdx\[CloseCurlyQuote] is specified, the Nambu component \
is fixed.\
\>", "Text",
 CellChangeTimes->{
  3.9077382215659647`*^9, {3.9077382923703613`*^9, 3.9077384065565405`*^9}, {
   3.9077384522680173`*^9, 3.9077384848449383`*^9}, {3.9077430709590244`*^9, 
   3.907743126073769*^9}, {3.9077450424291105`*^9, 3.9077450765315623`*^9}, {
   3.9228829130708513`*^9, 3.9228829148420086`*^9}, {3.947078942003976*^9, 
   3.9470789461310863`*^9}},ExpressionUUID->"a525e5ce-a7b4-49b6-8f83-\
c87b371bc6f1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"GPPNambu", "=", 
    RowBox[{"Table", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "16"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", "1", ",", "4"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"GPPNambu", " ", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "1", ",", "1", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "1", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "1", ",", "2", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "1", ",", "1", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "2", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "2", ",", "2", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "1", ",", "2", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "2", ",", "1", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "1", ",", "1", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "1", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "1", ",", "2", ",", "1"}], "}"}], ",", 
