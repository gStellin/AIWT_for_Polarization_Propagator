            SubscriptBox["t", 
             RowBox[{"TimeClassOrdPlus", "[", 
              RowBox[{"[", 
               RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
         RowBox[{"\[Epsilon]", 
          RowBox[{"(", 
           RowBox[{
            SubscriptBox["t", "2"], "-", 
            SubscriptBox["t", "1"]}], ")"}]}], "-", 
         RowBox[{"\[Digamma]", 
          RowBox[{"(", 
           RowBox[{
            SubscriptBox["t", "3"], "-", 
            SubscriptBox["t", "2"]}], ")"}]}]}]}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"T", "\[Equal]", "3"}], ",", 
       RowBox[{
        RowBox[{"GGFTotalPolynomial", "[", 
         RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "+", " ", 
         RowBox[{"\[Omega]", 
          RowBox[{"(", 
           RowBox[{
            SubscriptBox["t", 
             RowBox[{"TimeClassOrdPlus", "[", 
              RowBox[{"[", 
               RowBox[{"T", ",", "3"}], "]"}], "]"}]], "-", 
            SubscriptBox["t", 
             RowBox[{"TimeClassOrdPlus", "[", 
              RowBox[{"[", 
               RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
         RowBox[{"\[Epsilon]", 
          RowBox[{"(", 
           RowBox[{
            SubscriptBox["t", "3"], "-", 
            SubscriptBox["t", "2"]}], ")"}]}], "-", 
         RowBox[{"\[Digamma]", 
          RowBox[{"(", 
           RowBox[{
            SubscriptBox["t", "2"], "-", 
            SubscriptBox["t", "1"]}], ")"}]}]}]}]}], "]"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.8883131567634354`*^9, 3.888313167190439*^9}, 
