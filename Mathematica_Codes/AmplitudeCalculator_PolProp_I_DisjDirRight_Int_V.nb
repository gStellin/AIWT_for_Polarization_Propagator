Cell["\<\
The expressions of the amplitudes associated to each Feynman diagram are \
calculated in time representation.\
\>", "Text",
 CellChangeTimes->{{3.8982551888079557`*^9, 3.898255239729643*^9}, {
  3.8985851050466156`*^9, 3.898585106550789*^9}, {3.91214768640839*^9, 
