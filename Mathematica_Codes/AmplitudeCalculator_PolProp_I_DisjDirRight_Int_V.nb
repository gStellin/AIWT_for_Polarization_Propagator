            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "1"}], " ", "&&", 
              RowBox[{
               RowBox[{"GGFNambu", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "2"}]}], ",", " ", 
             RowBox[{
              RowBox[{"SPLIndex", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "=", 
              RowBox[{"OverBar", "[", "\"\<p\>\"", "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "2"}], " ", "&&", " ", 
              RowBox[{
               RowBox[{"GGFNambu", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], " ", 
