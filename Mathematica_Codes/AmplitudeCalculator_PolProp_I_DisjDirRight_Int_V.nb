       RowBox[{"s", "\[Equal]", 
        RowBox[{"-", "5"}]}], ",", " ", 
       RowBox[{"Return", "[", 
        RowBox[{"OverBar", "[", "\"\<a\>\"", "]"}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"s", "\[Equal]", "6"}], ",", " ", 
       RowBox[{"Return", "[", "\"\<b\>\"", "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"s", "\[Equal]", 
        RowBox[{"-", "6"}]}], ",", " ", 
       RowBox[{"Return", "[", 
        RowBox[{"OverBar", "[", "\"\<b\>\"", "]"}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"s", "\[Equal]", "7"}], ",", " ", 
