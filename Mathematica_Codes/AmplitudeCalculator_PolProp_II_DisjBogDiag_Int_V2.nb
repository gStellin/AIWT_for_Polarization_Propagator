                "\[HBar]"}]}]}]}]}], ",", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"GGFAmplitude", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i"}], "]"}], "]"}], " ", "=", 
             RowBox[{
              RowBox[{"StringForm", "[", 
               RowBox[{"\"\<``\>\"", ",", 
                RowBox[{"Superscript", "[", 
                 RowBox[{
                  RowBox[{"Superscript", "[", 
                   RowBox[{
                    RowBox[{"Subscript", "[", 
                    RowBox[{"\[Chi]", ",", 
                    RowBox[{"NtL", "[", 
                    RowBox[{"GGFSParticle", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], "]"}]}], 
                    "]"}], ",", 
                    RowBox[{"GGFNambu", "[", 
