     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "38"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SignFlip", " ", "=", " ", 
   RowBox[{"Table", "[", 
