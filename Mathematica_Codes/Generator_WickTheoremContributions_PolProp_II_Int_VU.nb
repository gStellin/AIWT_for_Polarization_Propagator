Cell[BoxData[{
 RowBox[{
  RowBox[{"AdcbaVertex", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "72"}], "}"}], ",", 
