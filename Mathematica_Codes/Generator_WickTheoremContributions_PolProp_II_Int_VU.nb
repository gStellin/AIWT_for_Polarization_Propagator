Cell[CellGroupData[{

Cell["Disjoint Diagrams", "Chapter",
 CellChangeTimes->{{3.8746447213615894`*^9, 3.874644731124649*^9}, {
   3.8746447691271086`*^9, 3.87464477328621*^9}, {3.8746449100185723`*^9, 
   3.87464492347766*^9}, {3.8886425624638295`*^9, 3.888642564518868*^9}, {
   3.8920170569792547`*^9, 3.8920170612152023`*^9}, 
   3.9119029150224075`*^9},ExpressionUUID->"473a3570-d147-4203-bf1a-\
098f59364694"],

Cell["\<\
The disjoint  diagrams at second order are 576 in total. These are \
distributed as follows:
i) 72 Bogoliubov diagrams dressed in the antidiagonal;
ii) 72 Bogoliubov diagrams dressed in the diagonal;
iii) 48 Bogoliubov diagrams dressed in both the diagonal and the antidiagonal;
iv) 72 Direct diagrams dressed in the left propagator;
v) 72 Direct diagrams dressed in the right propagator;
vi) 48 Direct diagrams dressed in both the left and the right propagator;
vii) 72 Exchange diagrams dressed in the propagator above;
viii) 72 Exchange diagrams dressed in the propagator below;
ix) 48 Exchange diagrams dressed in both the above and below propagator;\
\>", "Text",
 CellChangeTimes->{{3.8746447846491413`*^9, 3.874644822571206*^9}, {
   3.874644938314557*^9, 3.874644942272763*^9}, {3.8836802941172266`*^9, 
   3.8836803136658287`*^9}, {3.8836805023891754`*^9, 
