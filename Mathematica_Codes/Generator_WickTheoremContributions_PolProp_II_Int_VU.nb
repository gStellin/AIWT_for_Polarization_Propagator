Cell["\<\
Direct diagrams with dressed 1-body propagator above and below are processed. \
Their initial number is 48 in total.\
\>", "Text",
 CellChangeTimes->{{3.8836813753146152`*^9, 3.88368147043666*^9}, {
  3.8836820487185183`*^9, 3.88368205024879*^9}, {3.883682180609577*^9, 
