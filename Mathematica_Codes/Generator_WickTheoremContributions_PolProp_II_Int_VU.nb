34f4a943264a"],

Cell[CellGroupData[{

Cell["Filtration of the fully-contracted terms", "Subsection",
 CellChangeTimes->{{3.874644843789677*^9, 3.8746448545752873`*^9}, {
   3.883112065177337*^9, 3.883112118360941*^9}, {3.8831146011227875`*^9, 
   3.8831146201744213`*^9}, {3.883115184479356*^9, 3.8831151965813236`*^9}, {
   3.8884058729915524`*^9, 3.8884058731821747`*^9}, {3.892796304865531*^9, 
   3.8927963061083*^9}, {3.8970416648940463`*^9, 3.897041696332107*^9}, {
   3.8970430127224007`*^9, 3.8970430129919276`*^9}, {3.9118815456012297`*^9, 
   3.911881558423523*^9}, 3.911881964925539*^9, {3.9118823203354487`*^9, 
   3.9118823662610793`*^9}},ExpressionUUID->"17ce82f7-dce0-4727-ab10-\
663fd6befa4b"],

Cell[TextData[{
 "Filtration of the conjoint composite diagrams. At second order with a \
one-body interaction vertex plus a two-body one, transpositions between \
single-particle indices of different two-body vertices (external \
permutations) are not possible and the overall corresponding combinatorial \
factor is ",
 StyleBox["1!",
  FontSlant->"Italic"],
 ". On the other hand, transposition between single-particle index of the \
same two-body vertex are available. Fully-contracted terms which are mapped \
one another by the permutation ",
 StyleBox["p \[RightTeeArrow] q",
  FontSlant->"Italic"],
 "  and ",
 StyleBox["r \[RightTeeArrow] s",
  FontSlant->"Italic"],
 "  and ",
 StyleBox["p \[RightTeeArrow] q",
  FontSlant->"Italic"],
 ", ",
 StyleBox["r \[RightTeeArrow] s",
  FontSlant->"Italic"],
 " are identified and summed, eventually canceling out the ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"2", "!"}], ")"}], "2"],
    FontSlant->"Italic"], TraditionalForm]],ExpressionUUID->
  "d1735abe-b0bc-4f9e-8ee3-2107b48c8442"],
 " at the denominator, arising from the partial antisymmetry of the  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox[
     RowBox[{" ", "V"}], "_"], "pqrs"], TraditionalForm]],ExpressionUUID->
  "5dae3fc3-c06a-4236-8f15-a16b30a02c6f"],
 " interaction vertex. The cancellation is only partial when one-body \
propagators linking a vertex to itself are present."
}], "Text",
 CellChangeTimes->{{3.8836806708732624`*^9, 3.883680671103075*^9}, {
  3.8836807100445924`*^9, 3.8836809748029747`*^9}, {3.88368106035993*^9, 
  3.88368123630155*^9}, {3.8884066008391533`*^9, 3.8884066027299986`*^9}, {
  3.8895318871960154`*^9, 3.8895318884833517`*^9}, {3.9118815764375877`*^9, 
  3.911881584921088*^9}, {3.9118816319417095`*^9, 3.911881890471509*^9}, {
  3.9118819594531937`*^9, 3.9118819596905937`*^9}, {3.9118820061070004`*^9, 
  3.91188213908997*^9}, {3.911882255927207*^9, 3.9118823113000793`*^9}, {
  3.9123434592120924`*^9, 3.912343460657421*^9}, {3.912343525673345*^9, 
  3.9123435488477335`*^9}, {3.9124096609810886`*^9, 3.912409665294118*^9}, {
  3.9138863861266527`*^9, 
  3.9138863884530373`*^9}},ExpressionUUID->"3b99f959-eb86-4ca8-9ebf-\
8aff67e54700"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"AccVertex", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "192"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "5"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MultccVertex", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "192"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ifrepeat", "=", " ", "False"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Temp", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "4"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "5"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"IfTemp", " ", "=", 
    RowBox[{"Table", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "4"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "5"}], "}"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"s", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"AccVertex", "[", 
    RowBox[{"[", "1", "]"}], "]"}], " ", "=", " ", 
   RowBox[{"Aconjsort", "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"MultccVertex", "[", 
    RowBox[{"[", "1", "]"}], "]"}], " ", "=", " ", "1"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"u", "=", "1"}], ",", 
   RowBox[{"u", "\[LessEqual]", "192"}], ",", 
   RowBox[{"u", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "\[LessEqual]", "5"}], ",", 
      RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"j", "=", "1"}], ",", 
        RowBox[{"j", "\[LessEqual]", "2"}], ",", 
        RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Aconjsort", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "1"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "i", ",", "j"}], "]"}], "]"}], "=", "2"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Aconjsort", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "2"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "i", ",", "j"}], "]"}], "]"}], "=", "1"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Aconjsort", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], 
            "\[GreaterEqual]", " ", "3"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "i", ",", "j"}], "]"}], "]"}], "=", 
            RowBox[{"Aconjsort", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}]}]}], "]"}], ";",
          "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Aconjsort", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "1"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", "2"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Aconjsort", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "2"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", "1"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Aconjsort", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "3"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", "4"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Aconjsort", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "4"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", "3"}]}], 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Aconjsort", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], 
            "\[GreaterEqual]", " ", "5"}], ",", 
           RowBox[{
            RowBox[{"Temp", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "i", ",", "j"}], "]"}], "]"}], "=", 
            RowBox[{"Aconjsort", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}]}]}], "]"}], ";",
          "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Aconjsort", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
