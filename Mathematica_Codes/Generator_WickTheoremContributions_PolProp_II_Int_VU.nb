Cell[CellGroupData[{

Cell["\<\
Disjoint direct diagrams with dressed single-particle propagator on the left\
\>", "Section",
 CellChangeTimes->{{3.8747474873699455`*^9, 3.8747475586269774`*^9}, {
  3.8836821843140464`*^9, 3.883682185030684*^9}, {3.8886425005080795`*^9, 
  3.8886425041635475`*^9}},ExpressionUUID->"e8563593-8eaf-48b7-8df9-\
921c4bec4d5c"],

Cell["\<\
Direct diagrams with unperturbed 1-body propagator on the right are \
processed. Their initial number is 72 in total.\
\>", "Text",
 CellChangeTimes->{{3.8836813753146152`*^9, 3.88368147043666*^9}, {
   3.8836820487185183`*^9, 3.88368205024879*^9}, {3.883682180609577*^9, 
   3.883682181425793*^9}, {3.8895326177197933`*^9, 3.8895326190004883`*^9}, {
   3.8927832371377015`*^9, 3.892783237556256*^9}, {3.911906600155179*^9, 
   3.911906604269761*^9}, 
   3.9124086388681307`*^9},ExpressionUUID->"d13b747e-e7a4-43b9-bf9d-\
d8cf09800dda"],

Cell[BoxData[
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"u", "=", "1"}], ",", 
    RowBox[{"u", "\[LessEqual]", "72"}], ",", 
    RowBox[{"u", "++"}], ",", 
    RowBox[{"Print", "[", 
     RowBox[{"AdisjDirLeft", "[", 
      RowBox[{"[", "u", "]"}], "]"}], "]"}]}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.8747489659683185`*^9, 3.874748971262155*^9}, {
   3.874750278096981*^9, 3.874750278551973*^9}, {3.8747509325127506`*^9, 
   3.8747509328870687`*^9}, {3.8765741047757406`*^9, 3.8765741055275917`*^9}, 
   3.8831148837672863`*^9, {3.883127184776041*^9, 3.8831271902198343`*^9}, {
   3.888406464599372*^9, 3.8884064696245165`*^9}, {3.8884067207057405`*^9, 
   3.8884067212108355`*^9}, {3.888407229646407*^9, 3.888407229904756*^9}, {
   3.889530703366559*^9, 3.8895307097735305`*^9}, {3.88953201045216*^9, 
   3.8895320107683506`*^9}, 3.889532405351248*^9, {3.889533182253409*^9, 
   3.8895331826663556`*^9}, {3.892802705556965*^9, 3.892802712929164*^9}, {
   3.892802760028386*^9, 3.892802767974951*^9}, {3.892802813093663*^9, 
   3.8928028356507096`*^9}, {3.9118985092703266`*^9, 3.911898525243123*^9}, {
   3.9119016297238483`*^9, 3.9119016363951025`*^9}, {3.9119683357675347`*^9, 
   3.9119683458631215`*^9}, {3.9124086238423495`*^9, 
   3.9124086257127805`*^9}},ExpressionUUID->"2089c253-eb47-412d-b1bc-\
335b87bff910"],

Cell[CellGroupData[{

Cell["Filtration of the fully-contracted terms", "Subsection",
 CellChangeTimes->{{3.874644843789677*^9, 3.8746448545752873`*^9}, {
   3.883112065177337*^9, 3.883112118360941*^9}, {3.8831146011227875`*^9, 
   3.8831146201744213`*^9}, {3.883115184479356*^9, 3.8831151965813236`*^9}, {
   3.8884058729915524`*^9, 3.8884058731821747`*^9}, {3.892800153537215*^9, 
   3.8928001610648518`*^9}, {3.897041751372193*^9, 3.8970417738128204`*^9}, {
   3.8970432846114845`*^9, 3.897043286022911*^9}, 
   3.911883818478182*^9},ExpressionUUID->"a950704d-7e7c-4440-96bf-\
aefb83d67513"],

Cell[TextData[{
 "Filtration of the left-dressed disjoint direct diagrams. At second order \
with a one-body interaction vertex plus a two-body one, transpositions \
between single-particle indices of different two-body vertices (external \
permutations) are not possible and the overall corresponding combinatorial \
factor is ",
 StyleBox["1!",
  FontSlant->"Italic"],
 ". On the other hand, transposition between single-particle index of the \
same two-body vertex are available. Fully-contracted terms which are mapped \
one another by the permutation ",
 StyleBox["p \[RightTeeArrow] q",
  FontSlant->"Italic"],
 "  and ",
 StyleBox["r \[RightTeeArrow] s",
  FontSlant->"Italic"],
 "  and ",
 StyleBox["p \[RightTeeArrow] q",
  FontSlant->"Italic"],
 ", ",
 StyleBox["r \[RightTeeArrow] s",
  FontSlant->"Italic"],
 " are identified and summed, eventually canceling out the ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"2", "!"}], ")"}], "2"],
    FontSlant->"Italic"], TraditionalForm]],ExpressionUUID->
  "fc0e3fbe-b077-4af6-9be2-e09375c97832"],
 " at the denominator, arising from the partial antisymmetry of the  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox[
     RowBox[{" ", "V"}], "_"], "pqrs"], TraditionalForm]],ExpressionUUID->
  "e73c728d-ca9a-4945-b6f8-88e49205dfe7"],
 " interaction vertex. The cancellation is only partial when one-body \
propagators linking a vertex to itself are present."
}], "Text",
 CellChangeTimes->{{3.8836806708732624`*^9, 3.883680671103075*^9}, {
  3.8836807100445924`*^9, 3.8836809748029747`*^9}, {3.88368106035993*^9, 
  3.88368123630155*^9}, {3.8884066008391533`*^9, 3.8884066027299986`*^9}, {
  3.8895318871960154`*^9, 3.8895318884833517`*^9}, {3.9118815764375877`*^9, 
  3.911881584921088*^9}, {3.9118816319417095`*^9, 3.911881890471509*^9}, {
  3.9118819594531937`*^9, 3.9118819596905937`*^9}, {3.9118820061070004`*^9, 
  3.91188213908997*^9}, {3.911882255927207*^9, 3.9118823113000793`*^9}, {
  3.9123434592120924`*^9, 3.912343460657421*^9}, {3.912343525673345*^9, 
  3.9123435488477335`*^9}, {3.9124095998857183`*^9, 3.9124096073023186`*^9}, {
  3.912409646499759*^9, 3.912409651132216*^9}, {3.913886426095109*^9, 
  3.913886428070937*^9}},ExpressionUUID->"a19a7ee8-13ed-4a13-bee7-\
01b64e9694b0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"AdcdlVertex", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "72"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "5"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MultdcdlVertex", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "72"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ifrepeat", "=", " ", "False"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Temp", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "4"}], "}"}], ",", 
     RowBox[{"{", 
