   3.911883818478182*^9},ExpressionUUID->"f7cc9efc-87af-493e-b892-\
abfe97c6245c"],

Cell[TextData[{
 "Filtration of the antidiagonally-and-diagonally-dressed disjoint Bogoliubov \
diagrams. At second order with a one-body interaction vertex plus a two-body \
one, transpositions between single-particle indices of different two-body \
vertices (external permutations) are not possible and the overall \
corresponding combinatorial factor is ",
 StyleBox["1!",
  FontSlant->"Italic"],
 ". On the other hand, transposition between single-particle index of the \
same two-body vertex are available. Fully-contracted terms which are mapped \
one another by the permutation ",
 StyleBox["p \[RightTeeArrow] q",
  FontSlant->"Italic"],
 "  and ",
 StyleBox["r \[RightTeeArrow] s",
  FontSlant->"Italic"],
 "  and ",
 StyleBox["p \[RightTeeArrow] q",
  FontSlant->"Italic"],
 ", ",
 StyleBox["r \[RightTeeArrow] s",
  FontSlant->"Italic"],
 " are identified and summed, eventually canceling out the ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"2", "!"}], ")"}], "2"],
    FontSlant->"Italic"], TraditionalForm]],ExpressionUUID->
  "720adf54-b4c1-4b50-91aa-55ffd4f76585"],
 " at the denominator, arising from the partial antisymmetry of the  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox[
     RowBox[{" ", "V"}], "_"], "pqrs"], TraditionalForm]],ExpressionUUID->
  "6c9d1f2f-d9e8-47a6-b2a9-2d00962bdf22"],
 " interaction vertex. The cancellation is only partial when one-body \
propagators linking a vertex to itself are present."
}], "Text",
 CellChangeTimes->CompressedData["
1:eJxTTMoPSmViYGAQBmIQfeTj7eKO928cU3weg2nf3IMVIPrHxpszQXRPS/cS
EO2zrHMXiI64JcXZ8+ONo1pMOJg+5PqsduOvN47zyvnrQPQOBr7cINW3jn2V
snkgukbpXzGIniXmPwVET2h4NwdER0h+A9M9OYcXgWjOh0mbQfS61X8PgmiH
WS9PgOiyk2lfjNXeOs7gnAqmuXu2/gHRixRm/wfR58L/2IeA5Ne8dADR7P/O
u4JoWesUNxBd9upsO4hWiXgGpnUdhdeDaBluPzDtFfakORrEnzi9FURb5Kyd
HgOk/15aMAtEr92Xnayq+dZx6etzYBoAaOKZ+g==
  "],ExpressionUUID->"0d7a02de-1635-4b82-85cb-1f6ef7fa133c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"AdcbVertex", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "48"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "5"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MultdcbVertex", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "48"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ifrepeat", "=", " ", "False"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Temp", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "4"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "5"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"IfTemp", " ", "=", 
    RowBox[{"Table", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "4"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "5"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"s", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"AdcbVertex", "[", 
    RowBox[{"[", "1", "]"}], "]"}], " ", "=", " ", 
   RowBox[{"AdisjBogoliubov", "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"MultdcbVertex", "[", 
    RowBox[{"[", "1", "]"}], "]"}], " ", "=", " ", "1"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"u", "=", "1"}], ",", 
   RowBox[{"u", "\[LessEqual]", "48"}], ",", 
   RowBox[{"u", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "\[LessEqual]", "5"}], ",", 
      RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"j", "=", "1"}], ",", 
        RowBox[{"j", "\[LessEqual]", "2"}], ",", 
        RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"If", "[", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"AdisjBogoliubov", "[", 
             RowBox[{"[", 
              RowBox[{"u", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
            "1"}], ",", 
           RowBox[{
