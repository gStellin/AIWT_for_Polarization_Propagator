  3.9191643410208225`*^9},ExpressionUUID->"4a8a0e49-c74d-4a0e-b25c-\
269fb5c4c400"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["\[CapitalPi]", "acdb"], 
    RowBox[{
     SubscriptBox["g", "1"], 
     SubscriptBox["g", "3"], 
