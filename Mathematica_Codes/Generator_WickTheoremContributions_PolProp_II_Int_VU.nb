Cell["There are only 192 second-order conjoint contributions.", "Text",
 CellChangeTimes->{{3.9118825127573195`*^9, 3.9118825231292744`*^9}, {
  3.9123436651904993`*^9, 3.912343670398157*^9}, {3.912429521828949*^9, 
  3.91242952197289*^9}, {3.912430388958939*^9, 
  3.9124303899521494`*^9}},ExpressionUUID->"06ad508a-5dca-406e-91a8-\
9509485b97a4"],

Cell[BoxData[
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"u", "=", "1"}], ",", 
   RowBox[{"u", "\[LessEqual]", " ", "192"}], ",", 
   RowBox[{"u", "++"}], ",", 
   RowBox[{"Print", "[", 
    RowBox[{"Aconjsort", "[", 
     RowBox[{"[", "u", "]"}], "]"}], "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.8740534673734355`*^9, 3.874053486721454*^9}, {
  3.8740535363188667`*^9, 3.874053552077848*^9}, {3.874556804727316*^9, 
