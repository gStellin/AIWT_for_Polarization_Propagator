     RowBox[{"{", 
      RowBox[{"9", ",", "10"}], "}"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"g", "=", "1"}], ",", 
    RowBox[{"g", "\[LessEqual]", "9"}], ",", 
    RowBox[{"g", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"growind", " ", "=", " ", "1"}], ";", "\[IndentingNewLine]", 
     RowBox[{"gcolind", " ", "=", " ", "2"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"h", "=", "1"}], ",", 
       RowBox[{"h", "\[LessEqual]", "7"}], ",", 
       RowBox[{"h", "++"}], ",", "\[IndentingNewLine]", 
