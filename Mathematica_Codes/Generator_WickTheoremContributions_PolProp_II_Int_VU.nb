   3.892038712383728*^9, 3.892039062309143*^9}, {3.8920419598380885`*^9, 
   3.8920420631656446`*^9}, {3.892720004927622*^9, 3.8927200377390924`*^9}, {
   3.8927335205347958`*^9, 3.8927335466775837`*^9}, {3.8927859490870333`*^9, 
   3.8927859510251875`*^9}, {3.892798870514522*^9, 3.89279887279115*^9}, {
