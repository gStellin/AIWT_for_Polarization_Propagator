               RowBox[{"[", 
                RowBox[{"NppIdx", ",", "1"}], "]"}], "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"CombDirRight", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "\[Equal]", 
