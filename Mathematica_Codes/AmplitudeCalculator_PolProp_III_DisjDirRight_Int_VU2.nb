       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"j", "=", 
          RowBox[{"i", "+", "1"}]}], ",", 
         RowBox[{"j", "\[LessEqual]", " ", "12"}], ",", 
         RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
