Cell[CellGroupData[{

Cell["Labels of Gorkov-Green\[CloseCurlyQuote]s functions", "Subsection",
 CellChangeTimes->{{3.888315173503672*^9, 3.888315249112604*^9}, {
  3.888315302609094*^9, 3.8883153149727306`*^9}, {3.888315562099093*^9, 
  3.888315691229587*^9}, {3.907955613278085*^9, 
  3.907955659557123*^9}},ExpressionUUID->"dbb227e6-9e48-4c8b-9883-\
f80afe756016"],

Cell["\<\
A multiplication factor of 1/2 should correspond to each pair of equivalent \
propagators, i.e. starting at the same interaction vertex and ending at the \
same vertex. Additionally, a factor of 1/2 appears whenever an anomalous \
propagator is contracted to the same interaction vertex (anomalous loop). In \
these diagrams, no equivalent lines are present in the graphs. Also, \
anomalous loops do not occur. Comparison with the input values in the array \
\[OpenCurlyQuote]GGFMult\[CloseCurlyQuote] is done, for the purpose of \
checking the initial data.\
\>", "Text",
 CellChangeTimes->{{3.888317144112847*^9, 3.888317221803842*^9}, {
   3.888317253679213*^9, 3.888317283413673*^9}, {3.8884104851279387`*^9, 
   3.888410531357524*^9}, {3.888410568841679*^9, 3.888410569651976*^9}, {
   3.8884106618952093`*^9, 3.888410684198667*^9}, {3.8884117553874006`*^9, 
   3.888411778188436*^9}, {3.889588714939645*^9, 3.889588725167736*^9}, {
   3.9079188968094006`*^9, 3.907918957686596*^9}, 3.9144786979613533`*^9, {
   3.914492477078985*^9, 
   3.914492479119063*^9}},ExpressionUUID->"aa3cda99-0b6c-4c22-aacf-\
8186597e0d2c"],

