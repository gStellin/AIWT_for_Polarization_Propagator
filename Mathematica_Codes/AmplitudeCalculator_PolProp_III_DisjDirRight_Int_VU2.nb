98b7f091fbc0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", "NcMax"}], ",", 
    RowBox[{"r", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "0"}], ",", 
      RowBox[{"i", "\[LessEqual]", " ", "5"}], ",", " ", 
      RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"SPSequence", "[", 
         RowBox[{"[", 
          RowBox[{"r", ",", 
           RowBox[{
            RowBox[{"2", "i"}], "+", "1"}]}], "]"}], "]"}], " ", "=", " ", 
        RowBox[{"Abs", "[", 
