              "\[LessEqual]", " ", "4"}], ",", 
             RowBox[{
              RowBox[{"NambuDirLeft", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "=", "1"}]}],
             "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"CombDirLeft", "[", 
               RowBox[{"[", 
