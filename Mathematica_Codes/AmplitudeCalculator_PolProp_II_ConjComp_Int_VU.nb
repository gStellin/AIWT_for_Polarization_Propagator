Cell[CellGroupData[{

Cell["Selection of the Nambu component of the one-body potential", "Section",
 CellChangeTimes->{{3.9120816659877415`*^9, 
  3.9120817133455973`*^9}},ExpressionUUID->"296c2904-fac3-48fa-9d3d-\
50c6a15c4da6"],

Cell[TextData[{
 "The analytical results presented henceforth refer to an element of the \
product between ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["V", "_"], "(", 
    SubscriptBox["t", "1"]}], TraditionalForm]],ExpressionUUID->
  "9b933f97-b92c-4ae9-bb11-43b8ad39d290"],
 "), ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "2"]}], TraditionalForm]],ExpressionUUID->
  "8ef0fd6c-4b60-41aa-a0d9-d62d45c93b5c"],
 ") and the second-quantization operators with external single-particle \
indices. The elements of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "2"]}], TraditionalForm]],ExpressionUUID->
  "793dd614-b4d1-4b9c-95a2-19368aa96eae"],
 ") are specified by the two indices that determine the Nambu component, ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], 
    RowBox[{
     SubscriptBox["g", "5"], 
     SubscriptBox["g", "6"]}]], TraditionalForm]],ExpressionUUID->
  "9e5f7a1a-bd7f-4daf-8fed-7f14b5b01995"],
 " , of the auxiliary one-body potential ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "2"]}], TraditionalForm]],ExpressionUUID->
  "aeb0e32f-f93f-4f43-8eff-cff15a1740ab"],
 "), ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "5"], TraditionalForm]],ExpressionUUID->
  "5e4bdc75-e205-4e9f-9722-cb361bbd2312"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "6"], TraditionalForm]],ExpressionUUID->
  "c42d53a2-4e2a-42d6-a1b8-cf2953653b45"],
 ", stored in the array \[OpenCurlyQuote]UNambu\[CloseCurlyQuote]. As a \
result,  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "5"], TraditionalForm]],ExpressionUUID->
  "81823090-53e3-4f35-8297-061843a0af23"],
 "=1 and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["g", "6"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "5cb6e1f3-f77a-4358-86da-f03406650ffd"],
 " denote the component ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "11"], TraditionalForm]],ExpressionUUID->
  "52979833-5619-45c9-8e67-7e8087572dcc"],
 " and is encoded by \[OpenCurlyQuote]UNambu[[1]]\[CloseCurlyQuote] . \
Analogously,  ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "22"], TraditionalForm]],ExpressionUUID->
  "1b497893-43a1-4b2e-9e1c-048ce46daa33"],
 " is mapped to \[OpenCurlyQuote]UNambu[[4]]\[CloseCurlyQuote], ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "21"], TraditionalForm]],ExpressionUUID->
  "39dcf40d-4317-4a95-ad5b-05e8b19cc0cb"],
 " to \[OpenCurlyQuote]UNambu[[3]]\[CloseCurlyQuote] and ",
 Cell[BoxData[
