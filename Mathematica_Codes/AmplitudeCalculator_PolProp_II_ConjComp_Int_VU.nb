Cell[TextData[{
 "Single-particle indices ",
 StyleBox["b",
  FontSlant->"Italic"],
 " and ",
 StyleBox["d",
  FontSlant->"Italic"],
 " in Bogoliubov fully-contracted terms are involute. For their numeric \
counterpart, the following convention is adopted: \nIndex > 0 \
\[DoubleRightArrow] ",
 StyleBox["standard",
  FontSlant->"Italic"],
 "\nIndex < 0 \[DoubleRightArrow] ",
 StyleBox["involute",
  FontSlant->"Italic"],
 "."
}], "Text",
