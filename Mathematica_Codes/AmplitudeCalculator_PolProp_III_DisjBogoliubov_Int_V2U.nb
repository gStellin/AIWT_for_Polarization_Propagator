     RowBox[{"{", 
      RowBox[{"2", ",", "1", ",", "2", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "1", ",", "1", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
