                RowBox[{"T", ",", "4"}], "]"}], "]"}]], "-", 
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdPlus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
          RowBox[{"\[Gamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "4"], "-", 
