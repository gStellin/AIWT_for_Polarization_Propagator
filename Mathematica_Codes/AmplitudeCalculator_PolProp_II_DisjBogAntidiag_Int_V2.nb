Cell[CellGroupData[{

Cell["\<\
Calculation of the amplitude associated to the \
Gorkov-Green\[CloseCurlyQuote]s functions with alphabetic indices\
\>", "Subsection",
 CellChangeTimes->{{3.888315861110175*^9, 3.8883159051561947`*^9}, {
  3.8883159887111607`*^9, 3.888316043821027*^9}, {3.9080016383725634`*^9, 
  3.908001643028146*^9}},ExpressionUUID->"ed68eae8-835e-4e7f-b15a-\
5a2e6e7c9d66"],

Cell["\<\
Initialization of the Gorkov-Green\[CloseCurlyQuote]s functions based on the \
chosen time ordering. The polynomial, appearing as argument of a natural \
exponential, is also calculated, neglecting the imaginary unit \[ImaginaryI] \
(factor).\
\>", "Text",
 CellChangeTimes->{{3.8883163242658205`*^9, 3.8883163554476023`*^9}, {
  3.8883164071679173`*^9, 
  3.8883165187772655`*^9}},ExpressionUUID->"c70730ca-137b-4daf-be16-\
be112d586ca7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "k", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"GGFAmplitude", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "38"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "6"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"GGFPolynomial", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0.0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "38"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "6"}], "}"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.8878878608574233`*^9, 3.8878880940257835`*^9}, 
   3.887890072328867*^9, {3.8878914603928394`*^9, 3.8878914700344296`*^9}, {
   3.8884119686701937`*^9, 3.88841197242874*^9}, {3.8895893978728447`*^9, 
   3.889589403387763*^9}, {3.908264222635662*^9, 3.908264226907137*^9}, {
   3.909206178706339*^9, 3.909206183009929*^9}, {3.9092186895870147`*^9, 
   3.9092186927624874`*^9}, {3.9092226530680475`*^9, 
   3.9092226556607637`*^9}, {3.909227939636098*^9, 3.909227942753165*^9}},
 CellLabel->
  "In[283]:=",ExpressionUUID->"f0488fe4-aaba-43a0-9bf5-9d3a732b81a4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", " ", "38"}], ",", " ", 
    RowBox[{"r", "++"}], ",", " ", "\[IndentingNewLine]", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "\[LessEqual]", " ", "6"}], ",", 
      RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"GGFTime", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], " ", ">", " ", 
          RowBox[{"GGFTime", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]}], ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"GGFAmplitude", "[", 
            RowBox[{"[", 
             RowBox[{"r", ",", "i"}], "]"}], "]"}], " ", "=", 
           RowBox[{
            RowBox[{"StringForm", "[", 
             RowBox[{"\"\<``\>\"", ",", 
              RowBox[{"Superscript", "[", 
               RowBox[{
                RowBox[{"Superscript", "[", 
                 RowBox[{
                  RowBox[{"Subscript", "[", 
                   RowBox[{"\[Chi]", ",", 
                    RowBox[{"NtL", "[", 
                    RowBox[{"GGFSParticle", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], "]"}]}], 
                   "]"}], ",", 
                  RowBox[{"GGFNambu", "[", 
                   RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}]}], "]"}], 
                ",", 
                SubscriptBox["k", "i"]}], "]"}]}], "]"}], 
            RowBox[{"StringForm", "[", 
             RowBox[{"\"\<``\>\"", ",", 
              RowBox[{"Superscript", "[", 
               RowBox[{
                RowBox[{"Superscript", "[", 
                 RowBox[{
                  RowBox[{"Subscript", "[", 
                   RowBox[{
                    RowBox[{"OverBar", "[", "\[Chi]", "]"}], ",", 
                    RowBox[{"NtL", "[", 
                    RowBox[{"GGFSParticle", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}], "]"}]}], 
                   "]"}], ",", 
                  RowBox[{"GGFNambu", "[", 
                   RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]}], "]"}], 
                ",", 
                SubscriptBox["k", "i"]}], "]"}]}], "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"GGFPolynomial", "[", 
            RowBox[{"[", 
             RowBox[{"r", ",", "i"}], "]"}], "]"}], " ", "=", 
           RowBox[{
            RowBox[{
             RowBox[{"-", 
              RowBox[{"(", " ", 
               RowBox[{
                SubscriptBox["\[CapitalOmega]", 
                 SubscriptBox["k", "i"]], "-", 
                SubscriptBox["\[CapitalOmega]", "0"]}], ")"}]}], 
             RowBox[{
              SubscriptBox["t", 
               RowBox[{"GGFTime", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}]], "/", 
              "\[HBar]"}]}], "+", 
            RowBox[{
             RowBox[{"(", " ", 
              RowBox[{
               SubscriptBox["\[CapitalOmega]", 
                SubscriptBox["k", "i"]], "-", 
               SubscriptBox["\[CapitalOmega]", "0"]}], ")"}], 
             RowBox[{
              SubscriptBox["t", 
               RowBox[{"GGFTime", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]], "/", 
              "\[HBar]"}]}]}]}], ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"GGFTime", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], " ", "<", " ", 
          RowBox[{"GGFTime", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]}], ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"GGFAmplitude", "[", 
            RowBox[{"[", 
             RowBox[{"r", ",", "i"}], "]"}], "]"}], " ", "=", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"StringForm", "[", 
              RowBox[{"\"\<``\>\"", ",", 
               RowBox[{"Superscript", "[", 
                RowBox[{
                 RowBox[{"Superscript", "[", 
                  RowBox[{
                   RowBox[{"Subscript", "[", 
                    RowBox[{"\[CapitalUpsilon]", ",", 
                    RowBox[{"NtL", "[", 
                    RowBox[{"GGFSParticle", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], "]"}]}], 
                    "]"}], ",", 
                   RowBox[{"GGFNambu", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}]}], "]"}], 
                 ",", 
                 SubscriptBox["k", "i"]}], "]"}]}], "]"}]}], 
            RowBox[{"StringForm", "[", 
             RowBox[{"\"\<``\>\"", ",", 
              RowBox[{"Superscript", "[", 
               RowBox[{
                RowBox[{"Superscript", "[", 
                 RowBox[{
                  RowBox[{"Subscript", "[", 
                   RowBox[{
                    RowBox[{"OverBar", "[", "\[CapitalUpsilon]", "]"}], ",", 
                    RowBox[{"NtL", "[", 
                    RowBox[{"GGFSParticle", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}], "]"}]}], 
                   "]"}], ",", 
                  RowBox[{"GGFNambu", "[", 
                   RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]}], "]"}], 
                ",", 
                SubscriptBox["k", "i"]}], "]"}]}], "]"}]}]}], ";", 
          "\[IndentingNewLine]", " ", 
          RowBox[{
           RowBox[{"GGFPolynomial", "[", 
            RowBox[{"[", 
             RowBox[{"r", ",", "i"}], "]"}], "]"}], " ", "=", 
           RowBox[{
            RowBox[{
             RowBox[{"+", 
              RowBox[{"(", " ", 
               RowBox[{
                SubscriptBox["\[CapitalOmega]", 
                 SubscriptBox["k", "i"]], "-", 
                SubscriptBox["\[CapitalOmega]", "0"]}], ")"}]}], 
             RowBox[{
              SubscriptBox["t", 
               RowBox[{"GGFTime", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}]], "/", 
              "\[HBar]"}]}], "-", 
            RowBox[{
             RowBox[{"(", " ", 
              RowBox[{
               SubscriptBox["\[CapitalOmega]", 
                SubscriptBox["k", "i"]], "-", 
               SubscriptBox["\[CapitalOmega]", "0"]}], ")"}], 
             RowBox[{
              SubscriptBox["t", 
               RowBox[{"GGFTime", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]], "/", 
              "\[HBar]"}]}]}]}], ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"GGFTime", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], " ", "==", " ", 
          RowBox[{"GGFTime", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]}], ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"GGFNambu", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], " ", 
             "\[Equal]", "2"}], "  ", "&&", "  ", 
            RowBox[{
             RowBox[{"GGFNambu", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}], "\[Equal]", 
             "2"}]}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"GGFAmplitude", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i"}], "]"}], "]"}], " ", "=", 
             RowBox[{
              RowBox[{"-", 
               RowBox[{"StringForm", "[", 
                RowBox[{"\"\<``\>\"", ",", 
                 RowBox[{"Superscript", "[", 
                  RowBox[{
                   RowBox[{"Superscript", "[", 
                    RowBox[{
                    RowBox[{"Subscript", "[", 
                    RowBox[{"\[CapitalUpsilon]", ",", 
                    RowBox[{"NtL", "[", 
                    RowBox[{"GGFSParticle", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], "]"}]}], 
                    "]"}], ",", 
                    RowBox[{"GGFNambu", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}]}], "]"}], 
                   ",", 
                   SubscriptBox["k", "i"]}], "]"}]}], "]"}]}], 
              RowBox[{"StringForm", "[", 
               RowBox[{"\"\<``\>\"", ",", 
                RowBox[{"Superscript", "[", 
                 RowBox[{
                  RowBox[{"Superscript", "[", 
                   RowBox[{
                    RowBox[{"Subscript", "[", 
                    RowBox[{
                    RowBox[{"OverBar", "[", "\[CapitalUpsilon]", "]"}], ",", 
                    RowBox[{"NtL", "[", 
                    RowBox[{"GGFSParticle", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}], "]"}]}], 
                    "]"}], ",", 
                    RowBox[{"GGFNambu", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]}], "]"}], 
                  ",", 
                  SubscriptBox["k", "i"]}], "]"}]}], "]"}]}]}], " ", ";", 
            "\[IndentingNewLine]", " ", 
            RowBox[{
             RowBox[{"GGFPolynomial", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i"}], "]"}], "]"}], " ", "=", 
