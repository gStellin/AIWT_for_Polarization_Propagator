                 SubscriptBox["\[CapitalOmega]", 
                  SubscriptBox["k", "i"]], "-", 
                 SubscriptBox["\[CapitalOmega]", "0"]}], ")"}], 
               RowBox[{
                SubscriptBox["t", 
                 RowBox[{"GGFTime", "[", 
                  RowBox[{"[", 
