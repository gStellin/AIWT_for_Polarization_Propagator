                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}]}], "]"}], 
                  ",", 
                  SubscriptBox["k", "i"]}], "]"}]}], "]"}], 
              RowBox[{"StringForm", "[", 
               RowBox[{"\"\<``\>\"", ",", 
                RowBox[{"Superscript", "[", 
                 RowBox[{
                  RowBox[{"Superscript", "[", 
                   RowBox[{
                    RowBox[{"Subscript", "[", 
                    RowBox[{
                    RowBox[{"OverBar", "[", "\[Chi]", "]"}], ",", 
                    RowBox[{"NtL", "[", 
                    RowBox[{"GGFSParticle", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}], "]"}]}], 
                    "]"}], ",", 
                    RowBox[{"GGFNambu", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]}], "]"}], 
                  ",", 
                  SubscriptBox["k", "i"]}], "]"}]}], "]"}]}]}], " ", ";", 
            "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"GGFPolynomial", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i"}], "]"}], "]"}], " ", "=", 
             RowBox[{
