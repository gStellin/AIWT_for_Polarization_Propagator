  3.9079185042453585`*^9}},ExpressionUUID->"474ef4b6-15db-48fb-aa40-\
e4d47466cd72"],

Cell["\<\
Arrays specifying the Nambu indices (cf. NambuSkel), the operator type (cf. \
SQTypeSkel) and distinguishing internal from external single-particle indices \
(cf. IntExtSkel) are defined, in accordance with the conventions for the \
second-quantization operators in the header of the notebook. In particular, \
to external (internal) single-particle indices the value of \
\[OpenCurlyQuote]1\[CloseCurlyQuote] (\[OpenCurlyQuote]0\[CloseCurlyQuote]) \
is assigned, whereas for second-quantization operators of creation \
(annihilation) type the associated array entry is \[OpenCurlyQuote]0\
\[CloseCurlyQuote] (\[OpenCurlyQuote]1\[CloseCurlyQuote]). For Nambu indices, \
the convention is straightforward.\
\>", "Text",
 CellChangeTimes->{
  3.9077382215659647`*^9, {3.9077382923703613`*^9, 3.9077384065565405`*^9}, {
   3.9077384522680173`*^9, 3.9077384848449383`*^9}, {3.9077430709590244`*^9, 
   3.907743126073769*^9}, {3.9077450424291105`*^9, 3.9077450765315623`*^9}, {
   3.907918517166184*^9, 3.9079188444385033`*^9}, 3.9091515935484114`*^9, {
   3.9092041717880774`*^9, 3.9092041805155473`*^9}, {3.909825793352968*^9, 
   3.909825806952718*^9}},ExpressionUUID->"00cd9032-66c2-488d-9319-\
494ff6bfd779"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"NambuSkel", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "924"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "8"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", " ", "924"}], ",", 
    RowBox[{"r", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"j", "=", "1"}], ",", 
       RowBox[{"j", "\[LessEqual]", " ", "8"}], ",", 
       RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"k", "=", "1"}], ",", 
          RowBox[{"k", "\[LessEqual]", "2"}], ",", 
          RowBox[{"k", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"CombSkel", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], 
              "\[LessEqual]", " ", "12"}], ",", 
             RowBox[{
              RowBox[{"NambuSkel", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "=", "1"}]}],
             "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"CombSkel", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "\[Equal]", 
              "13"}], ",", 
             RowBox[{
              RowBox[{"NambuSkel", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "=", 
              RowBox[{"GPPNambu", "[", 
               RowBox[{"[", 
                RowBox[{"NppIdx", ",", "1"}], "]"}], "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"CombSkel", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "\[Equal]", 
              "14"}], ",", 
             RowBox[{
              RowBox[{"NambuSkel", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "=", 
              RowBox[{"GPPNambu", "[", 
               RowBox[{"[", 
                RowBox[{"NppIdx", ",", "4"}], "]"}], "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"CombSkel", "[", 
