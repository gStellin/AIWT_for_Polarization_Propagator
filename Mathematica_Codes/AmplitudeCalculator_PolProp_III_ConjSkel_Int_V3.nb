   3.888383424985591*^9}, 3.8883863841619015`*^9, {3.888394854217784*^9, 
   3.8883948546868258`*^9}, 3.888399889643489*^9, 3.8884001206989126`*^9, 
   3.888400250710778*^9, {3.8884004564625115`*^9, 3.8884004567839556`*^9}, 
   3.8884006048699055`*^9, {3.8884007067661734`*^9, 3.888400717585126*^9}, 
   3.888400878965273*^9, 3.888401074647033*^9, 3.8884011779473057`*^9, 
   3.8884013069217825`*^9, 3.8884013954501605`*^9, {3.888481723984605*^9, 
