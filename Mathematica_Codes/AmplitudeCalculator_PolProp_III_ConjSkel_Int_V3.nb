              RowBox[{"GPPNambu", "[", 
               RowBox[{"[", 
                RowBox[{"NppIdx", ",", "3"}], "]"}], "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"CombSkel", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "\[Equal]", 
              "16"}], ",", 
             RowBox[{
              RowBox[{"NambuSkel", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "=", 
              RowBox[{"GPPNambu", "[", 
               RowBox[{"[", 
                RowBox[{"NppIdx", ",", "2"}], "]"}], "]"}]}]}], "]"}], 
           ";"}]}], "\[IndentingNewLine]", "]"}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], 
