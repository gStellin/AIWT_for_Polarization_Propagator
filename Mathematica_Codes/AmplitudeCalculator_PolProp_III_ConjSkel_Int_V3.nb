Cell[CellGroupData[{

Cell["\<\
Calculation of the amplitude associated to Goldstone diagrams with alphabetic \
indices\
\>", "Subsection",
 CellChangeTimes->{{3.888315861110175*^9, 3.8883159051561947`*^9}, {
  3.8883159887111607`*^9, 3.888316043821027*^9}, {3.888316084808132*^9, 
  3.888316094409692*^9}, {3.9080017355726566`*^9, 3.9080017402516623`*^9}, {
  3.9082509561005807`*^9, 
  3.9082509656258793`*^9}},ExpressionUUID->"5b9be295-f6cd-42af-a4fa-\
941ccfe0e6a9"],

Cell[TextData[{
 "The four time integrals are evaluated in two steps. First, one computes the \
integral over ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "1"], TraditionalForm]],ExpressionUUID->
  "4da2f389-7f47-430f-afbf-4e3c181a6faa"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "2"], TraditionalForm]],ExpressionUUID->
  "d68fdfa1-c72d-4538-9ec1-80b8e380f4c1"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "3"], TraditionalForm]],ExpressionUUID->
  "f6640cf2-56d4-4aad-8f92-72323092c5ef"],
 "  (dummy times), by solving a linear system with a parameter (the fourth \
frequency). At third order, the frequency variables which are evaluated after \
integration by ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "1"], TraditionalForm]],ExpressionUUID->
  "8174887a-1e8e-45f8-bca5-57f9478edc43"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "2"], TraditionalForm]],ExpressionUUID->
  "ed52d449-b602-43f2-b64f-5445436339b5"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "3"], TraditionalForm]],ExpressionUUID->
  "86b4ee89-cd7d-4151-ba18-97c06a045734"],
 "  are labeled as \[Gamma], \[Epsilon] and \[Iota]. Consequently, the time \
differences multiplying \[Gamma], \[Epsilon] and \[Iota] must contain the \
times ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["t", 
     RowBox[{"1", " "}]], ","}], TraditionalForm]],ExpressionUUID->
  "b03b1f78-c53d-4405-8414-cbcac82f2978"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "2"], TraditionalForm]],ExpressionUUID->
  "d6002ad3-681f-4054-8257-4f7a3c6085ac"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "3"], TraditionalForm]],ExpressionUUID->
  "a41ae70e-59f7-4e73-b249-bc7b30e2db75"],
 ", otherwise integration fails. Next, the integration over (t-t\
\[CloseCurlyQuote]) is performed, solving a single linear equation, obtained \
by equating the coefficient of (t-t\[CloseCurlyQuote]) in the total \
polynomial to zero. Note that the time interval that multiplies \[Digamma]  \
must contain either t or t\[CloseCurlyQuote]. However, t and t\
\[CloseCurlyQuote] shall not appear together in that time interval, otherwise \
the time ordering of the corresponding Goldstone diagram becomes undefined \
(or ambiguously defined). Consequently, in the denominators of the energy \
representation, multiple \[OpenCurlyQuote]omegas\[CloseCurlyQuote] may \
appear, depending on the topology of the unoriented Goldstone diagram. \
Besides, the time interval multiplying \[Digamma]  shall never coincide with \
the time interval multiplying \[Gamma] ,\[Iota] and \[Epsilon], otherwise the \
implemented time sequence is ill-defined."
}], "Text",
 CellChangeTimes->{{3.88831632426582*^9, 3.888316355447603*^9}, {
   3.888316407167918*^9, 3.8883165187772655`*^9}, {3.888316549145891*^9, 
   3.888316725014002*^9}, {3.8921261744276867`*^9, 3.892126176144218*^9}, {
   3.8980862869710255`*^9, 3.898086320953068*^9}, {3.8982421237906322`*^9, 
   3.8982421340044594`*^9}, {3.940396293830358*^9, 3.9403964913762336`*^9}, 
   3.9459253271265163`*^9},ExpressionUUID->"e0504d6c-86c6-402a-83de-\
4e71a88b11bd"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"GGFTotalPolynomial", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "1", ",", "924"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", " ", "924"}], ",", " ", 
    RowBox[{"r", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"j", "=", "1"}], ",", 
       RowBox[{"j", "\[LessEqual]", "8"}], ",", 
       RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", 
         RowBox[{
          RowBox[{"GGFTotalPolynomial", "[", 
           RowBox[{"[", "r", "]"}], "]"}], "+", 
          RowBox[{"GGFPolynomial", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", "j"}], "]"}], "]"}]}]}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"T", "\[Equal]", "1"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
         RowBox[{
          RowBox[{"GGFTotalPolynomial", "[", 
           RowBox[{"[", "r", "]"}], "]"}], " ", "+", " ", 
          RowBox[{"\[Omega]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdPlus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "5"}], "]"}], "]"}]], "-", 
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdPlus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
          RowBox[{"\[Iota]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "4"], "-", 
             SubscriptBox["t", "3"]}], ")"}]}], "-", 
          RowBox[{"\[Gamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "3"], "-", 
             SubscriptBox["t", "2"]}], ")"}]}], "-", 
          RowBox[{"\[Epsilon]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "2"], "-", 
             SubscriptBox["t", "1"]}], ")"}]}], "-", 
          RowBox[{"\[Digamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "5"], "-", 
             SubscriptBox["t", "4"]}], ")"}]}]}]}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"T", "\[Equal]", "2"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
         RowBox[{
          RowBox[{"GGFTotalPolynomial", "[", 
           RowBox[{"[", "r", "]"}], "]"}], " ", "+", " ", 
          RowBox[{"\[Omega]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdPlus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "5"}], "]"}], "]"}]], "-", 
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdPlus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
          RowBox[{"\[Iota]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "5"], "-", 
             SubscriptBox["t", "4"]}], ")"}]}], "-", 
          RowBox[{"\[Gamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "4"], "-", 
             SubscriptBox["t", "3"]}], ")"}]}], "-", 
          RowBox[{"\[Epsilon]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "3"], "-", 
             SubscriptBox["t", "2"]}], ")"}]}], "-", 
          RowBox[{"\[Digamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "2"], "-", 
             SubscriptBox["t", "1"]}], ")"}]}]}]}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"T", "\[Equal]", "3"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
         RowBox[{
          RowBox[{"GGFTotalPolynomial", "[", 
           RowBox[{"[", "r", "]"}], "]"}], " ", "+", " ", 
          RowBox[{"\[Omega]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdPlus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "5"}], "]"}], "]"}]], "-", 
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdPlus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
          RowBox[{"\[Iota]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "5"], "-", 
             SubscriptBox["t", "4"]}], ")"}]}], "-", 
          RowBox[{"\[Gamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "4"], "-", 
             SubscriptBox["t", "3"]}], ")"}]}], "-", 
          RowBox[{"\[Epsilon]", 
