   3.898346907794641*^9}, {3.898346962570633*^9, 3.8983470556380215`*^9}, {
   3.8985918639927588`*^9, 3.8985919104002695`*^9}, {3.9112955831095295`*^9, 
   3.911295597487336*^9}},ExpressionUUID->"67ea2e19-fc04-45b4-90f2-\
f7275ed18e38"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"r", "=", "1"}], ",", 
     RowBox[{"r", "\[LessEqual]", " ", "4"}], ",", " ", 
     RowBox[{"r", "++"}], ",", " ", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "\[LessEqual]", " ", "4"}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"j", "=", "1"}], ",", 
         RowBox[{"j", "\[LessEqual]", "2"}], ",", 
         RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "1"}], " ", "||", " ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "2"}], "||", " ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "3"}], " ", "||", "  ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "4"}]}], " ", ",", 
            RowBox[{
             RowBox[{"GGFTime", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "=", "2"}]}], 
           "]"}], ";", " ", 
          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{"Time", " ", "Class", " ", "2"}], " ", "=", " ", 
            SubscriptBox["t", "1"]}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "6"}], " ", "||", " ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "7"}]}], ",", 
            RowBox[{
             RowBox[{"GGFTime", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "=", "1"}]}], 
           "]"}], ";", " ", 
          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{"Time", " ", "Class", " ", "1"}], " ", "=", " ", 
            RowBox[{"t", "'"}]}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "5"}], " ", "||", " ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "8"}]}], ",", 
            RowBox[{
             RowBox[{"GGFTime", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "=", "3"}]}], 
           "]"}]}]}], 
        RowBox[{"(*", "  ", 
         RowBox[{
          RowBox[{"Time", " ", "Class", " ", "3"}], " ", "=", " ", "t"}], " ",
          "*)"}], "\[IndentingNewLine]", "]"}]}], "]"}]}], "]"}], ";"}], 
  "  "}]], "Input",
