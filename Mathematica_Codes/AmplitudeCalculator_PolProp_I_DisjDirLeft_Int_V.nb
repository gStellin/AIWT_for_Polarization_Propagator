            RowBox[{"TimeClassOrdMinus", "[", 
             RowBox[{"[", 
              RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], "]"}], "\[Equal]", 
         "0"}], ",", 
        RowBox[{"{", "\[Digamma]", "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[Digamma]", "}"}], " ", "=", 
      RowBox[{
       RowBox[{"TimeIntegralSolutions2", "//", "Values"}], "//", 
       "Flatten"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"GGFGoldstoneAmplitude", "[", 
       RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
      RowBox[{"StringForm", "[", 
       RowBox[{
       "\"\<`1`\!\(\*FractionBox[\(`2`\), \(`3` + \\\ \[ImaginaryI]\\\ \[Eta]\
\)]\)\!\(\*FractionBox[\(`4`\), \(`5` + \\\ \[ImaginaryI]\\\ \
\[Eta]'\)]\)\>\"", ",", "Pref", ",", 
        RowBox[{
         RowBox[{"GGFAmplitude", "[", 
          RowBox[{"[", 
           RowBox[{"r", ",", "2"}], "]"}], "]"}], 
         RowBox[{"GGFAmplitude", "[", 
          RowBox[{"[", 
           RowBox[{"r", ",", "1"}], "]"}], "]"}]}], ",", "\[Epsilon]", ",", 
        RowBox[{
         RowBox[{"GGFAmplitude", "[", 
