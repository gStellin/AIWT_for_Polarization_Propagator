Cell[CellGroupData[{

Cell["Initialization of Gorkov-Green\[CloseCurlyQuote]s functions", \
"Subsection",
 CellChangeTimes->{{3.888315173503672*^9, 3.888315249112604*^9}, {
  3.9082537791702285`*^9, 
  3.9082537877198505`*^9}},ExpressionUUID->"40caeaa1-f0ac-4f84-b398-\
b0a3b37a31da"],

Cell["\<\
An anomalous  (or \[OpenCurlyQuote]2\[CloseCurlyQuote]) Nambu index is \
introduced whenever a homogeneous pair of second-quantization operators is \
found, consistently with the definition of the one-body Gorkov propagators \
(cf. Som\[AGrave] et al, 2011). In Bogoliubov diagrams, involute \
single-particle indices do appear, since at least an anomalous contraction of \
external single-particle indices is present. In this case, involute \
single-particle indices are mapped into negative natural numbers. \
\>", "Text",
 CellChangeTimes->{{3.8883172996209154`*^9, 3.8883174034984384`*^9}, {
  3.8883176851044188`*^9, 3.888317943793604*^9}, {3.9149072423983393`*^9, 
  3.9149072470989065`*^9}, {3.91915922487037*^9, 
  3.919159252780528*^9}},ExpressionUUID->"1f5f2f36-d192-4f61-9a87-\
b731f486b724"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"GGFNambu", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "4"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "4"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"GGFTime", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "4"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "4"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"GGFSParticle", " ", "=", " ", 
    RowBox[{"Table", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "4"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", "1", ",", "4"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", " ", "4"}], ",", " ", 
    RowBox[{"r", "++"}], ",", " ", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "\[LessEqual]", " ", "4"}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{"Canonical", " ", "contractions"}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{"Contraction", " ", "between", " ", "a", " ", "non"}], "-", 
         RowBox[{
         "involute", " ", "annihilation", " ", "operator", 
          "\[IndentingNewLine]", "followed", " ", "by", " ", "an", " ", 
          "involute", " ", "annihilation", " ", "operator"}]}], " ", "*)"}], 
       " ", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"SQTypeDirLeft", "[", 
             RowBox[{"[", 
              RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], "\[Equal]", 
            "1"}], " ", "&&", " ", 
           RowBox[{
            RowBox[{"SQTypeDirLeft", "[", 
             RowBox[{"[", 
              RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}], "\[Equal]", 
            "1"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"NambuDirLeft", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], "\[Equal]", 
               " ", "1"}], " ", "&&", " ", 
              RowBox[{
               RowBox[{"NambuDirLeft", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}], "\[Equal]", 
               "2"}]}], " ", ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], "=", 
