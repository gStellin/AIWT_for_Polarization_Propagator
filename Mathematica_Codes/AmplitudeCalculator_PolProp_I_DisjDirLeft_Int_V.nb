         RowBox[{"GGFAmplitude", "[", 
          RowBox[{"[", 
           RowBox[{"r", ",", "4"}], "]"}], "]"}]}], ",", "\[Digamma]"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Clear", "[", "\[Digamma]", "]"}], ";", "\[IndentingNewLine]", 
