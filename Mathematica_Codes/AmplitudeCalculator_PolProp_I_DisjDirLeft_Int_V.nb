Cell[BoxData[
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", " ", "4"}], ",", " ", 
    RowBox[{"r", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"j", "=", "1"}], ",", 
       RowBox[{"j", "\[LessEqual]", "4"}], ",", 
       RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"i", "=", "1"}], ",", 
          RowBox[{"i", "\[LessEqual]", " ", "2"}], ",", 
          RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "1"}], " ", "&&", 
              RowBox[{
               RowBox[{"GGFNambu", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], " ", 
               "\[Equal]", " ", "1"}]}], " ", ",", " ", 
             RowBox[{
              RowBox[{"SPLIndex", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "=", "\"\<p\>\""}]}], "]"}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "1"}], " ", "&&", 
              RowBox[{
               RowBox[{"GGFNambu", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "2"}]}], ",", " ", 
             RowBox[{
              RowBox[{"SPLIndex", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "=", 
              RowBox[{"OverBar", "[", "\"\<p\>\"", "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "2"}], " ", "&&", " ", 
              RowBox[{
               RowBox[{"GGFNambu", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], " ", 
               "\[Equal]", " ", "1"}]}], " ", ",", " ", 
             RowBox[{
              RowBox[{"SPLIndex", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "=", "\"\<q\>\""}]}], "]"}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "2"}], " ", "&&", 
              RowBox[{
               RowBox[{"GGFNambu", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "2"}]}], ",", " ", 
             RowBox[{
              RowBox[{"SPLIndex", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "=", 
              RowBox[{"OverBar", "[", "\"\<q\>\"", "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "3"}], " ", "&&", " ", 
              RowBox[{
               RowBox[{"GGFNambu", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], " ", 
               "\[Equal]", " ", "1"}]}], " ", ",", " ", 
             RowBox[{
              RowBox[{"SPLIndex", "[", 
               RowBox[{"[", "3", "]"}], "]"}], "=", "\"\<s\>\""}]}], "]"}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "3"}], " ", "&&", 
              RowBox[{
               RowBox[{"GGFNambu", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "2"}]}], ",", " ", 
             RowBox[{
              RowBox[{"SPLIndex", "[", 
               RowBox[{"[", "3", "]"}], "]"}], "=", 
              RowBox[{"OverBar", "[", "\"\<s\>\"", "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "4"}], " ", "&&", " ", 
              RowBox[{
               RowBox[{"GGFNambu", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], " ", 
               "\[Equal]", " ", "1"}]}], " ", ",", " ", 
             RowBox[{
              RowBox[{"SPLIndex", "[", 
               RowBox[{"[", "4", "]"}], "]"}], "=", "\"\<r\>\""}]}], "]"}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "4"}], " ", "&&", 
              RowBox[{
               RowBox[{"GGFNambu", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "2"}]}], ",", " ", 
             RowBox[{
              RowBox[{"SPLIndex", "[", 
               RowBox[{"[", "4", "]"}], "]"}], "=", 
              RowBox[{"OverBar", "[", "\"\<r\>\"", "]"}]}]}], "]"}], ";"}]}], 
         "\[IndentingNewLine]", "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"Pref", " ", "=", 
      RowBox[{"StringForm", "[", 
       RowBox[{
       "\"\<``\!\(\*SubscriptBox[\(\[Sum]\), \(\*SubscriptBox[\(k\), \(1\)] \
\*SubscriptBox[\(k\), \(2\)] \*SubscriptBox[\(k\), \(3\)] \
\*SubscriptBox[\(k\), \(4\)]\)]\)\!\(\*SubscriptBox[\(\[Sum]\), \(pqrs\)]\) \
\!\(\*SubscriptBox[OverscriptBox[\(v\), \(_\)], \(``\\\ ``\\\ ``\\\ ``\)]\) \
\>\"", ",", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"-", "1"}], ")"}], 
          RowBox[{"AmplSign", "[", 
           RowBox[{"[", "r", "]"}], "]"}]], 
         FractionBox[
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"-", "\[ImaginaryI]"}], ")"}], "2"], "\[HBar]"], 
         SuperscriptBox[
          RowBox[{"(", 
           FractionBox["1", 
            RowBox[{"-", "\[ImaginaryI]"}]], ")"}], "2"], 
         FractionBox[
          RowBox[{"GGFMult", "[", 
           RowBox[{"[", "r", "]"}], "]"}], "4"]}], ",", 
        RowBox[{"SPLIndex", "[", 
         RowBox[{"[", "1", "]"}], "]"}], ",", 
        RowBox[{"SPLIndex", "[", 
         RowBox[{"[", "2", "]"}], "]"}], ",", 
        RowBox[{"SPLIndex", "[", 
         RowBox[{"[", "4", "]"}], "]"}], ",", 
        RowBox[{"SPLIndex", "[", 
         RowBox[{"[", "3", "]"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"TimeIntegralSolutions1", " ", "=", 
      RowBox[{"Solve", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Coefficient", "[", 
          RowBox[{
           RowBox[{"GGFTotalPolynomial", "[", 
            RowBox[{"[", "r", "]"}], "]"}], ",", 
           SubscriptBox["t", 
            RowBox[{"TimeClassOrdMinus", "[", 
             RowBox[{"[", 
              RowBox[{"T", ",", "2"}], "]"}], "]"}]]}], "]"}], "\[Equal]", 
         "0"}], " ", ",", 
        RowBox[{"{", "\[Epsilon]", "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[Epsilon]", "}"}], " ", "=", 
      RowBox[{
       RowBox[{"TimeIntegralSolutions1", "//", "Values"}], " ", "//", " ", 
       "Flatten"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"TimeIntegralSolutions2", " ", "=", 
      RowBox[{"Solve", "[", 
