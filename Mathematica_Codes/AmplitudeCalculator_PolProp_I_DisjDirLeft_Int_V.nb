Cell[CellGroupData[{

Cell["Assignment of the time indices, based on the time ordering", \
"Subsection",
 CellChangeTimes->{{3.888315861110175*^9, 
  3.8883159051561947`*^9}},ExpressionUUID->"e73dce37-c4c3-485e-852d-\
55ada5c5dfa1"],

Cell["\<\
It is convenient to assign the times (associated with the single-particle and \
the Nambu indices) only once the time ordering is established. This permits \
to evaluate the Gorkov-Green\[CloseCurlyQuote]s functions more rapidly, \
exploiting the order of the natural numbers 1, 2 and 3. The time indices \
appearing henceforth are, thus, relative times (= time-ordering dependent), \
whereas the absolute times (cf. the convention in the opening) correspond to \
the time classes. Times are sorted in ascending order: \[OpenCurlyQuote]3\
\[CloseCurlyQuote] is the latest time and \
\[OpenCurlyQuote]1\[CloseCurlyQuote] is the earliest one. \
\>", "Text",
 CellChangeTimes->{{3.8883167440333986`*^9, 3.88831696819341*^9}, {
  3.888317011995018*^9, 3.8883170646181097`*^9}, {3.889609118331727*^9, 
  3.889609124242071*^9}},ExpressionUUID->"525c4220-6ff2-4fd0-9e1a-\
d3c99d830d81"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"TimeClass", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", " ", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "3"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"TimeClassOrdMinus", " ", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"3", ",", "1", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "3", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"3", ",", "2", ",", "1"}], "}"}]}], "}"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.8878867610099325`*^9, 3.8878867920840836`*^9}, {
   3.889588756462142*^9, 3.889588756619676*^9}, 3.907955762735047*^9, {
   3.9082517213737535`*^9, 3.908251721706238*^9}},
 CellLabel->
  "In[296]:=",ExpressionUUID->"82db9229-08b1-41d6-8d69-c37244704441"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"T", " ", "=", "3"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"r", "=", "1"}], ",", 
     RowBox[{"r", "\[LessEqual]", " ", "4"}], ",", " ", 
     RowBox[{"r", "++"}], ",", " ", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "\[LessEqual]", " ", "4"}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"j", "=", "1"}], ",", 
         RowBox[{"j", "\[LessEqual]", "2"}], ",", 
         RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "1"}], " ", "||", " ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "2"}], "||", " ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "3"}], " ", "||", "  ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "4"}]}], " ", ",", 
            RowBox[{
             RowBox[{"GGFTime", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "=", 
             RowBox[{"TimeClassOrdMinus", "[", 
              RowBox[{"[", 
               RowBox[{"T", ",", "2"}], "]"}], "]"}]}]}], "]"}], ";", " ", 
          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{"Time", " ", "Class", " ", "2"}], " ", "=", " ", 
            SubscriptBox["t", "1"]}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "6"}], " ", "||", " ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "7"}]}], ",", 
            RowBox[{
             RowBox[{"GGFTime", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "=", 
             RowBox[{"TimeClassOrdMinus", "[", 
              RowBox[{"[", 
               RowBox[{"T", ",", "1"}], "]"}], "]"}]}]}], "]"}], ";", " ", 
          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{"Time", " ", "Class", " ", "1"}], " ", "=", " ", 
            RowBox[{"t", "'"}]}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "5"}], " ", "||", " ", 
             RowBox[{
              RowBox[{"GGFSParticle", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "\[Equal]", 
              "8"}]}], ",", 
            RowBox[{
             RowBox[{"GGFTime", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "=", 
             RowBox[{"TimeClassOrdMinus", "[", 
              RowBox[{"[", 
               RowBox[{"T", ",", "3"}], "]"}], "]"}]}]}], "]"}]}]}], 
        RowBox[{"(*", "  ", 
         RowBox[{
          RowBox[{"Time", " ", "Class", " ", "3"}], " ", "=", " ", "t"}], " ",
          "*)"}], "\[IndentingNewLine]", "]"}]}], "]"}]}], "]"}], ";"}], 
  "  "}]}], "Input",
