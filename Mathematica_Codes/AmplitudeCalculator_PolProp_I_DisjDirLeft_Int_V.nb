d778e1940991"],

Cell[CellGroupData[{

Cell["\<\
Assignment of the time indices, based on the canonical ordering\
\>", "Subsection",
 CellChangeTimes->{{3.888315861110175*^9, 3.8883159051561947`*^9}, {
  3.8983468473701744`*^9, 
  3.8983468556580143`*^9}},ExpressionUUID->"cbfba900-a694-4fd2-9224-\
1d7cfbc49154"],

Cell[TextData[{
 "Times are sorted in ascending order: \[OpenCurlyQuote]3\[CloseCurlyQuote] \
is the latest time and denotes t, \[OpenCurlyQuote]2\[CloseCurlyQuote] \
denotes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "1"], TraditionalForm]],ExpressionUUID->
  "5265e50f-185f-4c5e-86d4-9ea2fccb093f"],
 " and \[OpenCurlyQuote]1\[CloseCurlyQuote] and denotes t\[CloseCurlyQuote]."
}], "Text",
 CellChangeTimes->{{3.8883167440333986`*^9, 3.88831696819341*^9}, {
   3.888317011995018*^9, 3.8883170646181097`*^9}, 3.892123452544158*^9, {
