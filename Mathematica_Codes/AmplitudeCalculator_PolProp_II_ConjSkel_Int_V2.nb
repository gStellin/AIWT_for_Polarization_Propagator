Cell[CellGroupData[{

Cell["\<\
Calculation of the amplitude associated to Goldstone diagrams with alphabetic \
indices\
\>", "Subsection",
 CellChangeTimes->{{3.888315861110175*^9, 3.8883159051561947`*^9}, {
  3.8883159887111607`*^9, 3.888316043821027*^9}, {3.888316084808132*^9, 
  3.888316094409692*^9}, {3.9080017355726566`*^9, 3.9080017402516623`*^9}, {
  3.9082509561005807`*^9, 
  3.9082509656258793`*^9}},ExpressionUUID->"23cfda71-9cab-40e5-a9d6-\
90ea60aefb99"],

Cell[TextData[{
 "The three time integrals are evaluated in two steps. First, one computes \
the integrals over ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "1"], TraditionalForm]],ExpressionUUID->
  "7a140110-3f8d-44d2-8d6c-76a8935f4fd7"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "2"], TraditionalForm]],ExpressionUUID->
  "97ef505a-440f-44a1-adcd-feb9ff05fc25"],
 " (dummy times), by solving a linear system with a parameter (the third \
frequency). At second order, the frequency variables which are evaluated \
after integration by ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "1"], TraditionalForm]],ExpressionUUID->
  "a3e99c05-806a-4a94-aa89-17d23662c217"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "2"], TraditionalForm]],ExpressionUUID->
  "b30a08cd-ecce-42ab-9ce0-4c13a1c667f0"],
 " are labeled as \[Gamma] and \[Epsilon]. Consequently, the time differences \
multiplying \[Gamma] and \[Epsilon] must contain the times ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", 
    RowBox[{"1", " "}]], TraditionalForm]],ExpressionUUID->
  "4b55f0fe-a3c8-4b4f-ba01-70bb2f4f5cb5"],
 "and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "2"], TraditionalForm]],ExpressionUUID->
  "1506a122-845b-4799-987d-6149460e7e6e"],
 ", otherwise the integration fails. Next, the integration over (t-t\
\[CloseCurlyQuote]) is performed by solving a single linear equation, \
obtained by equating the coefficient of (t-t\[CloseCurlyQuote]) in the total \
polynomial to zero. Note that the time interval that multiplies \[Digamma]  \
must contain t and/or t\[CloseCurlyQuote].  However, t and \
t\[CloseCurlyQuote] shall not appear together in that time interval, \
otherwise the time ordering of the corresponding Goldstone diagram becomes \
undefined (or ambiguously defined). Consequently, in the denominators of the \
energy representation, multiple \[OpenCurlyQuote]omegas\[CloseCurlyQuote] may \
appear, depending on the topology of the unoriented Goldstone diagram. \
Besides, the time interval multiplying \[Digamma]  shall never coincide with \
the one multiplying \[Gamma] or \[Epsilon], otherwise the implemented time \
sequence is ill-defined."
}], "Text",
 CellChangeTimes->{{3.8883163242658205`*^9, 3.8883163554476023`*^9}, {
   3.8883164071679173`*^9, 3.8883165187772655`*^9}, {3.888316549145891*^9, 
   3.888316725014002*^9}, {3.8921261744276867`*^9, 3.8921261761442184`*^9}, {
   3.9399911443863597`*^9, 3.939991398095018*^9}, {3.939991454698805*^9, 
   3.9399914925585866`*^9}, {3.939995783623706*^9, 3.939995794686199*^9}, {
   3.9399958964808445`*^9, 3.939995900606132*^9}, 
   3.945764995399589*^9},ExpressionUUID->"c76dc78e-2c30-4c93-b762-\
6c7b779da6c7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"GGFTotalPolynomial", " ", "=", " ", 
    RowBox[{"Table", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"r", ",", "1", ",", "60"}], "}"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", " ", "60"}], ",", " ", 
    RowBox[{"r", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"j", "=", "1"}], ",", 
       RowBox[{"j", "\[LessEqual]", "6"}], ",", 
       RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", 
         RowBox[{
          RowBox[{"GGFTotalPolynomial", "[", 
           RowBox[{"[", "r", "]"}], "]"}], "+", 
          RowBox[{"GGFPolynomial", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", "j"}], "]"}], "]"}]}]}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"T", "\[Equal]", "1"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
         RowBox[{
          RowBox[{"GGFTotalPolynomial", "[", 
           RowBox[{"[", "r", "]"}], "]"}], " ", "+", " ", 
          RowBox[{"\[Omega]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdPlus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "4"}], "]"}], "]"}]], "-", 
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdPlus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
          RowBox[{"\[Gamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "4"], "-", 
             SubscriptBox["t", "3"]}], ")"}]}], "-", 
          RowBox[{"\[Epsilon]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "2"], "-", 
             SubscriptBox["t", "1"]}], ")"}]}], "-", 
          RowBox[{"\[Digamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "3"], "-", 
             SubscriptBox["t", "2"]}], ")"}]}]}]}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"T", "\[Equal]", "2"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
         RowBox[{
          RowBox[{"GGFTotalPolynomial", "[", 
           RowBox[{"[", "r", "]"}], "]"}], " ", "+", " ", 
          RowBox[{"\[Omega]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdPlus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "4"}], "]"}], "]"}]], "-", 
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdPlus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
          RowBox[{"\[Gamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "4"], "-", 
             SubscriptBox["t", "3"]}], ")"}]}], "-", 
          RowBox[{"\[Epsilon]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "3"], "-", 
             SubscriptBox["t", "2"]}], ")"}]}], "-", 
          RowBox[{"\[Digamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "2"], "-", 
             SubscriptBox["t", "1"]}], ")"}]}]}]}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"T", "\[Equal]", "3"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
         RowBox[{
          RowBox[{"GGFTotalPolynomial", "[", 
           RowBox[{"[", "r", "]"}], "]"}], " ", "+", " ", 
          RowBox[{"\[Omega]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdPlus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "4"}], "]"}], "]"}]], "-", 
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdPlus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
          RowBox[{"\[Gamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "4"], "-", 
             SubscriptBox["t", "3"]}], ")"}]}], "-", 
          RowBox[{"\[Epsilon]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "3"], "-", 
             SubscriptBox["t", "2"]}], ")"}]}], "-", 
          RowBox[{"\[Digamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "2"], "-", 
             SubscriptBox["t", "1"]}], ")"}]}]}]}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"T", "\[Equal]", "4"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
