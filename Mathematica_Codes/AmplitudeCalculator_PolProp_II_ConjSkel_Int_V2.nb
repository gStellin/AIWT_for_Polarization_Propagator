           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdPlus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "4"}], "]"}], "]"}]], "-", 
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdPlus", "[", 
               RowBox[{"[", 
