Cell[CellGroupData[{

Cell["\<\
Calculation of the amplitude associated to the \
Gorkov-Green\[CloseCurlyQuote]s functions with alphabetic indices\
\>", "Subsection",
 CellChangeTimes->{{3.888315861110175*^9, 3.8883159051561947`*^9}, {
  3.8883159887111607`*^9, 3.888316043821027*^9}, {3.9080016383725634`*^9, 
  3.908001643028146*^9}},ExpressionUUID->"e5531210-a346-4dbb-9cdc-\
ee134e97ee53"],

Cell["\<\
Initialization of the Gorkov-Green\[CloseCurlyQuote]s functions based on the \
chosen time ordering. The polynomial, appearing as argument of a natural \
exponential, is also calculated, neglecting the imaginary unit \[ImaginaryI] \
(factor).\
\>", "Text",
 CellChangeTimes->{{3.8883163242658205`*^9, 3.8883163554476023`*^9}, {
  3.8883164071679173`*^9, 
  3.8883165187772655`*^9}},ExpressionUUID->"16b801ac-10f0-40d2-8411-\
132ae4e5dea7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "k", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"GGFAmplitude", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "60"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "6"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"GGFPolynomial", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0.0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "60"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "6"}], "}"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.8878878608574233`*^9, 3.8878880940257835`*^9}, 
   3.887890072328867*^9, {3.8878914603928394`*^9, 3.8878914700344296`*^9}, {
   3.8884119686701937`*^9, 3.88841197242874*^9}, {3.8895893978728447`*^9, 
   3.889589403387763*^9}, {3.908264222635662*^9, 3.908264226907137*^9}, {
   3.909206178706339*^9, 3.909206183009929*^9}, {3.909218754757968*^9, 
   3.9092187579511137`*^9}},
 CellLabel->
  "In[157]:=",ExpressionUUID->"c3d46856-5fa0-43db-9944-0f90ae14eb7d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", " ", "60"}], ",", " ", 
    RowBox[{"r", "++"}], ",", " ", "\[IndentingNewLine]", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"i", "\[LessEqual]", " ", "6"}], ",", 
      RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"GGFTime", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], " ", ">", " ", 
          RowBox[{"GGFTime", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]}], ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"GGFAmplitude", "[", 
            RowBox[{"[", 
             RowBox[{"r", ",", "i"}], "]"}], "]"}], " ", "=", 
           RowBox[{
            RowBox[{"StringForm", "[", 
             RowBox[{"\"\<``\>\"", ",", 
              RowBox[{"Superscript", "[", 
               RowBox[{
                RowBox[{"Superscript", "[", 
                 RowBox[{
                  RowBox[{"Subscript", "[", 
                   RowBox[{"\[Chi]", ",", 
                    RowBox[{"NtL", "[", 
                    RowBox[{"GGFSParticle", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], "]"}]}], 
                   "]"}], ",", 
                  RowBox[{"GGFNambu", "[", 
                   RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}]}], "]"}], 
                ",", 
                SubscriptBox["k", "i"]}], "]"}]}], "]"}], 
            RowBox[{"StringForm", "[", 
             RowBox[{"\"\<``\>\"", ",", 
              RowBox[{"Superscript", "[", 
               RowBox[{
                RowBox[{"Superscript", "[", 
                 RowBox[{
                  RowBox[{"Subscript", "[", 
                   RowBox[{
                    RowBox[{"OverBar", "[", "\[Chi]", "]"}], ",", 
                    RowBox[{"NtL", "[", 
                    RowBox[{"GGFSParticle", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}], "]"}]}], 
                   "]"}], ",", 
                  RowBox[{"GGFNambu", "[", 
                   RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]}], "]"}], 
                ",", 
                SubscriptBox["k", "i"]}], "]"}]}], "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"GGFPolynomial", "[", 
            RowBox[{"[", 
             RowBox[{"r", ",", "i"}], "]"}], "]"}], " ", "=", 
           RowBox[{
            RowBox[{
             RowBox[{"-", 
              RowBox[{"(", " ", 
               RowBox[{
                SubscriptBox["\[CapitalOmega]", 
                 SubscriptBox["k", "i"]], "-", 
                SubscriptBox["\[CapitalOmega]", "0"]}], ")"}]}], 
             RowBox[{
              SubscriptBox["t", 
               RowBox[{"GGFTime", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}]], "/", 
              "\[HBar]"}]}], "+", 
            RowBox[{
             RowBox[{"(", " ", 
              RowBox[{
               SubscriptBox["\[CapitalOmega]", 
                SubscriptBox["k", "i"]], "-", 
               SubscriptBox["\[CapitalOmega]", "0"]}], ")"}], 
             RowBox[{
              SubscriptBox["t", 
               RowBox[{"GGFTime", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]], "/", 
              "\[HBar]"}]}]}]}], ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"GGFTime", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], " ", "<", " ", 
          RowBox[{"GGFTime", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}]}], ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"GGFAmplitude", "[", 
