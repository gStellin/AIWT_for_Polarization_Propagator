      RowBox[{"i", ",", "1", ",", "1"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SignFlip", " ", "=", " ", 
   RowBox[{"Table", "[", 
