Cell[CellGroupData[{

Cell["Assignment of the time indices, based on the time ordering", \
"Subsection",
 CellChangeTimes->{{3.888315861110175*^9, 
  3.8883159051561947`*^9}},ExpressionUUID->"5b2a489c-1cbc-416e-80e4-\
feae00432d90"],

Cell["\<\
It is convenient to assign the times (associated with the single-particle and \
the Nambu indices) only once the time ordering is established. This permits \
to evaluate the Gorkov-Green\[CloseCurlyQuote]s functions more rapidly, \
exploiting the order of the natural numbers 1 and 2. The time indices \
appearing henceforth are, thus, relative times (= time-ordering dependent), \
whereas the absolute times (cf. the convention in the opening) correspond to \
the time classes. Times are sorted in ascending order: \[OpenCurlyQuote]2\
\[CloseCurlyQuote] is the latest time and \
\[OpenCurlyQuote]1\[CloseCurlyQuote] is the earliest one. \
\>", "Text",
 CellChangeTimes->{{3.8883167440333986`*^9, 3.88831696819341*^9}, {
  3.888317011995018*^9, 3.8883170646181097`*^9}, {3.889609118331727*^9, 
  3.889609124242071*^9}, {3.910168847672412*^9, 
  3.910168860487174*^9}},ExpressionUUID->"4198bdd3-52a8-4a2a-8e49-\
b18393b25ffe"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"T", " ", "=", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"r", "=", "1"}], ",", 
     RowBox[{"r", "\[LessEqual]", " ", "1"}], ",", " ", 
     RowBox[{"r", "++"}], ",", " ", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "\[LessEqual]", " ", "2"}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"j", "=", "1"}], ",", 
         RowBox[{"j", "\[LessEqual]", "2"}], ",", 
         RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "]"}], 
              "\[Equal]", "2"}], " ", "||", " ", 
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "]"}], 
              "\[Equal]", "3"}]}], ",", 
            RowBox[{
             RowBox[{"GGFTime", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "=", 
             RowBox[{"TimeClassOrdPlus", "[", 
              RowBox[{"[", 
               RowBox[{"T", ",", "1"}], "]"}], "]"}]}]}], "]"}], ";", " ", 
          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{"Time", " ", "Class", " ", "1"}], " ", "=", " ", 
            RowBox[{"t", "'"}]}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "]"}], 
              "\[Equal]", "1"}], " ", "||", " ", 
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "]"}], 
              "\[Equal]", "4"}]}], ",", 
            RowBox[{
             RowBox[{"GGFTime", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i", ",", "j"}], "]"}], "]"}], "=", 
             RowBox[{"TimeClassOrdPlus", "[", 
              RowBox[{"[", 
               RowBox[{"T", ",", "2"}], "]"}], "]"}]}]}], "]"}]}]}], 
        RowBox[{"(*", "  ", 
         RowBox[{
          RowBox[{"Time", " ", "Class", " ", "2"}], " ", "=", " ", "t"}], " ",
          "*)"}], "\[IndentingNewLine]", "]"}]}], "]"}]}], "]"}], ";"}], 
  "  "}]}], "Input",
