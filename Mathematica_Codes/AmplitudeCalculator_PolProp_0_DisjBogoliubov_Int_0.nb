Cell[BoxData[
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", "1"}], ",", 
    RowBox[{"r", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"SignFlip", "[", 
       RowBox[{"[", "r", "]"}], "]"}], "=", "0"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "0"}], ",", 
       RowBox[{"i", "\[LessEqual]", " ", "1"}], ",", " ", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"SPSequence", "[", 
          RowBox[{"[", 
           RowBox[{"r", ",", 
            RowBox[{
             RowBox[{"2", "i"}], "+", "1"}]}], "]"}], "]"}], " ", "=", " ", 
         RowBox[{"Abs", "[", 
          RowBox[{"GGFSParticle", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", 
             RowBox[{"i", "+", "1"}], ",", "1"}], "]"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"SPSequence", "[", 
          RowBox[{"[", 
           RowBox[{"r", ",", 
            RowBox[{
             RowBox[{"2", "i"}], "+", "2"}]}], "]"}], "]"}], " ", "=", " ", 
