                    RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}], " ", 
                    "\[Equal]", "11"}]}], ")"}], "\[IndentingNewLine]", "&&", 
                    " ", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"CombBog", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}], " ", 
                    "\[Equal]", "9"}], "||", 
                    RowBox[{
