                RowBox[{"T", ",", "4"}], "]"}], "]"}]], "-", 
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdMinus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
          RowBox[{"\[Gamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "2"], "-", 
             SubscriptBox["t", "1"]}], ")"}]}], "-", 
          RowBox[{"\[Epsilon]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "3"], "-", 
             SubscriptBox["t", "2"]}], ")"}]}], "-", 
          RowBox[{"\[Digamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "4"], "-", 
             SubscriptBox["t", "3"]}], ")"}]}]}]}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"T", "\[Equal]", "5"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"GGFTotalPolynomial", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
         RowBox[{
          RowBox[{"GGFTotalPolynomial", "[", 
           RowBox[{"[", "r", "]"}], "]"}], " ", "+", " ", 
          RowBox[{"\[Omega]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdMinus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "4"}], "]"}], "]"}]], "-", 
             SubscriptBox["t", 
              RowBox[{"TimeClassOrdMinus", "[", 
               RowBox[{"[", 
                RowBox[{"T", ",", "1"}], "]"}], "]"}]]}], ")"}]}], "-", 
          RowBox[{"\[Gamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "4"], "-", 
             SubscriptBox["t", "3"]}], ")"}]}], "-", 
          RowBox[{"\[Epsilon]", 
