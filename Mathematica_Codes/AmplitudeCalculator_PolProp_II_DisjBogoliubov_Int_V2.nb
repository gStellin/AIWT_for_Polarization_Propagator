Cell[CellGroupData[{

Cell["Determination of the sign", "Subsection",
 CellChangeTimes->{{3.888315173503672*^9, 3.888315249112604*^9}, {
  3.8883153026090937`*^9, 3.8883153149727306`*^9}, {3.8883155620990925`*^9, 
  3.8883156912295876`*^9}},ExpressionUUID->"68396bd3-ee92-4866-af62-\
5d1842f314ef"],

Cell["\<\
The sign corresponds to the minimum number of 2-cycle/binary permutations (= \
transpositions) necessary to disentangle the all the contractions of \
second-quantization operators and, thus, reproduce the loaded sequences of \
single-particle indices. \
\>", "Text",
 CellChangeTimes->{{3.8883172996209154`*^9, 
  3.8883174034984384`*^9}},ExpressionUUID->"a79a97a9-8e4e-4d53-8c2f-\
e4596cdb6615"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"AmplSign", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "16"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SignFlip", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "16"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SPSequence", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "16"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "12"}], "}"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.887459078849492*^9, 3.887459122037883*^9}, {
   3.8874592893808393`*^9, 3.887459297677747*^9}, 3.887459357795594*^9, {
   3.888056647410096*^9, 3.8880566840199842`*^9}, {3.88805694331452*^9, 
   3.8880569442140484`*^9}, {3.888410270393134*^9, 3.8884102743974495`*^9}, {
   3.889586544972464*^9, 3.8895865531963754`*^9}, {3.909054615140287*^9, 
   3.9090546334660006`*^9}, {3.9090549824619236`*^9, 3.909054984981395*^9}, {
   3.909234312070729*^9, 3.909234322347723*^9}, {3.9094877076910114`*^9, 
   3.909487713172553*^9}},ExpressionUUID->"d2129d90-10d2-4fc8-a89e-\
28cdbd6c004e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", "16"}], ",", 
    RowBox[{"r", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"SignFlip", "[", 
       RowBox[{"[", "r", "]"}], "]"}], "=", "0"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "0"}], ",", 
       RowBox[{"i", "\[LessEqual]", " ", "5"}], ",", " ", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"SPSequence", "[", 
          RowBox[{"[", 
           RowBox[{"r", ",", 
            RowBox[{
             RowBox[{"2", "i"}], "+", "1"}]}], "]"}], "]"}], " ", "=", " ", 
         RowBox[{"Abs", "[", 
          RowBox[{"GGFSParticle", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", 
             RowBox[{"i", "+", "1"}], ",", "1"}], "]"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"SPSequence", "[", 
          RowBox[{"[", 
           RowBox[{"r", ",", 
            RowBox[{
             RowBox[{"2", "i"}], "+", "2"}]}], "]"}], "]"}], " ", "=", " ", 
         RowBox[{"Abs", "[", 
          RowBox[{"GGFSParticle", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", 
             RowBox[{"i", "+", "1"}], ",", "2"}], "]"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"SignFlip", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
         RowBox[{
          RowBox[{"SignFlip", "[", 
           RowBox[{"[", "r", "]"}], "]"}], " ", "+", " ", 
          RowBox[{"SignFlipBog", " ", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", 
             RowBox[{"i", "+", "1"}]}], "]"}], "]"}]}]}], ";"}]}], 
      "\[IndentingNewLine]", "]"}]}]}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.8880567089287558`*^9, 3.888056881383081*^9}, {
