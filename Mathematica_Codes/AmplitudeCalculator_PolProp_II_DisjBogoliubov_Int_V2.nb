                 "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"GGFSParticle", "[", 
                   RowBox[{"[", 
                    RowBox[{"r", ",", "i", ",", "2"}], "]"}], "]"}], "=", 
                  RowBox[{"CombBog", "[", 
