   3.9145864418743815`*^9}},ExpressionUUID->"17151657-fdd4-406d-9bb1-\
bd7cc127b794"],

Cell[BoxData[
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"u", "=", "1"}], ",", 
   RowBox[{"u", "\[LessEqual]", " ", "22"}], ",", 
