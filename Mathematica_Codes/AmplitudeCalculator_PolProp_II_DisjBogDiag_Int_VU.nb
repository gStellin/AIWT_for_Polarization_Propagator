   3.888400878965273*^9, 3.888401074647033*^9, 3.8884011779473057`*^9, 
   3.8884013069217825`*^9, 3.8884013954501605`*^9, {3.888411910226502*^9, 
   3.8884119104961667`*^9}, 3.888412677387509*^9, 3.88841307504419*^9, 
   3.8884134110582433`*^9, {3.888413573077077*^9, 3.8884135734645896`*^9}, 
   3.8884143581006765`*^9, {3.888414518849474*^9, 3.888414519518566*^9}, 
   3.88841460825488*^9, {3.8884146831229835`*^9, 3.8884146834245987`*^9}, {
   3.888414763299806*^9, 3.8884147637122216`*^9}, 3.88841506626973*^9, {
   3.888415129003436*^9, 3.888415129246996*^9}, {3.8928037455808544`*^9, 
   3.8928037458025627`*^9}, {3.8970506020561666`*^9, 
   3.8970506090547857`*^9}, {3.909207414962878*^9, 3.9092074283182917`*^9}, {
   3.9127511637627816`*^9, 3.912751177657996*^9}, {3.9127514479468484`*^9, 
   3.912751456414852*^9}, {3.9127519256588497`*^9, 3.9127519416916256`*^9}, {
   3.912924062565045*^9, 3.9129240627482405`*^9}, {3.9129242289023447`*^9, 
