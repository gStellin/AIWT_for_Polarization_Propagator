      RowBox[{"3", ",", "2", ",", "1", ",", "4"}], "}"}]}], "}"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.8878867610099325`*^9, 3.8878867920840836`*^9}, 
   3.91275196053093*^9, {3.945955047674754*^9, 
   3.9459550547097883`*^9}},ExpressionUUID->"bfca7c18-597b-434f-9ab1-\
