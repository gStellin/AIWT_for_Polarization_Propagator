             SubscriptBox["t", "4"]}], ")"}]}], "-", 
          RowBox[{"\[Gamma]", 
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["t", "4"], "-", 
             SubscriptBox["t", "3"]}], ")"}]}], "-", 
          RowBox[{"\[Epsilon]", 
           RowBox[{"(", 
