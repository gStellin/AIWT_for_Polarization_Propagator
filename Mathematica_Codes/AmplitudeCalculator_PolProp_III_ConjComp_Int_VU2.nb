                "\[HBar]"}]}]}]}]}]}], "]"}]}], "]"}], ";"}]}], 
     "\[IndentingNewLine]", "]"}]}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.887888869530408*^9, 3.8878890140860596`*^9}, {
   3.8878890811605024`*^9, 3.887889210979035*^9}, {3.8878892879117765`*^9, 
