     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"s", "\[Equal]", 
        RowBox[{"-", "1"}]}], ",", " ", 
       RowBox[{"Return", "[", 
        RowBox[{"OverBar", "[", "\"\<p\>\"", "]"}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
