Cell[BoxData[
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", " ", "340"}], ",", " ", 
    RowBox[{"r", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"j", "=", "1"}], ",", 
       RowBox[{"j", "\[LessEqual]", "7"}], ",", 
       RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"i", "=", "1"}], ",", 
          RowBox[{"i", "\[LessEqual]", " ", "2"}], ",", 
          RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "1"}], " ", "&&", 
              RowBox[{
               RowBox[{"GGFNambu", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], " ", 
               "\[Equal]", " ", "1"}]}], " ", ",", " ", 
             RowBox[{
              RowBox[{"SPLIndex", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "=", "\"\<p\>\""}]}], "]"}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "1"}], " ", "&&", 
              RowBox[{
               RowBox[{"GGFNambu", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "2"}]}], ",", " ", 
             RowBox[{
              RowBox[{"SPLIndex", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "=", 
              RowBox[{"OverBar", "[", "\"\<p\>\"", "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "2"}], " ", "&&", " ", 
              RowBox[{
               RowBox[{"GGFNambu", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], " ", 
               "\[Equal]", " ", "1"}]}], " ", ",", " ", 
             RowBox[{
              RowBox[{"SPLIndex", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "=", "\"\<q\>\""}]}], "]"}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "2"}], " ", "&&", 
              RowBox[{
               RowBox[{"GGFNambu", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "2"}]}], ",", " ", 
             RowBox[{
              RowBox[{"SPLIndex", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "=", 
              RowBox[{"OverBar", "[", "\"\<q\>\"", "]"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "3"}], " ", "&&", " ", 
              RowBox[{
               RowBox[{"GGFNambu", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], " ", 
               "\[Equal]", " ", "1"}]}], " ", ",", " ", 
             RowBox[{
              RowBox[{"SPLIndex", "[", 
               RowBox[{"[", "3", "]"}], "]"}], "=", "\"\<s\>\""}]}], "]"}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"GGFSParticle", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "3"}], " ", "&&", 
              RowBox[{
               RowBox[{"GGFNambu", "[", 
                RowBox[{"[", 
                 RowBox[{"r", ",", "j", ",", "i"}], "]"}], "]"}], "\[Equal]", 
               "2"}]}], ",", " ", 
             RowBox[{
              RowBox[{"SPLIndex", "[", 
               RowBox[{"[", "3", "]"}], "]"}], "=", 
              RowBox[{"OverBar", "[", "\"\<s\>\"", "]"}]}]}], "]"}], ";", 
