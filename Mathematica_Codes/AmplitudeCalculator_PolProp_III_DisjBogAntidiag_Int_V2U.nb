Cell[BoxData[
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", " ", "340"}], ",", 
    RowBox[{"r", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"c", "=", "0"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "\[LessEqual]", "14"}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"j", "=", 
          RowBox[{"i", "+", "1"}]}], ",", 
         RowBox[{"j", "\[LessEqual]", "14"}], ",", 
         RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"SPSequence", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "i"}], "]"}], "]"}], " ", ">", " ", 
             RowBox[{"SPSequence", "[", 
              RowBox[{"[", 
               RowBox[{"r", ",", "j"}], "]"}], "]"}]}], ",", 
            RowBox[{"c", "=", 
             RowBox[{"c", "+", "1"}]}]}], "]"}], ";"}]}], "]"}]}], "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"AmplSign", "[", 
       RowBox[{"[", "r", "]"}], "]"}], "=", 
      RowBox[{"Mod", "[", 
       RowBox[{
        RowBox[{"c", "+", 
         RowBox[{"SignFlip", "[", 
          RowBox[{"[", "r", "]"}], "]"}]}], ",", "2"}], "]"}]}], ";"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}]], "Input",
