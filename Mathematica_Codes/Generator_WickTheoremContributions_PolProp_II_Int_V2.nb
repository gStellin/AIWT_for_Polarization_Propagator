Cell[CellGroupData[{

Cell["Separation between skeleton and composite diagrams", "Subsection",
 CellChangeTimes->{{3.874644843789677*^9, 3.8746448545752873`*^9}, {
  3.889778687121766*^9, 3.8897786991771154`*^9}, {3.911898216018196*^9, 
  3.911898239200224*^9}},ExpressionUUID->"bf7f62d5-994f-4148-8484-\
6316b4ffc224"],

Cell["\<\
Contributions which correspond to a first-order conjoint diagram with a \
dressed one-body propagator are separated from the skeleton second-order \
diagrams. Composite (skeleton) diagrams are found to be 2304 (1728) in total. \
\>", "Text",
 CellChangeTimes->{{3.883680330036955*^9, 3.8836804885586143`*^9}, {
  3.8836805700695734`*^9, 3.883680650666025*^9}, {3.892114247327975*^9, 
  3.892114254704054*^9}, {3.911898128554555*^9, 
  3.9118981954843397`*^9}},ExpressionUUID->"315aa5fa-b19e-4f08-9010-\
e0f8e92adee3"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"AconjSkel", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "4032"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "6"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"AconjComp", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "4032"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "6"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"m", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"n", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"r", "=", "1"}], ",", 
   RowBox[{"r", "\[LessEqual]", " ", "4032"}], ",", 
   RowBox[{"r", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"IfDress1stOrdP1", "=", "0"}], ";", "\[IndentingNewLine]", 
    RowBox[{"IfDress1stOrdP2", " ", "=", "0"}], ";", "\[IndentingNewLine]", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"j", "=", "1"}], ",", 
      RowBox[{"j", "\[LessEqual]", " ", "6"}], ",", 
      RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Aconjsort", "[", 
            RowBox[{"[", 
             RowBox[{"r", ",", "j"}], "]"}], "]"}], "\[Equal]", 
           RowBox[{"{", 
            RowBox[{"1", ",", "2"}], "}"}]}], "  ", "||", " ", 
          RowBox[{
           RowBox[{"Aconjsort", "[", 
            RowBox[{"[", 
             RowBox[{"r", ",", "j"}], "]"}], "]"}], "\[Equal]", 
           RowBox[{"{", 
            RowBox[{"1", ",", "3"}], "}"}]}], " ", "||", "  ", 
          RowBox[{
           RowBox[{"Aconjsort", "[", 
            RowBox[{"[", 
             RowBox[{"r", ",", "j"}], "]"}], "]"}], "\[Equal]", 
           RowBox[{"{", 
            RowBox[{"1", ",", "4"}], "}"}]}], " ", "||", " ", 
          RowBox[{
           RowBox[{"Aconjsort", "[", 
            RowBox[{"[", 
             RowBox[{"r", ",", "j"}], "]"}], "]"}], "\[Equal]", 
           RowBox[{"{", 
            RowBox[{"2", ",", "3"}], "}"}]}], " ", "||", " ", 
          RowBox[{
           RowBox[{"Aconjsort", "[", 
            RowBox[{"[", 
             RowBox[{"r", ",", "j"}], "]"}], "]"}], "\[Equal]", 
           RowBox[{"{", 
            RowBox[{"2", ",", "4"}], "}"}]}], " ", "||", " ", 
          RowBox[{
           RowBox[{"Aconjsort", "[", 
            RowBox[{"[", 
             RowBox[{"r", ",", "j"}], "]"}], "]"}], "\[Equal]", 
           RowBox[{"{", 
            RowBox[{"3", ",", "4"}], "}"}]}]}], " ", ",", 
         RowBox[{"IfDress1stOrdP1", "=", "1"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Aconjsort", "[", 
            RowBox[{"[", 
             RowBox[{"r", ",", "j"}], "]"}], "]"}], "\[Equal]", 
           RowBox[{"{", 
            RowBox[{"5", ",", "6"}], "}"}]}], "  ", "||", " ", 
          RowBox[{
           RowBox[{"Aconjsort", "[", 
            RowBox[{"[", 
             RowBox[{"r", ",", "j"}], "]"}], "]"}], "\[Equal]", 
           RowBox[{"{", 
            RowBox[{"5", ",", "7"}], "}"}]}], " ", "||", "  ", 
          RowBox[{
           RowBox[{"Aconjsort", "[", 
            RowBox[{"[", 
             RowBox[{"r", ",", "j"}], "]"}], "]"}], "\[Equal]", 
           RowBox[{"{", 
            RowBox[{"5", ",", "8"}], "}"}]}], " ", "||", " ", 
          RowBox[{
           RowBox[{"Aconjsort", "[", 
            RowBox[{"[", 
             RowBox[{"r", ",", "j"}], "]"}], "]"}], "\[Equal]", 
           RowBox[{"{", 
            RowBox[{"6", ",", "7"}], "}"}]}], " ", "||", " ", 
          RowBox[{
           RowBox[{"Aconjsort", "[", 
            RowBox[{"[", 
             RowBox[{"r", ",", "j"}], "]"}], "]"}], "\[Equal]", 
           RowBox[{"{", 
            RowBox[{"6", ",", "8"}], "}"}]}], " ", "||", " ", 
          RowBox[{
           RowBox[{"Aconjsort", "[", 
            RowBox[{"[", 
             RowBox[{"r", ",", "j"}], "]"}], "]"}], "\[Equal]", 
           RowBox[{"{", 
            RowBox[{"7", ",", "8"}], "}"}]}]}], " ", ",", 
         RowBox[{"IfDress1stOrdP2", "=", "1"}]}], "]"}], ";"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"If", "[", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"IfDress1stOrdP1", " ", "\[Equal]", "1"}], " ", "||", 
       RowBox[{"IfDress1stOrdP2", " ", "\[Equal]", "1"}]}], " ", ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"AconjComp", "[", 
         RowBox[{"[", "m", "]"}], "]"}], "=", 
        RowBox[{"Aconjsort", "[", 
         RowBox[{"[", "r", "]"}], "]"}]}], ";", 
       RowBox[{"m", "++"}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"AconjSkel", "[", 
         RowBox[{"[", "n", "]"}], "]"}], "=", 
        RowBox[{"Aconjsort", "[", 
         RowBox[{"[", "r", "]"}], "]"}]}], ";", 
       RowBox[{"n", "++"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Mod", "[", 
         RowBox[{"r", ",", "1000"}], "]"}], "\[Equal]", "0"}], " ", "||", " ", 
       RowBox[{"r", "\[Equal]", "4032"}]}], ",", 
      RowBox[{"Print", "[", 
       RowBox[{
       "\"\<Loop \>\"", ",", " ", "r", ",", " ", "\"\< completed and \>\"", 
        ",", " ", 
        RowBox[{"n", "-", "1"}], ",", " ", 
        "\"\< conjoint skeleton contributions found.\>\""}], "]"}]}], " ", 
     "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Mod", "[", 
         RowBox[{"r", ",", "1000"}], "]"}], "\[Equal]", "0"}], " ", "||", " ", 
       RowBox[{"r", "\[Equal]", "4032"}]}], ",", 
      RowBox[{"Print", "[", 
       RowBox[{
       "\"\<Loop \>\"", ",", "r", ",", " ", "\"\< completed and \>\"", ",", 
        " ", 
        RowBox[{"m", "-", "1"}], ",", " ", 
        "\"\< conjoint composite contributions found.\>\""}], "]"}]}], " ", 
     "]"}], ";"}]}], "\[IndentingNewLine]", "]"}]}], "Input",
 CellChangeTimes->{{3.8901928636779566`*^9, 3.8901931699216623`*^9}, {
