   3.888406464599372*^9, 3.8884064696245165`*^9}, {3.8884067207057405`*^9, 
   3.8884067212108355`*^9}, {3.888407229646407*^9, 3.888407229904756*^9}, {
   3.889530703366559*^9, 3.8895307097735305`*^9}, {3.88953201045216*^9, 
