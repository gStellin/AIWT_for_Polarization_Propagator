Cell[CellGroupData[{

Cell["\<\
Disjoint direct diagrams with dressed single-particle propagator on the left\
\>", "Section",
 CellChangeTimes->{{3.8747474873699455`*^9, 3.8747475586269774`*^9}, {
  3.8836821843140464`*^9, 3.883682185030684*^9}, {3.8886425005080795`*^9, 
  3.8886425041635475`*^9}},ExpressionUUID->"7e638cb3-d287-469f-a6e9-\
542ecfbcb6d9"],

Cell["\<\
Direct diagrams with unperturbed 1-body propagator on the right are \
processed. Their initial number is 768 in total.\
\>", "Text",
 CellChangeTimes->{{3.8836813753146152`*^9, 3.88368147043666*^9}, {
  3.8836820487185183`*^9, 3.88368205024879*^9}, {3.883682180609577*^9, 
  3.883682181425793*^9}, {3.8895326177197933`*^9, 3.8895326190004883`*^9}, {
  3.8927832371377015`*^9, 3.892783237556256*^9}, {3.911906600155179*^9, 
  3.911906604269761*^9}},ExpressionUUID->"ce5031ea-656c-4cfe-8fc8-\
00b227728e99"],

Cell[BoxData[
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"u", "=", "1"}], ",", 
    RowBox[{"u", "\[LessEqual]", "768"}], ",", 
    RowBox[{"u", "++"}], ",", 
    RowBox[{"Print", "[", 
     RowBox[{"AdisjDirLeft", "[", 
      RowBox[{"[", "u", "]"}], "]"}], "]"}]}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.8747489659683185`*^9, 3.874748971262155*^9}, {
   3.874750278096981*^9, 3.874750278551973*^9}, {3.8747509325127506`*^9, 
   3.8747509328870687`*^9}, {3.8765741047757406`*^9, 3.8765741055275917`*^9}, 
   3.8831148837672863`*^9, {3.883127184776041*^9, 3.8831271902198343`*^9}, {
   3.888406464599372*^9, 3.8884064696245165`*^9}, {3.8884067207057405`*^9, 
   3.8884067212108355`*^9}, {3.888407229646407*^9, 3.888407229904756*^9}, {
   3.889530703366559*^9, 3.8895307097735305`*^9}, {3.88953201045216*^9, 
   3.8895320107683506`*^9}, 3.889532405351248*^9, {3.889533182253409*^9, 
   3.8895331826663556`*^9}, {3.892802705556965*^9, 3.892802712929164*^9}, {
   3.892802760028386*^9, 3.892802767974951*^9}, {3.892802813093663*^9, 
   3.8928028356507096`*^9}, {3.9118985092703266`*^9, 3.911898525243123*^9}, {
   3.9119016297238483`*^9, 3.9119016363951025`*^9}, {3.9119683357675347`*^9, 
   3.9119683458631215`*^9}},ExpressionUUID->"e95004de-3093-4ae0-aa22-\
5146aee3bab0"],

Cell[CellGroupData[{

Cell["Filtration of the fully-contracted terms", "Subsection",
 CellChangeTimes->{{3.874644843789677*^9, 3.8746448545752873`*^9}, {
   3.883112065177337*^9, 3.883112118360941*^9}, {3.8831146011227875`*^9, 
   3.8831146201744213`*^9}, {3.883115184479356*^9, 3.8831151965813236`*^9}, {
   3.8884058729915524`*^9, 3.8884058731821747`*^9}, {3.892800153537215*^9, 
   3.8928001610648518`*^9}, {3.897041751372193*^9, 3.8970417738128204`*^9}, {
   3.8970432846114845`*^9, 3.897043286022911*^9}, 
   3.911883818478182*^9},ExpressionUUID->"99699e50-04aa-418d-81b2-\
ba869d369653"],

Cell[TextData[{
 "Filtration of the left-dressed disjoint direct fully-contracted terms. At \
second order, transpositions between single particles of both different \
vertices (external permutations) and the same vertex (internal permutations) \
are possible. Fully-contracted terms which are mapped one another by the \
permutation ",
 StyleBox["p \[RightTeeArrow] q",
  FontSlant->"Italic"],
 "  and ",
 StyleBox["r \[RightTeeArrow] s",
  FontSlant->"Italic"],
 "  and ",
 StyleBox["p \[RightTeeArrow] q, r \[RightTeeArrow] s",
  FontSlant->"Italic"],
 " are identified and summed, eventually canceling out the factor ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"2", "!"}], ")"}], "2"],
    FontSlant->"Italic"], TraditionalForm]],ExpressionUUID->
  "7340ac42-fe07-445e-917d-7492e78ffaec"],
 " at the denominator, arising from the partial antisymmetry of the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox[
     RowBox[{" ", "V"}], "_"], "pqrs"], TraditionalForm]],ExpressionUUID->
  "ddfc57c4-3e59-47a6-908b-2f7ba35c030f"],
 " interaction vertex. Simultaneously, diagrams which are mapped one another \
by the permutation ",
 StyleBox["t \[RightTeeArrow] u",
  FontSlant->"Italic"],
 "  and ",
 StyleBox["v \[RightTeeArrow] w",
  FontSlant->"Italic"],
 "  and ",
 StyleBox["t \[RightTeeArrow] u, v \[RightTeeArrow] w",
  FontSlant->"Italic"],
 " are also identified and summed, eventually canceling out the other ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"2", "!"}], ")"}], "2"], TraditionalForm]],
  FontSlant->"Italic",ExpressionUUID->"6c61ae65-aa37-4df2-bd0b-80f166baf24f"],
 StyleBox[" ",
  FontSlant->"Italic"],
 "factor at the denominator, arising from the partial antisymmetry of the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox[
     RowBox[{" ", "V"}], "_"], "tuvw"], TraditionalForm]],ExpressionUUID->
  "0dc6cdb4-d596-498d-8568-691e0c432cf2"],
 " interaction vertex. The procedure is repeated 2 times, assuming in the \
second case, a permutation of the indices of the two vertices. As a result, \
38 second-order left-dressed disjoint direct fully-contracted terms are found."
}], "Text",
 CellChangeTimes->{{3.8836806708732624`*^9, 3.883680671103075*^9}, {
   3.8836807100445924`*^9, 3.8836809748029747`*^9}, {3.88368106035993*^9, 
   3.88368123630155*^9}, {3.8884066008391533`*^9, 3.8884066027299986`*^9}, {
   3.8897788646156874`*^9, 3.8897788665710464`*^9}, {3.8926969246265383`*^9, 
   3.8926970411577735`*^9}, {3.892698767515374*^9, 3.8926988019171734`*^9}, {
