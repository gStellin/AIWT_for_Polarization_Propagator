  3.9191686708510203`*^9}},ExpressionUUID->"5e549683-39fa-4e15-a387-\
f635d0a1982d"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["\[CapitalPi]", "acdb"], 
    RowBox[{
     SubscriptBox["g", "1"], 
     SubscriptBox["g", "3"], 
     SubscriptBox["g", "4"], 
     SubscriptBox["g", "2"]}]], TraditionalForm]],ExpressionUUID->
  "7ca1a4e3-55a2-4c84-a28b-0efff7c1b317"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"t", ",", 
      RowBox[{"t", "'"}]}], ")"}], 
    SubscriptBox["|", 
     RowBox[{"second", " ", "order"}]]}], TraditionalForm]],ExpressionUUID->
  "c9d3f713-74c1-4b12-b399-cb08c9f81caf"],
 "     = -\[ImaginaryI] ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     FractionBox[
      RowBox[{"-", "\[ImaginaryI]"}], "\[HBar]"], ")"}], "2"], 
   TraditionalForm]],ExpressionUUID->"4b7dc434-e673-431d-9860-4d47c843dad2"],
 " ",
 Cell[BoxData[
  FormBox[
