7864c5b628c4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"u", "=", "1"}], ",", 
    RowBox[{"u", "\[LessEqual]", "768"}], ",", 
    RowBox[{"u", "++"}], ",", 
    RowBox[{"Print", "[", 
     RowBox[{"AdisjDirRight", "[", 
      RowBox[{"[", "u", "]"}], "]"}], "]"}]}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.8747489659683185`*^9, 3.874748971262155*^9}, {
