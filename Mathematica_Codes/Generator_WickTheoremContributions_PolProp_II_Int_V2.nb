Cell[CellGroupData[{

Cell["\<\
Disjoint Bogoliubov diagrams with diagonally-and-antidiagonally dressed \
single-particle propagators\
\>", "Section",
 CellChangeTimes->{{3.8747474873699455`*^9, 3.8747475345907583`*^9}, {
  3.8884847013485146`*^9, 3.888484713293386*^9}, {3.888642450412324*^9, 
  3.8886424579370823`*^9}, {3.8886426420738716`*^9, 3.888642643993717*^9}, {
  3.9119698604458523`*^9, 
  3.9119698675123563`*^9}},ExpressionUUID->"d563faab-d72a-43c0-a1d0-\
bdd8ca77e7c2"],

Cell["\<\
Bogoliubov diagrams with dressed 1-body propagator on the diagonal and on the \
antidiagonal are processed. Their initial number is 288 in total.\
\>", "Text",
 CellChangeTimes->{{3.8836813753146152`*^9, 3.88368147043666*^9}, {
  3.8836820487185183`*^9, 3.88368205024879*^9}, {3.883682180609577*^9, 
  3.883682181425793*^9}, {3.8895326177197933`*^9, 3.8895326190004883`*^9}, {
  3.8927832371377015`*^9, 3.892783237556256*^9}, {3.911906600155179*^9, 
  3.911906604269761*^9}, {3.9119674719442787`*^9, 3.9119674726562777`*^9}, {
  3.911968431859207*^9, 3.9119684438166695`*^9}, {3.9119698304105034`*^9, 
  3.9119698456076183`*^9}, {3.911975132893018*^9, 
  3.9119751479176073`*^9}},ExpressionUUID->"31514439-692a-449e-a4b8-\
7d1482094a14"],

Cell[BoxData[
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"u", "=", "1"}], ",", 
    RowBox[{"u", "\[LessEqual]", "288"}], ",", 
    RowBox[{"u", "++"}], ",", 
    RowBox[{"Print", "[", 
     RowBox[{"AdisjBogoliubov", "[", 
      RowBox[{"[", "u", "]"}], "]"}], "]"}]}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.8747489659683185`*^9, 3.874748971262155*^9}, {
   3.874750278096981*^9, 3.874750278551973*^9}, {3.8747509325127506`*^9, 
   3.8747509328870687`*^9}, {3.8765741047757406`*^9, 3.8765741055275917`*^9}, 
   3.8831148837672863`*^9, {3.883127184776041*^9, 3.8831271902198343`*^9}, {
   3.888406464599372*^9, 3.8884064696245165`*^9}, {3.8884067207057405`*^9, 
   3.8884067212108355`*^9}, {3.888407229646407*^9, 3.888407229904756*^9}, {
   3.889530703366559*^9, 3.8895307097735305`*^9}, {3.88953201045216*^9, 
   3.8895320107683506`*^9}, 3.889532405351248*^9, {3.889533182253409*^9, 
   3.8895331826663556`*^9}, {3.892802705556965*^9, 3.892802712929164*^9}, {
   3.892802760028386*^9, 3.892802767974951*^9}, {3.892802813093663*^9, 
   3.8928028356507096`*^9}, {3.9118985092703266`*^9, 3.911898525243123*^9}, {
   3.9119016297238483`*^9, 3.9119016363951025`*^9}, {3.9119683357675347`*^9, 
   3.911968361556467*^9}, {3.91196844799314*^9, 3.9119684485130873`*^9}, {
   3.911969731887582*^9, 
   3.9119697423153825`*^9}},ExpressionUUID->"b81a4c88-00d6-4c33-a703-\
6b7a1df35578"],

Cell[CellGroupData[{

Cell["Filtration of the fully-contracted terms", "Subsection",
 CellChangeTimes->{{3.874644843789677*^9, 3.8746448545752873`*^9}, {
   3.883112065177337*^9, 3.883112118360941*^9}, {3.8831146011227875`*^9, 
   3.8831146201744213`*^9}, {3.883115184479356*^9, 3.8831151965813236`*^9}, {
   3.8884058729915524`*^9, 3.8884058731821747`*^9}, {3.892800153537215*^9, 
   3.8928001610648518`*^9}, {3.897041751372193*^9, 3.8970417738128204`*^9}, {
   3.8970432846114845`*^9, 3.897043286022911*^9}, 
   3.911883818478182*^9},ExpressionUUID->"2c4dbb9c-07db-4f28-af6b-\
fc208063057a"],

Cell[TextData[{
 "Filtration of the diagonally-and-antidiagonally-dressed disjoint  \
fully-contracted terms. At second order, transpositions between single \
particles of both different vertices (external permutations) and the same \
vertex (internal permutations) are possible. Fully-contracted terms which \
Bogoliubov are mapped one another by the permutation ",
 StyleBox["p \[RightTeeArrow] q",
  FontSlant->"Italic"],
 "  and ",
 StyleBox["r \[RightTeeArrow] s",
  FontSlant->"Italic"],
 "  and ",
 StyleBox["p \[RightTeeArrow] q, r \[RightTeeArrow] s",
  FontSlant->"Italic"],
 " are identified and summed, eventually canceling out the factor ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"2", "!"}], ")"}], "2"],
    FontSlant->"Italic"], TraditionalForm]],ExpressionUUID->
  "be8dcacb-3bb9-44a5-9a24-2a95e766ce94"],
 " at the denominator, arising from the partial antisymmetry of the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox[
     RowBox[{" ", "V"}], "_"], "pqrs"], TraditionalForm]],ExpressionUUID->
  "4eb3b687-d168-4db9-bfce-d7cd87327328"],
 " interaction vertex. Simultaneously, diagrams which are mapped one another \
by the permutation ",
 StyleBox["t \[RightTeeArrow] u",
  FontSlant->"Italic"],
 "  and ",
 StyleBox["v \[RightTeeArrow] w",
  FontSlant->"Italic"],
 "  and ",
 StyleBox["t \[RightTeeArrow] u, v \[RightTeeArrow] w",
  FontSlant->"Italic"],
 " are also identified and summed, eventually canceling out the other ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"2", "!"}], ")"}], "2"], TraditionalForm]],
  FontSlant->"Italic",ExpressionUUID->"d38cf484-fdbf-48e3-8f8c-cb963d5774a4"],
 StyleBox[" ",
  FontSlant->"Italic"],
 "factor at the denominator, arising from the partial antisymmetry of the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox[
     RowBox[{" ", "V"}], "_"], "tuvw"], TraditionalForm]],ExpressionUUID->
  "45f30d70-fd49-4124-8f42-5d06ca357194"],
 " interaction vertex. The procedure is repeated 2 times, assuming in the \
second case, a permutation of the indices of the two vertices. As a result, \
16 second-order diagonally-and-antidiagonally-dressed disjoint Bogoliubov \
fully-contracted terms are found."
}], "Text",
 CellChangeTimes->{{3.8836806708732624`*^9, 3.883680671103075*^9}, {
   3.8836807100445924`*^9, 3.8836809748029747`*^9}, {3.88368106035993*^9, 
   3.88368123630155*^9}, {3.8884066008391533`*^9, 3.8884066027299986`*^9}, {
   3.8897788646156874`*^9, 3.8897788665710464`*^9}, {3.8926969246265383`*^9, 
   3.8926970411577735`*^9}, {3.892698767515374*^9, 3.8926988019171734`*^9}, {
   3.892698944167777*^9, 3.89269895025534*^9}, 3.897980551930337*^9, {
   3.9118989337632127`*^9, 3.9118991105611753`*^9}, {3.911899164309193*^9, 
   3.911899190598539*^9}, {3.9119016504202213`*^9, 3.9119016541753263`*^9}, {
   3.9119016871370583`*^9, 3.911901688588021*^9}, {3.911902046055127*^9, 
   3.911902134247444*^9}, {3.9119031827654963`*^9, 3.9119031947466836`*^9}, {
   3.9119032265890102`*^9, 3.911903232121472*^9}, {3.9119066756959314`*^9, 
   3.9119067606544895`*^9}, {3.9119674038631635`*^9, 3.911967411543034*^9}, {
   3.9119684536302376`*^9, 3.9119684697264695`*^9}, {3.911969879724894*^9, 
   3.9119699273338194`*^9}},ExpressionUUID->"e9b32039-a25d-4b46-9071-\
32bc9657dbe5"],

