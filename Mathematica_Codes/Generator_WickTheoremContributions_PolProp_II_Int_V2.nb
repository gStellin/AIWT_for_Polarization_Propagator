  3.9119682559798*^9}},ExpressionUUID->"31af4118-9479-4c8b-ab7e-ddaf945c3348"],

Cell["\<\
Direct diagrams with dressed 1-body propagator on the left and on the right \
are processed. Their initial number is 288 in total.\
\>", "Text",
 CellChangeTimes->{{3.8836813753146152`*^9, 3.88368147043666*^9}, {
  3.8836820487185183`*^9, 3.88368205024879*^9}, {3.883682180609577*^9, 
  3.883682181425793*^9}, {3.8895326177197933`*^9, 3.8895326190004883`*^9}, {
  3.8927832371377015`*^9, 3.892783237556256*^9}, {3.911906600155179*^9, 
  3.911906604269761*^9}, {3.9119674719442787`*^9, 3.9119674726562777`*^9}, {
  3.911968431859207*^9, 3.9119684438166695`*^9}, {3.9119751853547926`*^9, 
  3.911975186571862*^9}},ExpressionUUID->"d0dba037-8506-4ee8-a925-\
b2d0839d7503"],

Cell[BoxData[
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"u", "=", "1"}], ",", 
    RowBox[{"u", "\[LessEqual]", "768"}], ",", 
    RowBox[{"u", "++"}], ",", 
    RowBox[{"Print", "[", 
     RowBox[{"AdisjDirect", "[", 
      RowBox[{"[", "u", "]"}], "]"}], "]"}]}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.8747489659683185`*^9, 3.874748971262155*^9}, {
   3.874750278096981*^9, 3.874750278551973*^9}, {3.8747509325127506`*^9, 
   3.8747509328870687`*^9}, {3.8765741047757406`*^9, 3.8765741055275917`*^9}, 
   3.8831148837672863`*^9, {3.883127184776041*^9, 3.8831271902198343`*^9}, {
   3.888406464599372*^9, 3.8884064696245165`*^9}, {3.8884067207057405`*^9, 
   3.8884067212108355`*^9}, {3.888407229646407*^9, 3.888407229904756*^9}, {
   3.889530703366559*^9, 3.8895307097735305`*^9}, {3.88953201045216*^9, 
   3.8895320107683506`*^9}, 3.889532405351248*^9, {3.889533182253409*^9, 
