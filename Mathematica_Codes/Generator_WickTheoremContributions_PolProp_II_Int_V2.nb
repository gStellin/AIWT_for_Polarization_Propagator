Cell[CellGroupData[{

Cell["\<\
Disjoint direct diagrams with dressed single-particle propagator on the right\
\>", "Section",
 CellChangeTimes->{{3.8747474873699455`*^9, 3.8747475345907583`*^9}, {
  3.8886424734570084`*^9, 
  3.888642477121547*^9}},ExpressionUUID->"342b4f06-a82e-4a85-9848-\
3cb06a9f077f"],

Cell["\<\
Direct diagrams with unperturbed 1-body propagator on the left are processed. \
Their initial number is 768 in total.\
\>", "Text",
 CellChangeTimes->{{3.8836813753146152`*^9, 3.88368147043666*^9}, {
  3.8836820487185183`*^9, 3.88368205024879*^9}, {3.883682180609577*^9, 
