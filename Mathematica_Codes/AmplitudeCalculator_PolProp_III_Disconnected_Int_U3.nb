       RowBox[{"1", ",", "1", ",", "2", ",", "1", ",", "2", ",", "2"}], "}"}],
       ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2", ",", "2", ",", "1", ",", "2", ",", "2"}], 
       "}"}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"UMult", " ", "=", 
   RowBox[{"{", 
    RowBox[{
