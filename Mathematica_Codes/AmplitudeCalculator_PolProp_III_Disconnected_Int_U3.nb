       ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "1", ",", "1", ",", "2", ",", "1", ",", "2"}], "}"}],
       ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "1", ",", "2", ",", "1", ",", "2", ",", "1"}], "}"}],
       ",", 
