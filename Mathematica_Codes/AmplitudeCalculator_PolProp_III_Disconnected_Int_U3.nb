   3.898083084444205*^9, 3.898083085491214*^9}, 3.9095751880600643`*^9, 
   3.909575699205435*^9, 3.9095771968831463`*^9, {3.9144023114331436`*^9, 
   3.914402317457941*^9}, {3.914402598071266*^9, 3.914402623390375*^9}, {
   3.914406253933094*^9, 3.9144062545767326`*^9}, 3.9144102343033714`*^9, {
   3.9145743880163116`*^9, 3.9145744537915297`*^9}},
