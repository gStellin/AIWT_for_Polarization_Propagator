Cell[BoxData[
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", "22"}], ",", 
    RowBox[{"r", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"SignFlip", "[", 
       RowBox[{"[", "r", "]"}], "]"}], "=", "0"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "0"}], ",", 
       RowBox[{"i", "\[LessEqual]", " ", "4"}], ",", " ", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"SPSequence", "[", 
          RowBox[{"[", 
           RowBox[{"r", ",", 
            RowBox[{
             RowBox[{"2", "i"}], "+", "1"}]}], "]"}], "]"}], " ", "=", " ", 
         RowBox[{"Abs", "[", 
          RowBox[{"GGFSParticle", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", 
             RowBox[{"i", "+", "1"}], ",", "1"}], "]"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"SPSequence", "[", 
          RowBox[{"[", 
           RowBox[{"r", ",", 
            RowBox[{
             RowBox[{"2", "i"}], "+", "2"}]}], "]"}], "]"}], " ", "=", " ", 
         RowBox[{"Abs", "[", 
          RowBox[{"GGFSParticle", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", 
             RowBox[{"i", "+", "1"}], ",", "2"}], "]"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"SignFlip", "[", 
          RowBox[{"[", "r", "]"}], "]"}], " ", "=", " ", 
         RowBox[{
          RowBox[{"SignFlip", "[", 
           RowBox[{"[", "r", "]"}], "]"}], " ", "+", " ", 
          RowBox[{"SignFlipBogAntidiag", " ", "[", 
           RowBox[{"[", 
            RowBox[{"r", ",", 
             RowBox[{"i", "+", "1"}]}], "]"}], "]"}]}]}], ";"}]}], 
      "\[IndentingNewLine]", "]"}]}]}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.8880567089287558`*^9, 3.888056881383081*^9}, {
