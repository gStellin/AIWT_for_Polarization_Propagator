Cell[CellGroupData[{

Cell["Selection of the Nambu component of the one-body potential", "Section",
 CellChangeTimes->{{3.9120816659877415`*^9, 
  3.9120817133455973`*^9}},ExpressionUUID->"5ce447e0-a27f-4b38-881e-\
a0ec67536240"],

Cell[TextData[{
 "The analytical results presented henceforth refer to an element of the \
product between ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["V", "_"], "(", 
    SubscriptBox["t", "1"]}], TraditionalForm]],ExpressionUUID->
  "6a2c85e8-e8ef-41fb-b639-0bcd8d44d9f3"],
 "), ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "2"]}], TraditionalForm]],ExpressionUUID->
  "350dedde-3f05-46a5-b136-6a4f50317080"],
 ") and the second-quantization operators with external single-particle \
indices. At second order, such elements are specified by the two indices that \
determine the Nambu component, ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], 
    RowBox[{
     SubscriptBox["g", "5"], 
     SubscriptBox["g", "6"]}]], TraditionalForm]],ExpressionUUID->
  "c77197e6-e316-435d-920d-ef34a9af0f9f"],
 " , of the auxiliary one-body potential ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "2"]}], TraditionalForm]],ExpressionUUID->
  "4de560c3-5802-4cf1-9005-2f35f34d3d47"],
 "), ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "5"], TraditionalForm]],ExpressionUUID->
  "46d41041-7fa2-446c-9f01-afa31c95d53b"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "6"], TraditionalForm]],ExpressionUUID->
  "87082fdc-58d2-4b09-9338-400f742e21ea"],
 ", stored in the array \[OpenCurlyQuote]UNambu\[CloseCurlyQuote]. As a \
result,  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "5"], TraditionalForm]],ExpressionUUID->
  "8a55e8d2-6492-4e16-b402-2a8a3d39e91f"],
 "=1 and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["g", "6"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "a2d11b5b-08a0-4f46-a58c-b93caafdfe8b"],
 " denote the component ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "11"], TraditionalForm]],ExpressionUUID->
  "a1e5ae84-cade-4e02-96f0-676aebbc3a89"],
 " and is encoded by \[OpenCurlyQuote]UNambu[[1]]\[CloseCurlyQuote] . \
Analogously,  ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "22"], TraditionalForm]],ExpressionUUID->
  "33ba30d0-eea8-402c-9c2c-f393e86d2a95"],
 " is mapped to \[OpenCurlyQuote]UNambu[[4]]\[CloseCurlyQuote], ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "21"], TraditionalForm]],ExpressionUUID->
  "7c6f7864-b259-452d-8ab9-a3a855ef7536"],
 " to \[OpenCurlyQuote]UNambu[[3]]\[CloseCurlyQuote] and ",
 Cell[BoxData[
  FormBox[
