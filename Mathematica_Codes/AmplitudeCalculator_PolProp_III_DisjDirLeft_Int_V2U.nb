 CellChangeTimes->{{3.9112976535209*^9, 3.9112977725088825`*^9}, {
  3.914391561196263*^9, 3.914391579599857*^9}, {3.914391657930671*^9, 
  3.9143916643697214`*^9}},ExpressionUUID->"2d33cec5-b5e9-44a1-8c68-\
c1451811a9d0"],

Cell[TextData[{
 "Single-particle indices \[OpenCurlyQuote]b\[CloseCurlyQuote] and \
\[OpenCurlyQuote]d\[CloseCurlyQuote] in Bogoliubov fully-contracted terms are \
involute. For their numeric counterpart, the following convention is adopted: \
\nIndex > 0 \[DoubleRightArrow] ",
 StyleBox["standard",
  FontSlant->"Italic"],
 "\nIndex < 0 \[DoubleRightArrow] ",
 StyleBox["involute",
  FontSlant->"Italic"],
 "."
}], "Text",
 CellChangeTimes->{{3.8874623260617843`*^9, 3.8874623745747523`*^9}, {
  3.88746257423927*^9, 3.887462578566905*^9}, {3.888312600987131*^9, 
  3.8883126358497353`*^9}, {3.91129488637901*^9, 
  3.911295044011321*^9}},ExpressionUUID->"fd35a5e7-1a31-4510-b78b-\
887a8d206cf9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Selection of the Nambu component of the one-body potential", "Section",
 CellChangeTimes->{{3.912081665987741*^9, 
  3.9120817133455973`*^9}},ExpressionUUID->"f7efa213-bb4c-4cb0-a2e2-\
e4f1f82e4d1f"],

Cell[TextData[{
 "The analytical results presented henceforth refer to an element of the \
product between ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["V", "_"], "(", 
     SubscriptBox["t", "1"], ")"}], ",", 
    RowBox[{
     OverscriptBox["V", "_"], "(", 
     SubscriptBox["t", "2"], ")"}], ",", 
    RowBox[{"U", "(", 
     SubscriptBox["t", "3"]}]}], TraditionalForm]],ExpressionUUID->
  "2e3d3725-a7ea-4ab3-8469-15a49e553b94"],
 ") and the second-quantization operators with external single-particle \
indices. The elements of  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "3"]}], TraditionalForm]],ExpressionUUID->
  "abfb364b-9322-4933-bb28-f69a2635cfeb"],
 ") are specified by the two indices that determine the Nambu component, ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], 
    RowBox[{
     SubscriptBox["g", "5"], 
     SubscriptBox["g", "6"]}]], TraditionalForm]],ExpressionUUID->
  "55ff7ded-37d1-4353-88c2-f05d480a2dea"],
 " , of the auxiliary one-body potential ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", 
    SubscriptBox["t", "3"]}], TraditionalForm]],ExpressionUUID->
  "e742c617-4544-4a8c-8b30-fa89c8e27b96"],
 "), ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "5"], TraditionalForm]],ExpressionUUID->
  "48d0088d-72af-4c69-977c-ec732e875f4c"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "6"], TraditionalForm]],ExpressionUUID->
  "5b78ff2b-5cc9-4975-a1cf-3a271eeab450"],
 ", stored in the array \[OpenCurlyQuote]UNambu\[CloseCurlyQuote]. As a \
result,  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["g", "5"], TraditionalForm]],ExpressionUUID->
  "2d8562ba-3d4e-4ecf-9acb-67de8b151911"],
 "=1 and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["g", "6"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "17485036-7f83-415b-a5c3-7dc039d6a9ef"],
 " denote the component ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "11"], TraditionalForm]],ExpressionUUID->
  "9f69e675-0687-4234-be98-632b885ada12"],
 " and is encoded by \[OpenCurlyQuote]UNambu[[1]]\[CloseCurlyQuote] . \
Analogously,  ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "22"], TraditionalForm]],ExpressionUUID->
  "2b543e32-519e-4a41-9a4b-825b0f52badb"],
 " is mapped to \[OpenCurlyQuote]UNambu[[4]]\[CloseCurlyQuote], ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "21"], TraditionalForm]],ExpressionUUID->
  "ad0eb148-79fa-4ff4-b1af-d85f8569428f"],
 " to \[OpenCurlyQuote]UNambu[[3]]\[CloseCurlyQuote] and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["u", "ef"], "12"], TraditionalForm]],ExpressionUUID->
  "c3e13862-922c-4a4b-b5a5-0d374df472df"],
 " to \[OpenCurlyQuote]UNambu[[2]]\[CloseCurlyQuote] ."
}], "Text",
 CellChangeTimes->{{3.912081776386461*^9, 3.9120818052616024`*^9}, {
  3.912081937013556*^9, 3.912082002664327*^9}, {3.912082104513921*^9, 
  3.912082421167441*^9}, {3.912082530467517*^9, 3.9120826433982725`*^9}, {
  3.912082706934461*^9, 3.912082894366768*^9}, {3.912673400031556*^9, 
  3.912673403518268*^9}, {3.9132022481604238`*^9, 3.9132022951233273`*^9}, {
  3.9143931925454082`*^9, 
