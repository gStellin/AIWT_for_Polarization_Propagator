Cell[CellGroupData[{

Cell["Definition of the auxiliary arrays", "Subsection",
 CellChangeTimes->{{3.888315173503672*^9, 3.888315249112604*^9}, {
  3.888315302609094*^9, 3.8883153149727306`*^9}, {3.888315800792353*^9, 
  3.888315802330164*^9}, {3.9077382535011215`*^9, 3.907738255398263*^9}, {
  3.907918473174707*^9, 
  3.907918504245359*^9}},ExpressionUUID->"0e4f9c96-7882-4e75-ade6-\
742230f1623a"],

Cell["\<\
Arrays specifying the Nambu indices (cf. NambuDisc), the operator type (cf. \
SQTypeDisc) and distinguishing internal from external single-particle indices \
(cf. IntExtDisc) are defined, in accordance with the conventions for the \
second-quantization operators in the header of the notebook. In particular, \
to external (internal) single-particle indices the value of \
\[OpenCurlyQuote]1\[CloseCurlyQuote] (\[OpenCurlyQuote]0\[CloseCurlyQuote]) \
is assigned, whereas for second-quantization operators of creation \
(annihilation) type the associated array entry is \[OpenCurlyQuote]0\
\[CloseCurlyQuote] (\[OpenCurlyQuote]1\[CloseCurlyQuote]). For Nambu indices, \
the convention is straightforward.\
\>", "Text",
 CellChangeTimes->{
  3.907738221565965*^9, {3.907738292370362*^9, 3.9077384065565405`*^9}, {
   3.907738452268018*^9, 3.9077384848449388`*^9}, {3.9077430709590244`*^9, 
   3.907743126073769*^9}, {3.9077450424291105`*^9, 3.907745076531563*^9}, {
   3.907918517166184*^9, 3.9079188444385037`*^9}, 3.9091515935484114`*^9, {
   3.9092041717880774`*^9, 3.9092041805155473`*^9}, {3.913217012543521*^9, 
   3.913217015018977*^9}, {3.9144047070502014`*^9, 3.9144047204374857`*^9}, {
   3.921692023954213*^9, 
   3.921692023972161*^9}},ExpressionUUID->"557f8b47-8735-4927-9f8e-\
ce3fe4288786"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"NambuDisc", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "1401"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "7"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", " ", "1401"}], ",", 
    RowBox[{"r", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"j", "=", "1"}], ",", 
       RowBox[{"j", "\[LessEqual]", " ", "7"}], ",", 
       RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"k", "=", "1"}], ",", 
          RowBox[{"k", "\[LessEqual]", "2"}], ",", 
          RowBox[{"k", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"CombDisc", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], 
              "\[LessEqual]", " ", "8"}], ",", 
             RowBox[{
              RowBox[{"NambuDisc", "[", 
               RowBox[{"[", 
                RowBox[{"r", ",", "j", ",", "k"}], "]"}], "]"}], "=", "1"}]}],
             "]"}], ";", "\[IndentingNewLine]", 
