                 RowBox[{"GGFTime", "[", 
                  RowBox[{"[", 
                   RowBox[{"r", ",", "i", ",", "1"}], "]"}], "]"}]], "/", 
                "\[HBar]"}]}], "+", 
              RowBox[{
               RowBox[{"(", " ", 
