Cell[CellGroupData[{

Cell["Definition of the Nambu component", "Subsection",
 CellChangeTimes->{{3.888315173503672*^9, 3.888315249112604*^9}, {
  3.888315302609094*^9, 3.8883153149727306`*^9}, {3.888315800792353*^9, 
  3.888315802330164*^9}, {3.9077382535011215`*^9, 
  3.907738255398263*^9}},ExpressionUUID->"fcec2caf-365e-4368-b31a-\
4d30ae8b5719"],

Cell["\<\
Four Nambu indices specify univocally each of the 16 Nambu components of the \
polarization propagator. Normal (anomalous) components possess an even (even \
or odd) number of \[OpenCurlyQuote]1\[CloseCurlyQuote] and \[OpenCurlyQuote]2\
\[CloseCurlyQuote] indices. In total, there are 6 normal (indices 1-6 of \
GPPNambu) and 10 anomalous components (indices 7-16 of GPPNambu) . Once \
\[OpenCurlyQuote]NppIdx\[CloseCurlyQuote] is specified, the Nambu component \
is fixed.\
\>", "Text",
 CellChangeTimes->{
  3.907738221565965*^9, {3.907738292370362*^9, 3.9077384065565405`*^9}, {
   3.907738452268018*^9, 3.9077384848449388`*^9}, {3.9077430709590244`*^9, 
   3.907743126073769*^9}, {3.9077450424291105`*^9, 3.907745076531563*^9}, {
   3.922883672854347*^9, 3.922883674057166*^9}, 
   3.9471616990850353`*^9},ExpressionUUID->"5014aa25-ee17-4f2d-9c93-\
70de70637bfd"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"GPPNambu", "=", 
    RowBox[{"Table", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "16"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", "1", ",", "4"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"GPPNambu", " ", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "1", ",", "1", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "1", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "1", ",", "2", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "1", ",", "1", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "2", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "2", ",", "2", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "1", ",", "2", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "2", ",", "1", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "1", ",", "1", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "1", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "1", ",", "2", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "1", ",", "1", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "2", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "1", ",", "2", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "2", ",", "1", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "2", ",", "2", ",", "1"}], "}"}]}], "}"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9077384870000844`*^9, 3.907738568137504*^9}, {
   3.907738604794718*^9, 3.907738715379074*^9}, {3.9077429827705345`*^9, 
   3.907743060204199*^9}, 3.907916082369351*^9, 
   3.947161716783978*^9},ExpressionUUID->"25fd01f1-5651-4673-a786-\
3d157602c29b"],

