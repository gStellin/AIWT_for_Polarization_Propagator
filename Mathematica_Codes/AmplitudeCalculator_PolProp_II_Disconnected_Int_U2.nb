 CellLabel->
  "In[190]:=",ExpressionUUID->"aa5dae87-28b8-4a31-96f4-65d0d5ba25d4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"r", "=", "1"}], ",", 
    RowBox[{"r", "\[LessEqual]", "NcMax"}], ",", 
    RowBox[{"r", "++"}], ",", "\[IndentingNewLine]", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "0"}], ",", 
      RowBox[{"i", "\[LessEqual]", " ", "3"}], ",", " ", 
      RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"SPSequence", "[", 
         RowBox[{"[", 
          RowBox[{"r", ",", 
           RowBox[{
            RowBox[{"2", "i"}], "+", "1"}]}], "]"}], "]"}], " ", "=", " ", 
        RowBox[{"Abs", "[", 
